{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Server (dotnet watch)",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "watch-server",
            "program": "${workspaceFolder}/qubic_doge_stats/bin/Debug/net10.0/qubic_doge_stats.dll",
            "args": [],
            "cwd": "${workspaceFolder}/qubic_doge_stats",
            "stopAtEntry": false,
            "serverReadyAction": {
                "action": "openExternally",
                "pattern": "\\bNow listening on:\\s+(https?://\\S+)"
            },
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Development"
            },
            "sourceFileMap": {
                "/Views": "${workspaceFolder}/Views"
            },
            "presentation": {
                "hidden": true
            }
        },
        {
            "name": "Browser (Chrome)",
            "type": "chrome",
            "request": "launch",
            "url": "http://localhost:5180",
            "presentation": {
                "hidden": true
            }
        }
    ],
    "compounds": [
        {
            "name": "Start App (F5)",
            "configurations": ["Server (dotnet watch)", "Browser (Chrome)"],
            "stopAll": true,
            "presentation": {
                "order": 1
            }
        }
    ]
}
