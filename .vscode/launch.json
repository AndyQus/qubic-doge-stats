{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Watch + Chrome (F5)",
            "type": "chrome",
            "request": "launch",
            "url": "http://localhost:5180",
            "preLaunchTask": "watch",
            "presentation": {
                "order": 1
            }
        },
        {
            "name": "Start App (build only)",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build",
            "program": "${workspaceFolder}/qubic_doge_stats/bin/Debug/net10.0/qubic_doge_stats.dll",
            "args": [],
            "cwd": "${workspaceFolder}/qubic_doge_stats",
            "stopAtEntry": false,
            "serverReadyAction": {
                "action": "openExternally",
                "pattern": "\\bNow listening on:\\s+(https?://\\S+)"
            },
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Development"
            },
            "sourceFileMap": {
                "/Views": "${workspaceFolder}/Views"
            },
            "presentation": {
                "order": 2
            }
        }
    ]
}
