                <HeaderContent>
                    <MudTh Style="color:var(--mud-palette-text-secondary); font-size:0.75rem;">Model</MudTh>
                    <MudTh Style="color:var(--mud-palette-text-secondary); font-size:0.75rem; text-align:right;">Hashrate</MudTh>
                    <MudTh Style="color:var(--mud-palette-text-secondary); font-size:0.75rem; text-align:right;">Power</MudTh>
                    <MudTh Style="color:#FFD700; font-size:0.75rem; text-align:right;">DOGE Rev. 24h</MudTh>
                    <MudTh Style="color:#345D9D; font-size:0.75rem; text-align:right;">LTC Rev. 24h</MudTh>
                    <MudTh Style="color:var(--mud-palette-text-secondary); font-size:0.75rem; text-align:right;">Profit 24h</MudTh>
                    <MudTh Style="color:var(--mud-palette-text-secondary); font-size:0.75rem; text-align:right;">Break-even</MudTh>
