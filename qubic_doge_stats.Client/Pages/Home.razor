                          Tooltip="Unique visitors in the last 7 days (by IP hash)." />
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <StatCard Icon="@Icons.Material.Filled.CalendarMonth"
                          Title="Unique This Month"
                          Value="@(_visitorStats is not null ? _visitorStats.UniqueVisitorsThisMonth.ToString("N0") : "–")"
