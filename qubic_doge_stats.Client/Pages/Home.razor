    private void BuildEpochTimelineData()
    {
        _epochTimelineSeries = [];
        _epochTimelineLabels = [];

        var currentEpoch = _latest?.QubicEpoch ?? 0;
        if (currentEpoch == 0 || _fullHistory.Count == 0) return;

        // Filter by epoch tag — includes early-reporting snapshots before 12:00 UTC
        var epochData = _fullHistory
            .Where(h => h.QubicEpoch == currentEpoch)
            .OrderBy(h => h.Timestamp)
            .ToList();

        if (epochData.Count == 0) return;

        // Use Wed 12:00 UTC boundary of this epoch as reference start;
        // clamp backwards if RPC reported the epoch a few minutes early.
        var epochStart = GetEpochStart(epochData.Last().Timestamp.UtcDateTime);
        var actualStart = epochData[0].Timestamp.UtcDateTime < epochStart
            ? epochData[0].Timestamp.UtcDateTime
            : epochStart;

        string[] allDays = ["Sun", "Mon", "Tue", "Wed", "Thu", "Fri", "Sat"];

        var byDay = epochData
            .GroupBy(h => (int)((h.Timestamp.UtcDateTime - actualStart).TotalHours / 24))
            .Where(g => g.Key >= 0 && g.Key < 7)
            .OrderBy(g => g.Key)
            .ToList();

        if (byDay.Count == 0) return;

        var timelineData = byDay.Select(g => g.Average(h => ToTeraHashPerSecond(h.Hashrate))).ToArray();
        _epochTimelineSeries =
        [
            new ChartSeries<double>
            {
                Name = "Avg TH/s",
                Data = timelineData,
                TooltipYValueFormat = "F2"
            }
        ];

        int startDow = (int)actualStart.DayOfWeek;
        _epochTimelineLabels = byDay.Select(g => allDays[(startDow + g.Key) % 7]).ToArray();
    }

    private static DateTime GetEpochStart(DateTime utcTime)
    {
        // Last Wednesday 12:00 UTC at or before utcTime
        var candidate = utcTime.Date.AddHours(12);
        int daysBack = ((int)candidate.DayOfWeek - (int)DayOfWeek.Wednesday + 7) % 7;
        candidate = candidate.AddDays(-daysBack);
        if (candidate > utcTime) candidate = candidate.AddDays(-7);
        return candidate;
    }

    private static double ToTeraHashPerSecond(double hashrate) => hashrate / 1_000_000_000_000.0;

    /// <summary>
    /// Sums only positive increments between consecutive snapshots.
    /// Handles pool restarts (counter resets) correctly — a reset is treated as a new run from 0.
    /// </summary>
    private static int SumPositiveIncrements(IEnumerable<HashrateSnapshot> ordered, Func<HashrateSnapshot, int> selector)
    {
        var sum = 0;
        var prev = -1;
        foreach (var s in ordered)
        {
            var val = selector(s);
            if (prev >= 0 && val > prev)
                sum += val - prev;
            prev = val;
        }
        return sum;
    }

    private static string FormatGHs(double ghPerSec)
    {
        if (ghPerSec >= 1000) return $"{ghPerSec / 1000:F1} TH/s";
        if (ghPerSec >= 1) return $"{ghPerSec:F1} GH/s";
        return $"{ghPerSec * 1000:F0} MH/s";
    }

    private static string FormatHashrateDisplay(long hashrate, string _ = "")
    {
        if (hashrate >= 1_000_000_000_000L) return $"{hashrate / 1_000_000_000_000.0:F2} TH/s";
        if (hashrate >= 1_000_000_000L)     return $"{hashrate / 1_000_000_000.0:F2} GH/s";
        if (hashrate >= 1_000_000L)         return $"{hashrate / 1_000_000.0:F2} MH/s";
        return $"{hashrate} H/s";
    }

    private string FormatUptime(long seconds)
    {
        var ts = TimeSpan.FromSeconds(seconds);
        if (ts.TotalDays >= 1) return $"{(int)ts.TotalDays}d {ts.Hours}h {ts.Minutes}m";
        if (ts.TotalHours >= 1) return $"{(int)ts.TotalHours}h {ts.Minutes}m";
        return $"{ts.Minutes}m {ts.Seconds}s";
    }

    private static string FormatUptimeSpan(TimeSpan ts)
    {
        if (ts.TotalDays >= 1) return $"{(int)ts.TotalDays}d {ts.Hours}h {ts.Minutes}m";
        if (ts.TotalHours >= 1) return $"{(int)ts.TotalHours}h {ts.Minutes}m";
        return $"{ts.Minutes}m {ts.Seconds}s";
    }

