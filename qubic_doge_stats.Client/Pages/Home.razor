    private static string ChartWrapperStyle(List<ChartSeries<double>> series, string[] labels)
    {
        // Y-axis: character count of longest value
        double max = series.SelectMany(s => s.Data.Values).DefaultIfEmpty(0).Max();
        int yChars = ((int)Math.Ceiling(max)).ToString().Length;

        // X-axis: font size based on number of visible (non-empty) labels
        int visibleLabels = labels.Count(l => !string.IsNullOrEmpty(l));
        double xFontRem = visibleLabels switch
        {
            <= 8  => 1.26,
            <= 12 => 1.05,
            <= 18 => 0.88,
            <= 25 => 0.75,
            _     => 0.65
        };

        return $"--yaxis-chars: {yChars}; --xaxis-font-size: {xFontRem.ToString("F2", System.Globalization.CultureInfo.InvariantCulture)}rem;";
    }

    private static DateTime GetEpochStart(DateTime utcTime)
    {
        // Last Wednesday 12:00 UTC at or before utcTime
        var candidate = utcTime.Date.AddHours(12);
        int daysBack = ((int)candidate.DayOfWeek - (int)DayOfWeek.Wednesday + 7) % 7;
        candidate = candidate.AddDays(-daysBack);
        if (candidate > utcTime) candidate = candidate.AddDays(-7);
        return candidate;
    }

    private static double ToTeraHashPerSecond(double hashrate) => hashrate / 1_000_000_000_000.0;

    /// <summary>
    /// Sums only positive increments between consecutive snapshots.
    /// Handles pool restarts (counter resets) correctly — a reset is treated as a new run from 0.
    /// </summary>
    private static int SumPositiveIncrements(IEnumerable<HashrateSnapshot> ordered, Func<HashrateSnapshot, int> selector)
    {
        var sum = 0;
        var prev = -1;
        foreach (var s in ordered)
        {
            var val = selector(s);
            if (prev >= 0 && val > prev)
                sum += val - prev;
            prev = val;
        }
        return sum;
    }

    private static string FormatGHs(double ghPerSec)
    {
        if (ghPerSec >= 1000) return $"{ghPerSec / 1000:F1} TH/s";
        if (ghPerSec >= 1) return $"{ghPerSec:F1} GH/s";
        return $"{ghPerSec * 1000:F0} MH/s";
    }

    private static string FormatHashrateDisplay(long hashrate, string _ = "")
    {
        if (hashrate >= 1_000_000_000_000L) return $"{hashrate / 1_000_000_000_000.0:F2} TH/s";
        if (hashrate >= 1_000_000_000L)     return $"{hashrate / 1_000_000_000.0:F2} GH/s";
        if (hashrate >= 1_000_000L)         return $"{hashrate / 1_000_000.0:F2} MH/s";
        return $"{hashrate} H/s";
    }

    // ── Block interval helpers ──────────────────────────────────────────────────
    private record WorkerBlockStat(string Worker, int BlockCount, TimeSpan? AvgInterval, DateTimeOffset LastBlockTime);

    private TimeSpan? ComputeAvgInterval(IEnumerable<PoolBlock> blocks)
    {
        var sorted = blocks.OrderBy(b => b.Time).ToList();
        if (sorted.Count < 2) return null;
        var totalSecs = (sorted[^1].Time - sorted[0].Time).TotalSeconds;
        return TimeSpan.FromSeconds(totalSecs / (sorted.Count - 1));
    }

    private TimeSpan? _avgBlockIntervalAll => ComputeAvgInterval(_recentBlocks);

    private TimeSpan? _avgBlockIntervalEpoch
    {
        get
        {
            var curEpoch = _latest?.QubicEpoch ?? 0;
            if (curEpoch == 0) return null;
            return ComputeAvgInterval(_recentBlocks.Where(b => b.QubicEpoch == curEpoch));
        }
    }

    private List<WorkerBlockStat> _workerBlockStats
    {
        get
        {
            return _recentBlocks
                .Where(b => !string.IsNullOrEmpty(b.Worker))
                .GroupBy(b => b.Worker)
                .Select(g => new WorkerBlockStat(
                    g.Key,
                    g.Count(),
                    ComputeAvgInterval(g),
                    g.Max(b => b.Time)))
                .ToList();
        }
    }
