@page "/"
@inject ApiClient Api
@inject ISnackbar Snackbar
@implements IDisposable

<PageTitle>Qubic Doge Stats</PageTitle>

@* ===== STATS CARDS ===== *@
@if (_latest is not null)
{
    <MudGrid Class="mb-4 stats-grid" Spacing="3">
        <MudItem xs="12" sm="6">
            <StatCard Icon="@Icons.Material.Filled.Speed"
                      Title="Hashrate"
                      Value="@FormatHashrateDisplay(_latest.Hashrate, _latest.HashrateDisplay)"
                      Color="#7e6fff"
                      Tooltip="Current mining hashrate of the pool – the combined number of hashes per second computed by all connected miners." />
        </MudItem>
        <MudItem xs="12" sm="6">
            <StatCard Icon="@Icons.Material.Filled.Language"
                      Title="Pool Share of Network"
                      Value="@(_networkStats is not null && _networkStats.NetworkHashrate > 0
                          ? $"{(_latest.Hashrate / (double)_networkStats.NetworkHashrate * 100):F3} %"
                          : "–")"
                      Color="#4EE0FC"
                      Tooltip="The pool's share of the total Dogecoin network hashrate (24h average). The higher the percentage, the greater the chance of finding blocks." />
        </MudItem>
        <MudItem xs="12" sm="6">
            <StatCard Icon="@Icons.Material.Filled.TrendingUp"
                      Title="All-Time Peak Hashrate"
                      Value="@($"{(_peakSnapshot is not null ? FormatHashrateDisplay(_peakSnapshot.Hashrate, _peakSnapshot.HashrateDisplay) : "–")}{(_peakSnapshot?.QubicEpoch > 0 ? $" · E{_peakSnapshot!.QubicEpoch}" : "")}")"
                      Color="#FFD700"
                      Tooltip="Highest hashrate ever recorded by the pool, including the epoch in which it was reached." />
        </MudItem>
        <MudItem xs="12" sm="6">
            <StatCard Icon="@Icons.Material.Filled.CheckCircle"
                      Title="Pool Accepted"
                      Value="@_latest.PoolAccepted.ToString("N0")"
                      Color="#4caf50"
                      Tooltip="Number of shares accepted by the pool. A share is a valid partial solution submitted by a miner, proving work is being done." />
        </MudItem>
        <MudItem xs="12" sm="6">
            <StatCard Icon="@Icons.Material.Filled.Error"
                      Title="Pool Rejected"
                      Value="@_latest.PoolRejected.ToString("N0")"
                      Color="#f44336"
                      Tooltip="Number of shares rejected by the pool – e.g. due to stale work, incorrect difficulty, or connectivity issues." />
        </MudItem>
        <MudItem xs="12" sm="6">
            <StatCard Icon="@Icons.Material.Filled.Hub"
                      Title="Connected Peers"
                      Value="@($"{_latest.ConnectedPeers} / {_latest.TotalPeers}")"
                      Color="#4EE0FC"
                      Tooltip="Currently connected peers vs. known peers in the Qubic network. Reflects the dispatcher's network connectivity." />
        </MudItem>
        <MudItem xs="12" sm="6">
            <StatCard Icon="@Icons.Material.Filled.TaskAlt"
                      Title="Solutions Accepted"
                      Value="@_latest.SolutionsAccepted.ToString("N0")"
                      Color="#4caf50"
                      Tooltip="Number of solutions accepted by the Qubic network. Each accepted solution proves computational work contributed to Qubic AI training." />
        </MudItem>
        <MudItem xs="12" sm="6">
            <StatCard Icon="@Icons.Material.Filled.ContentPaste"
                      Title="Solutions Stale"
                      Value="@_latest.SolutionsStale.ToString("N0")"
                      Color="#ff9800"
                      Tooltip="Solutions submitted too late – the corresponding Qubic tick had already expired. No penalty, but the compute time was wasted." />
        </MudItem>
        <MudItem xs="12" sm="6">
            <StatCard Icon="@Icons.Material.Filled.Assignment"
                      Title="Tasks Distributed"
                      Value="@_latest.TasksDistributed.ToString("N0")"
                      Color="#7e6fff"
                      Tooltip="Number of compute tasks distributed by the dispatcher to miners. Each task contains a Qubic AI training workload." />
        </MudItem>
        <MudItem xs="12" sm="6">
            <StatCard Icon="@Icons.Material.Filled.LayersClear"
                      Title="Current Epoch"
                      Value="@(_latest.QubicEpoch > 0 ? _latest.QubicEpoch.ToString() : "–")"
                      Color="#4EE0FC"
                      Tooltip="Current Qubic epoch. Each epoch lasts one week (Wed 12:00 UTC to Wed 12:00 UTC). The epoch number increments weekly." />
        </MudItem>
        <MudItem xs="12" sm="6">
            <StatCard Icon="@Icons.Material.Filled.Timer"
                      Title="Uptime"
                      Value="@FormatUptime(_latest.UptimeSeconds)"
                      Color="#4EE0FC"
                      Tooltip="Time since the last dispatcher restart. A high value indicates stable, uninterrupted operation." />
        </MudItem>
        <MudItem xs="12" sm="6">
            <StatCard Icon="@Icons.Material.Filled.Stars"
                      Title="DOGE Blocks Found"
                      Value="@(_poolStats?.BlocksFound.ToString("N0") ?? "–")"
                      Color="#FFD700"
                      Tooltip="Number of Dogecoin blocks found in the current pool session. Each found block earns the pool a block reward in DOGE." />
        </MudItem>
        <MudItem xs="12" sm="6">
            <StatCard Icon="@Icons.Material.Filled.Verified"
                      Title="DOGE Blocks Confirmed"
                      Value="@(_poolStats?.BlocksConfirmed.ToString("N0") ?? "–")"
                      Color="#4caf50"
                      Tooltip="Blocks that have been finalized by the Dogecoin network. Only confirmed blocks guarantee that the block reward has been paid out." />
        </MudItem>
        <MudItem xs="12" sm="6">
            <StatCard Icon="@Icons.Material.Filled.CheckCircle"
                      Title="Pool Shares Valid"
                      Value="@(_poolStats?.SharesValid.ToString("N0") ?? "–")"
                      Color="#4EE0FC"
                      Tooltip="Valid shares submitted in the current pool session (from pool.json). Forms the basis for calculating each miner's reward payout." />
        </MudItem>
        <MudItem xs="12" sm="6">
            <StatCard Icon="@Icons.Material.Filled.Timer"
                      Title="Pool Session Uptime"
                      Value="@(_poolStats is not null ? FormatUptimeSpan(DateTimeOffset.UtcNow - _poolStats.SessionStart) : "–")"
                      Color="#7e6fff"
                      Tooltip="Duration of the current pool session since the last pool server restart. Shares and blocks are counted per session." />
        </MudItem>
        <MudItem xs="12" sm="6" md="4">
            <StatCard Icon="@Icons.Material.Filled.AttachMoney"
                      Title="DOGE Price (USD)"
                      Value="@(_dogePrice is not null ? $"${_dogePrice.UsdPrice:F4}" : "–")"
                      Color="#FFD700"
                      Tooltip="Current DOGE price in US Dollar (updated every 5 minutes via CoinGecko)." />
        </MudItem>
        <MudItem xs="12" sm="6" md="4">
            <StatCard Icon="@Icons.Material.Filled.Toll"
                      Title="Block Reward"
                      Value="10,000 DOGE"
                      Color="#4EE0FC"
                      Tooltip="Fixed Dogecoin block reward per mined block. Unlike Bitcoin, DOGE completed all scheduled halvings in 2015 — the reward is permanently fixed at 10,000 DOGE." />
        </MudItem>
        <MudItem xs="12" sm="6" md="4">
            <StatCard Icon="@Icons.Material.Filled.MonetizationOn"
                      Title="Block Reward (USD)"
                      Value="@(_dogePrice is not null ? $"${DogeBlockReward * _dogePrice.UsdPrice:F2}" : "–")"
                      Color="#4caf50"
                      Tooltip="Current USD value of one Dogecoin block reward (10,000 DOGE × current price)." />
        </MudItem>
         <MudItem xs="12" sm="6">
            <StatCard Icon="@Icons.Material.Filled.EmojiEvents"
                      Title="All-Time Blocks Found"
                      Value="@_recentBlocks.Count.ToString("N0")"
                      Color="#FFD700"
                      Tooltip="Total number of Dogecoin blocks ever found by this pool since it launched. Each block is permanently stored in the database." />
        </MudItem>
        <MudItem xs="12" sm="6">
            <StatCard Icon="@Icons.Material.Filled.Savings"
                      Title="Total Block Qubic Reward"
                      Value="@($"{_recentBlocks.Count * DogeBlockReward:N0} DOGE{(_dogePrice is not null ? $" · ${_recentBlocks.Count * DogeBlockReward * _dogePrice.UsdPrice:N2}" : "")}")"
                      Color="#4caf50"
                      Tooltip="Total DOGE earned by the pool from all blocks ever found — calculated as total blocks × 10,000 DOGE. USD value is based on the current DOGE price." />
        </MudItem>       
    </MudGrid>
}
else
{
    <MudPaper Class="glass-card pa-6 mb-4 d-flex justify-center align-center" Elevation="0">
        <MudProgressCircular Indeterminate="true" Color="Color.Primary" Size="Size.Large" />
        <MudText Class="ml-4 dim-text">Loading stats...</MudText>
    </MudPaper>
}

@* ===== TABS ===== *@
<MudTabs Elevation="0" TabHeaderClass="d-inline-flex mb-4">
    <MudTabPanel Text="Hashrate" Icon="@Icons.Material.Filled.Speed">

        <MudText Typo="Typo.caption" Class="mb-3 dim-text">Last updated: @_lastRefresh.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")</MudText>

        @* ===== LIVE HASHRATE CHARTS (side by side) ===== *@
        <MudGrid Class="mb-2">
            <MudItem xs="12" md="6">
                <MudPaper Class="glass-card pa-2" Elevation="0" Style="height:100%;">
                    <div class="d-flex justify-space-between align-end mb-3 flex-wrap gap-1">
                        <MudText Typo="Typo.h6" Style="color: #7e6fff;">Live Hashrate (GH/s)</MudText>
                        <MudText Typo="Typo.caption" Class="dim-text">
                            Last update: @_lastRefresh.ToLocalTime().ToString("HH:mm:ss") · auto 60 s
                        </MudText>
                    </div>
                    @if (_history.Count > 1)
                    {
                        <MudChart ChartType="ChartType.Line"
                                  ChartSeries="@_chartSeries"
                                  ChartLabels="@_chartLabels"
                                  Width="100%" Height="280px"
                                  ChartOptions="@_chartOptions" />
                    }
                    else
                    {
                        <div class="d-flex justify-center align-center" style="height:280px;">
                            <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
                            <MudText Class="ml-3 dim-text">Waiting for data…</MudText>
                        </div>
                    }
                </MudPaper>
            </MudItem>
            <MudItem xs="12" md="6">
                <MudPaper Class="glass-card pa-2" Elevation="0" Style="height:100%;">
                    <div class="d-flex justify-space-between align-end mb-3 flex-wrap gap-1">
                        <MudText Typo="Typo.h6" Style="color: #7e6fff;">Today's Avg Hashrate (GH/s)</MudText>
                        <div class="d-flex flex-column align-end">
                            <MudText Typo="Typo.caption" Class="dim-text">
                                @DateTimeOffset.UtcNow.ToLocalTime().ToString("yyyy-MM-dd") · by hour
                            </MudText>
                            @if (_todayPeak > 0)
                            {
                                <MudText Typo="Typo.caption" Style="color: #FFD700;">
                                    Peak: @($"{_todayPeak:F1} GH/s")
                                </MudText>
                            }
                        </div>
                    </div>
                    @if (_todaySeries.Count > 0)
                    {
                        <MudChart ChartType="ChartType.Line"
                                  ChartSeries="@_todaySeries"
                                  ChartLabels="@_todayLabels"
                                  Width="100%" Height="280px"
                                  ChartOptions="@_chartOptions" />
                    }
                    else
                    {
                        <div class="d-flex justify-center align-center" style="height:280px;">
                            <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
                            <MudText Class="ml-3 dim-text">Collecting today's data…</MudText>
                        </div>
                    }
                </MudPaper>
            </MudItem>
        </MudGrid>

        @* ===== CURRENT EPOCH TIMELINE + AVG HASHRATE PER EPOCH (side by side) ===== *@
        <MudGrid Class="mb-2">
            <MudItem xs="12" md="6">
                <MudPaper Class="glass-card pa-2" Elevation="0" Style="height:100%;">
                    <MudText Typo="Typo.h6" Class="mb-1" Style="color: #7e6fff;">
                        Current Epoch @(_latest?.QubicEpoch > 0 ? $"· Epoch {_latest.QubicEpoch}" : "") · Avg Hashrate (GH/s)
                    </MudText>
                    <MudText Typo="Typo.caption" Class="mb-3 dim-text">
                        Wed 12:00 UTC → next Wed 12:00 UTC
                    </MudText>
                    @if (_epochTimelineSeries.Count > 0)
                    {
                        <MudChart ChartType="ChartType.Line"
                                  ChartSeries="@_epochTimelineSeries"
                                  ChartLabels="@_epochTimelineLabels"
                                  Width="100%" Height="260px"
                                  ChartOptions="@_chartOptions" />
                    }
                    else
                    {
                        <div class="d-flex justify-center align-center" style="height:260px;">
                            <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
                            <MudText Class="ml-3 dim-text">Collecting current epoch data…</MudText>
                        </div>
                    }
                </MudPaper>
            </MudItem>
            <MudItem xs="12" md="6">
                <MudPaper Class="glass-card pa-2" Elevation="0" Style="height:100%;">
                    <MudText Typo="Typo.h6" Class="mb-1" Style="color: #7e6fff;">Avg Hashrate per Epoch (GH/s)</MudText>
                    <MudText Typo="Typo.caption" Class="mb-3 dim-text">Mean GH/s over all recorded snapshots per epoch</MudText>
                    @if (_epochHashrateSeries.Count > 0)
                    {
                        <MudChart ChartType="ChartType.Bar"
                                  ChartSeries="@_epochHashrateSeries"
                                  ChartLabels="@_epochLabels"
                                  Width="100%" Height="260px"
                                  ChartOptions="@_epochChartOptions" />
                    }
                    else
                    {
                        <div class="d-flex justify-center align-center" style="height:260px;">
                            <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
                        </div>
                    }
                </MudPaper>
            </MudItem>
        </MudGrid>

        @* ===== SOLUTIONS + POOL SHARES PER EPOCH ===== *@
        <MudGrid Class="mb-2">
            <MudItem xs="12" md="6">
                <MudPaper Class="glass-card pa-2" Elevation="0" Style="height:100%;">
                    <MudText Typo="Typo.h6" Class="mb-1" Style="color: #7e6fff;">Solutions per Epoch</MudText>
                    <MudText Typo="Typo.caption" Class="mb-3 dim-text">Accepted, rejected and stale solutions per epoch</MudText>
                    @if (_epochSolutionsDetailSeries.Count > 0)
                    {
                        <MudChart ChartType="ChartType.Bar"
                                  ChartSeries="@_epochSolutionsDetailSeries"
                                  ChartLabels="@_epochLabels"
                                  Width="100%" Height="260px"
                                  ChartOptions="@_epochChartOptions" />
                    }
                    else
                    {
                        <div class="d-flex justify-center align-center" style="height:260px;">
                            <MudProgressCircular Indeterminate="true" Color="Color.Secondary" />
                        </div>
                    }
                </MudPaper>
            </MudItem>
            <MudItem xs="12" md="6">
                <MudPaper Class="glass-card pa-2" Elevation="0" Style="height:100%;">
                    <MudText Typo="Typo.h6" Class="mb-1" Style="color: #7e6fff;">Pool Shares per Epoch</MudText>
                    <MudText Typo="Typo.caption" Class="mb-3 dim-text">Accepted vs. rejected pool shares per epoch</MudText>
                    @if (_epochPoolSeries.Count > 0)
                    {
                        <MudChart ChartType="ChartType.Bar"
                                  ChartSeries="@_epochPoolSeries"
                                  ChartLabels="@_epochLabels"
                                  Width="100%" Height="260px"
                                  ChartOptions="@_epochChartOptions" />
                    }
                    else
                    {
                        <div class="d-flex justify-center align-center" style="height:260px;">
                            <MudProgressCircular Indeterminate="true" Color="Color.Secondary" />
                        </div>
                    }
                </MudPaper>
            </MudItem>
        </MudGrid>

    </MudTabPanel>
    <MudTabPanel Text="Pool" Icon="@Icons.Material.Filled.Waves">

        <MudText Typo="Typo.caption" Class="mb-3 dim-text">
            @if (_poolStats?.LastShareTime.HasValue == true)
            {
                @($"Last share: {_poolStats.LastShareTime.Value.ToLocalTime():yyyy-MM-dd HH:mm:ss}")
            }
            else
            {
                @("Last share: –")
            }
        </MudText>

        @* Blocks per Epoch Chart + Recent Blocks table *@
        <MudGrid Class="mb-2">
            <MudItem xs="12" md="6">
                <MudPaper Class="glass-card pa-2" Elevation="0" Style="height:100%;">
                    <MudText Typo="Typo.h6" Class="mb-1" Style="color: #7e6fff;">Blocks per Epoch</MudText>
                    <MudText Typo="Typo.caption" Class="mb-3 dim-text">Found and confirmed blocks per Qubic epoch</MudText>
                    @if (_epochBlockSeries.Count > 0)
                    {
                        <MudChart ChartType="ChartType.Bar"
                                  ChartSeries="@_epochBlockSeries"
                                  ChartLabels="@_poolEpochLabels"
                                  Width="100%" Height="260px"
                                  ChartOptions="@_poolChartOptions" />
                    }
                    else
                    {
                        <div class="d-flex flex-column justify-center align-center gap-3" style="height:260px;">
                            <MudText Class="dim-text">No block data yet…</MudText>
                            <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
                        </div>
                    }
                </MudPaper>
            </MudItem>
            <MudItem xs="12" md="6">
                <MudPaper Class="glass-card pa-2" Elevation="0" Style="height:100%;">
                    <MudText Typo="Typo.h6" Class="mb-3" Style="color: #7e6fff;">Recent Blocks</MudText>
                    @if (_recentBlocks.Count > 0)
                    {
                        <MudTable Items="@_recentBlocks.Take(10)" Dense="true" Hover="true"
                                  Style="background: transparent;" Class="pool-blocks-table">
                            <HeaderContent>
                                <MudTh Style="color: #7e6fff;">Height</MudTh>
                                <MudTh Style="color: #7e6fff;">Hash</MudTh>
                                <MudTh Style="color: #7e6fff;">Time</MudTh>
                                <MudTh Style="color: #7e6fff;">Reward (USD)</MudTh>
                                <MudTh Style="color: #7e6fff;">Confirmations</MudTh>
                                <MudTh Style="color: #7e6fff;">Verify</MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd>
                                    <MudLink Href="@($"https://dogechain.info/block/{context.Height}")" Target="_blank"
                                             Style="color: #4EE0FC;">@context.Height</MudLink>
                                </MudTd>
                                <MudTd>
                                    <span style="font-family: monospace; font-size: 0.75rem; color: #4EE0FC;">
                                        @(context.Hash.Length > 12 ? context.Hash[..8] + "…" + context.Hash[^4..] : context.Hash)
                                    </span>
                                </MudTd>
                                <MudTd Style="font-size: 0.8rem;">@context.Time.ToLocalTime().ToString("MM-dd HH:mm")</MudTd>
                                <MudTd Style="color: #4caf50; font-size: 0.8rem;">
                                    @(_dogePrice is not null ? $"${DogeBlockReward * _dogePrice.UsdPrice:F2}" : "–")
                                </MudTd>
                                <MudTd>
                                    @{ var conf = _networkStats?.BestBlockHeight > 0 && context.Height > 0
                                           ? _networkStats!.BestBlockHeight - context.Height + 1 : (long?)null; }
                                    @if (conf is null)
                                    {
                                        <MudChip T="string" Size="Size.Small" Color="Color.Warning">Pending</MudChip>
                                    }
                                    else if (conf >= 100)
                                    {
                                        <MudChip T="string" Size="Size.Small" Color="Color.Success">@($"{conf:N0}")</MudChip>
                                    }
                                    else
                                    {
                                        <MudChip T="string" Size="Size.Small" Color="Color.Warning">@($"{conf:N0}")</MudChip>
                                    }
                                </MudTd>
                                <MudTd>
                                    <MudLink Href="@($"https://blockchair.com/dogecoin/block/{context.Hash}")" Target="_blank"
                                             Style="color: #7e6fff; font-size: 0.75rem;">
                                        <MudIcon Icon="@Icons.Material.Filled.OpenInNew" Style="font-size: 1rem;" />
                                    </MudLink>
                                </MudTd>
                            </RowTemplate>
                        </MudTable>
                    }
                    else
                    {
                        <div class="d-flex justify-center align-center" style="height:200px;">
                            <MudText Class="dim-text">No blocks found yet.</MudText>
                        </div>
                    }
                </MudPaper>
            </MudItem>
        </MudGrid>

        @* Full Block History Table *@
        @if (_recentBlocks.Count > 10)
        {
            <MudPaper Class="glass-card pa-4 mb-4" Elevation="0">
                <MudText Typo="Typo.h6" Class="mb-3" Style="color: #7e6fff;">All Blocks (@_recentBlocks.Count total)</MudText>
                <MudTable Items="@_recentBlocks" Dense="true" Hover="true" Style="background: transparent;"
                          FixedHeader="true" Height="400px">
                    <HeaderContent>
                        <MudTh Style="color: #7e6fff;">Height</MudTh>
                        <MudTh Style="color: #7e6fff;">Hash</MudTh>
                        <MudTh Style="color: #7e6fff;">Worker</MudTh>
                        <MudTh Style="color: #7e6fff;">Epoch</MudTh>
                        <MudTh Style="color: #7e6fff;">Time</MudTh>
                        <MudTh Style="color: #7e6fff;">Reward (USD)</MudTh>
                        <MudTh Style="color: #7e6fff;">Confirmations</MudTh>
                        <MudTh Style="color: #7e6fff;">Verify</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd>
                            <MudLink Href="@($"https://dogechain.info/block/{context.Height}")" Target="_blank"
                                     Style="color: #4EE0FC;">@context.Height</MudLink>
                        </MudTd>
                        <MudTd>
                            <span style="font-family: monospace; font-size: 0.75rem; color: #4EE0FC;">
                                @(context.Hash.Length > 16 ? context.Hash[..12] + "…" + context.Hash[^4..] : context.Hash)
                            </span>
                        </MudTd>
                        <MudTd>
                            <MudLink Href="@($"https://dogechain.info/address/{context.Worker}")" Target="_blank"
                                     Style="color: #7e6fff; font-family: monospace; font-size: 0.75rem;">
                                @(context.Worker.Length > 16 ? context.Worker[..12] + "…" + context.Worker[^4..] : context.Worker)
                            </MudLink>
                        </MudTd>
                        <MudTd>Ep @context.QubicEpoch</MudTd>
                        <MudTd Style="font-size: 0.8rem;">@context.Time.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</MudTd>
                        <MudTd Style="color: #4caf50; font-size: 0.8rem;">
                            @(_dogePrice is not null ? $"${DogeBlockReward * _dogePrice.UsdPrice:F2}" : "–")
                        </MudTd>
                        <MudTd>
                            @{ var confFull = _networkStats?.BestBlockHeight > 0 && context.Height > 0
                                   ? _networkStats!.BestBlockHeight - context.Height + 1 : (long?)null; }
                            @if (confFull is null)
                            {
                                <MudChip T="string" Size="Size.Small" Color="Color.Warning">Pending</MudChip>
                            }
                            else if (confFull >= 100)
                            {
                                <MudChip T="string" Size="Size.Small" Color="Color.Success">@($"{confFull:N0}")</MudChip>
                            }
                            else
                            {
                                <MudChip T="string" Size="Size.Small" Color="Color.Warning">@($"{confFull:N0}")</MudChip>
                            }
                        </MudTd>
                        <MudTd>
                            <MudLink Href="@($"https://blockchair.com/dogecoin/block/{context.Hash}")" Target="_blank"
                                     Style="color: #7e6fff;">
                                <MudIcon Icon="@Icons.Material.Filled.OpenInNew" Style="font-size: 1rem;" />
                            </MudLink>
                        </MudTd>
                    </RowTemplate>
                </MudTable>
            </MudPaper>
        }

    </MudTabPanel>
</MudTabs>

@code {
    [CascadingParameter(Name = "IsDarkMode")] private bool IsDarkMode { get; set; } = true;

    private static readonly string[] _darkPalette = ["#7e6fff", "#4EE0FC", "#4caf50", "#ff9800", "#f44336"];
    private static readonly string[] _lightPalette = ["#3d1fcc", "#006f8a", "#1b5e20", "#bf3600", "#8b0000"];

    private System.Threading.Timer? _refreshTimer;

    private const decimal DogeBlockReward = 10_000m;

    private HashrateSnapshot? _latest;
    private HashrateSnapshot? _peakSnapshot;
    private PoolLiveStats? _poolStats;
    private DogeNetworkStats? _networkStats;
    private DogePriceStats? _dogePrice;
    private List<HashrateSnapshot> _history = [];
    private List<HashrateSnapshot> _fullHistory = [];
    private DateTimeOffset _lastRefresh = DateTimeOffset.UtcNow;

    // Block-found notification tracking
    private HashSet<string> _knownBlockHashes = [];
    private bool _blockTrackingReady = false;

    // Pool-specific fields
    private List<PoolBlock> _recentBlocks = [];
    private List<ChartSeries<double>> _epochBlockSeries = [];
    private string[] _poolEpochLabels = [];

    private BarChartOptions _poolChartOptions => new BarChartOptions
    {
        YAxisTicks = 5,
        YAxisFormat = "F0",
        ChartPalette = IsDarkMode ? new[] { "#7e6fff", "#4caf50", "#f44336", "#4EE0FC", "#FFD700" }
                                  : new[] { "#3d1fcc", "#1b5e20", "#8b0000", "#006f8a", "#bf3600" },
    };

    // Live 60-min chart
    private List<ChartSeries<double>> _chartSeries = [];
    private string[] _chartLabels = [];
    private LineChartOptions _chartOptions => new LineChartOptions
    {
        YAxisTicks = 5,
        YAxisFormat = "F2",
        LineStrokeWidth = 2,
        ChartPalette = IsDarkMode ? _darkPalette : _lightPalette,
    };

    // Today's hashrate by hour
    private List<ChartSeries<double>> _todaySeries = [];
    private string[] _todayLabels = [];
    private double _todayPeak = 0;

    // Epoch comparison charts (side by side)
    private List<ChartSeries<double>> _epochHashrateSeries = [];
    private List<ChartSeries<double>> _epochSolutionsDetailSeries = [];
    private List<ChartSeries<double>> _epochPoolSeries = [];
    private string[] _epochLabels = [];
    private BarChartOptions _epochChartOptions => new BarChartOptions
    {
        YAxisTicks = 5,
        YAxisFormat = "F2",
        ChartPalette = IsDarkMode ? _darkPalette : _lightPalette,
    };

    // Current epoch timeline chart
    private List<ChartSeries<double>> _epochTimelineSeries = [];
    private string[] _epochTimelineLabels = [];

    protected override async Task OnInitializedAsync()
    {
        Snackbar.Configuration.PositionClass = Defaults.Classes.Position.TopRight;
        Snackbar.Configuration.PreventDuplicates = false;
        Snackbar.Configuration.MaxDisplayedSnackbars = 10;
        await RefreshDataAsync();
        _refreshTimer = new System.Threading.Timer(async _ =>
        {
            await RefreshDataAsync();
            await InvokeAsync(StateHasChanged);
        }, null, TimeSpan.FromSeconds(60), TimeSpan.FromSeconds(60));

    }

    private async Task RefreshDataAsync()
    {
        _latest = await Api.GetLatestSnapshotAsync();
        _poolStats = await Api.GetPoolStatsAsync();
        _networkStats = await Api.GetNetworkStatsAsync();
        _dogePrice = await Api.GetDogePriceAsync();
        _recentBlocks = await Api.GetPoolBlocksAsync();
        NotifyNewBlocks();
        BuildPoolEpochChart();
        // 10080 = 7 days × 24h × 60min at 60s poll interval (full epoch)
        _fullHistory = await Api.GetHistoryAsync(10080);
        _fullHistory = _fullHistory.OrderBy(x => x.Timestamp).ToList();
        _history = _fullHistory.TakeLast(60).ToList();
        _peakSnapshot = _fullHistory.Count > 0 ? _fullHistory.MaxBy(h => h.Hashrate) : null;
        _lastRefresh = DateTimeOffset.UtcNow;
        BuildChartData();
        BuildEpochChartData();
        BuildEpochTimelineData();
    }

    private void NotifyNewBlocks()
    {
        if (!_blockTrackingReady)
        {
            // First load: seed known hashes, no notifications
            _knownBlockHashes = _recentBlocks.Select(b => b.Hash).ToHashSet();
            _blockTrackingReady = true;
            return;
        }

        foreach (var block in _recentBlocks.Where(b => !_knownBlockHashes.Contains(b.Hash)))
        {
            _knownBlockHashes.Add(block.Hash);
            var time = block.Time.ToLocalTime().ToString("HH:mm");
            Snackbar.Add(
                $"🐕 Block #{block.Height} gefunden! — {time} Uhr",
                Severity.Success,
                config =>
                {
                    config.VisibleStateDuration = 90 * 60 * 1000; // 90 Minuten
                    config.ShowCloseIcon = true;
                    config.DuplicatesBehavior = SnackbarDuplicatesBehavior.Allow;
                });
        }
    }

    private void BuildPoolEpochChart()
    {
        if (_recentBlocks.Count == 0) return;

        var byEpoch = _recentBlocks
            .Where(b => b.QubicEpoch > 0)
            .GroupBy(b => b.QubicEpoch)
            .OrderBy(g => g.Key)
            .ToList();

        if (byEpoch.Count == 0) return;

        _poolEpochLabels = byEpoch.Select(g => $"Ep {g.Key}").ToArray();
        _epochBlockSeries =
        [
            new ChartSeries<double>
            {
                Name = "Found",
                Data = byEpoch.Select(g => (double)g.Count()).ToArray()
            },
            new ChartSeries<double>
            {
                Name = "Confirmed",
                Data = byEpoch.Select(g => (double)g.Count(b => b.Confirmed)).ToArray()
            }
        ];
    }

    private void BuildChartData()
    {
        if (_history.Count == 0) return;

        // 60-min chart: actual time labels every 10 points to avoid overlap
        var values = _history.Select(h => ToGigaHashPerSecond(h.Hashrate)).ToArray();
        int total = values.Length;
        _chartLabels = _history.Select((h, i) =>
            (i % 10 == 0 && i < total - 5) || i == total - 1
                ? h.Timestamp.ToLocalTime().ToString("HH:mm")
                : ""
        ).ToArray();
        _chartSeries = [new ChartSeries<double> { Name = "GH/s", Data = values, TooltipYValueFormat = "F2" }];

        // Today chart: average GH/s per hour bucket (00–23)
        var todayLocal = DateTimeOffset.UtcNow.ToLocalTime().Date;
        var byHour = _fullHistory
            .Where(h => h.Timestamp.ToLocalTime().Date == todayLocal)
            .GroupBy(h => h.Timestamp.ToLocalTime().Hour)
            .ToDictionary(g => g.Key, g => g.Average(x => ToGigaHashPerSecond(x.Hashrate)));

        int currentHour = DateTimeOffset.UtcNow.ToLocalTime().Hour;
        _todayLabels = Enumerable.Range(0, currentHour + 1).Select(h => $"{h:D2}").ToArray();
        _todaySeries =
        [
            new ChartSeries<double>
            {
                Name = "GH/s",
                Data = Enumerable.Range(0, currentHour + 1)
                    .Select(h => byHour.TryGetValue(h, out var v) ? v : 0.0)
                    .ToArray(),
                TooltipYValueFormat = "F2"
            }
        ];

        var todayAll = _fullHistory.Where(h => h.Timestamp.ToLocalTime().Date == todayLocal).ToList();
        _todayPeak = todayAll.Count > 0 ? todayAll.Max(h => ToGigaHashPerSecond(h.Hashrate)) : 0;
    }

    private void BuildEpochChartData()
    {
        var epochs = _fullHistory
            .Where(h => h.QubicEpoch > 0)
            .GroupBy(h => h.QubicEpoch)
            .OrderBy(g => g.Key)
            .ToList();

        if (epochs.Count == 0) return;

        _epochLabels = epochs.Select(g => $"Ep {g.Key}").ToArray();

        _epochHashrateSeries =
        [
            new ChartSeries<double>
            {
                Name = "Avg GH/s",
                Data = epochs.Select(g => g.Average(x => ToGigaHashPerSecond(x.Hashrate))).ToArray(),
                TooltipYValueFormat = "F2"
            }
        ];

        _epochSolutionsDetailSeries =
        [
            new ChartSeries<double>
            {
                Name = "Accepted",
                Data = epochs.Select(g =>
                {
                    var sorted = g.OrderBy(x => x.Timestamp).ToList();
                    return (double)Math.Max(0, sorted.Last().SolutionsAccepted - sorted.First().SolutionsAccepted);
                }).ToArray(),
                TooltipYValueFormat = "F0"
            },
            new ChartSeries<double>
            {
                Name = "Rejected",
                Data = epochs.Select(g =>
                {
                    var sorted = g.OrderBy(x => x.Timestamp).ToList();
                    return (double)Math.Max(0, sorted.Last().SolutionsRejected - sorted.First().SolutionsRejected);
                }).ToArray(),
                TooltipYValueFormat = "F0"
            },
            new ChartSeries<double>
            {
                Name = "Stale",
                Data = epochs.Select(g =>
                {
                    var sorted = g.OrderBy(x => x.Timestamp).ToList();
                    return (double)Math.Max(0, sorted.Last().SolutionsStale - sorted.First().SolutionsStale);
                }).ToArray(),
                TooltipYValueFormat = "F0"
            }
        ];

        _epochPoolSeries =
        [
            new ChartSeries<double>
            {
                Name = "Accepted",
                Data = epochs.Select(g =>
                {
                    var sorted = g.OrderBy(x => x.Timestamp).ToList();
                    return (double)Math.Max(0, sorted.Last().PoolAccepted - sorted.First().PoolAccepted);
                }).ToArray(),
                TooltipYValueFormat = "F0"
            },
            new ChartSeries<double>
            {
                Name = "Rejected",
                Data = epochs.Select(g =>
                {
                    var sorted = g.OrderBy(x => x.Timestamp).ToList();
                    return (double)Math.Max(0, sorted.Last().PoolRejected - sorted.First().PoolRejected);
                }).ToArray(),
                TooltipYValueFormat = "F0"
            }
        ];
    }

    private void BuildEpochTimelineData()
    {
        _epochTimelineSeries = [];
        _epochTimelineLabels = [];

        var currentEpoch = _latest?.QubicEpoch ?? 0;
        if (currentEpoch == 0 || _fullHistory.Count == 0) return;

        // Filter by epoch tag — includes early-reporting snapshots before 12:00 UTC
        var epochData = _fullHistory
            .Where(h => h.QubicEpoch == currentEpoch)
            .OrderBy(h => h.Timestamp)
            .ToList();

        if (epochData.Count == 0) return;

        // Use Wed 12:00 UTC boundary of this epoch as reference start;
        // clamp backwards if RPC reported the epoch a few minutes early.
        var epochStart = GetEpochStart(epochData.Last().Timestamp.UtcDateTime);
        var actualStart = epochData[0].Timestamp.UtcDateTime < epochStart
            ? epochData[0].Timestamp.UtcDateTime
            : epochStart;

        string[] allDays = ["Sun", "Mon", "Tue", "Wed", "Thu", "Fri", "Sat"];

        var byDay = epochData
            .GroupBy(h => (int)((h.Timestamp.UtcDateTime - actualStart).TotalHours / 24))
            .Where(g => g.Key >= 0 && g.Key < 7)
            .OrderBy(g => g.Key)
            .ToList();

        if (byDay.Count == 0) return;

        _epochTimelineSeries =
        [
            new ChartSeries<double>
            {
                Name = "Avg GH/s",
                Data = byDay.Select(g => g.Average(h => ToGigaHashPerSecond(h.Hashrate))).ToArray(),
                TooltipYValueFormat = "F2"
            }
        ];

        int startDow = (int)actualStart.DayOfWeek;
        _epochTimelineLabels = byDay.Select(g => allDays[(startDow + g.Key) % 7]).ToArray();
    }

    private static DateTime GetEpochStart(DateTime utcTime)
    {
        // Last Wednesday 12:00 UTC at or before utcTime
        var candidate = utcTime.Date.AddHours(12);
        int daysBack = ((int)candidate.DayOfWeek - (int)DayOfWeek.Wednesday + 7) % 7;
        candidate = candidate.AddDays(-daysBack);
        if (candidate > utcTime) candidate = candidate.AddDays(-7);
        return candidate;
    }

    private static double ToGigaHashPerSecond(double hashrate) => hashrate / 1_000_000_000.0;

    private static string FormatHashrateDisplay(long hashrate, string apiDisplay)
    {
        if (hashrate >= 1_000_000_000_000L)
            return $"{hashrate / 1_000_000_000_000.0:F2} TH/s";
        return string.IsNullOrEmpty(apiDisplay)
            ? $"{hashrate / 1_000_000_000.0:F1} GH/s"
            : apiDisplay;
    }

    private string FormatUptime(long seconds)
    {
        var ts = TimeSpan.FromSeconds(seconds);
        if (ts.TotalDays >= 1) return $"{(int)ts.TotalDays}d {ts.Hours}h {ts.Minutes}m";
        if (ts.TotalHours >= 1) return $"{(int)ts.TotalHours}h {ts.Minutes}m";
        return $"{ts.Minutes}m {ts.Seconds}s";
    }

    private static string FormatUptimeSpan(TimeSpan ts)
    {
        if (ts.TotalDays >= 1) return $"{(int)ts.TotalDays}d {ts.Hours}h {ts.Minutes}m";
        if (ts.TotalHours >= 1) return $"{(int)ts.TotalHours}h {ts.Minutes}m";
        return $"{ts.Minutes}m {ts.Seconds}s";
    }

    public void Dispose()
    {
        _refreshTimer?.Dispose();
    }
}
