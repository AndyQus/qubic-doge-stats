            <MudItem xs="12" sm="6" md="3">
                <StatCard Icon="@Icons.Material.Filled.CalendarToday"
                          Title="Unique Today"
                          Value="@(_visitorStats is not null ? _visitorStats.UniqueVisitorsToday.ToString("N0") : "–")"
                          Color="#4EE0FC"
                          Tooltip="Unique visitors today (UTC, by IP hash)." />
