    protected override void OnParametersSet()
    {
        if (_prevDarkMode != IsDarkMode)
        {
            _prevDarkMode = IsDarkMode;
            InitApex24hOptions();
            InitApexVisitorOptions();
        }

        if (_prevLiteMode != IsLiteMode)
        {
            _prevLiteMode = IsLiteMode;
            // Chart was hidden (display:none) during init — force re-render after mode switch
            _ = InvokeAsync(async () =>
            {
                await Task.Delay(50); // let DOM update first
                if (IsLiteMode && _apex24hChartLite is not null)
                    await _apex24hChartLite.RenderAsync();
                else if (!IsLiteMode && _apex24hChart is not null)
                    await _apex24hChart.RenderAsync();
            });
        }
    }

    protected override async Task OnInitializedAsync()
    {
        Snackbar.Configuration.PositionClass = Defaults.Classes.Position.TopRight;
        Snackbar.Configuration.PreventDuplicates = false;
        Snackbar.Configuration.MaxDisplayedSnackbars = 5;
        Snackbar.Configuration.NewestOnTop = true;
        InitApex24hOptions();
        InitApexVisitorOptions();
        await RefreshDataAsync();

        // Track this page visit (fire-and-forget)
        _ = Api.TrackVisitAsync(Nav.Uri);

        // Show visitor tab only when ?admin=true is in the URL
        var uri = new Uri(Nav.Uri);
        var query = System.Web.HttpUtility.ParseQueryString(uri.Query);
        _showVisitorTab = query["admin"] == "true";

        // Load visitor stats only when tab is visible
        if (_showVisitorTab)
            await RefreshVisitorStatsAsync();

        _refreshTimer = new System.Threading.Timer(async _ =>
        {
            await RefreshDataAsync();
            await InvokeAsync(StateHasChanged);
        }, null, TimeSpan.FromSeconds(60), TimeSpan.FromSeconds(60));

        if (_showVisitorTab)
            _visitorRefreshTimer = new System.Threading.Timer(async _ =>
            {
                await RefreshVisitorStatsAsync();
                await InvokeAsync(StateHasChanged);
            }, null, TimeSpan.FromSeconds(30), TimeSpan.FromSeconds(30));
    }

    private async Task RefreshDataAsync()
    {
        _latest = await Api.GetLatestSnapshotAsync();
        _poolStats = await Api.GetPoolStatsAsync();
        _quPrice = await Api.GetQuPriceAsync();
        if (_quPrice is not null && _quPriceManual == 0.0)
            _quPriceManual = (double)_quPrice.UsdPrice;
        _networkStats = await Api.GetNetworkStatsAsync();
        _dogePrice = await Api.GetDogePriceAsync();
        _ltcPrice  = await Api.GetLtcPriceAsync();
        _recentBlocks = await Api.GetPoolBlocksAsync();
        _latestEpochSummary = await Api.GetLatestEpochSummaryAsync();
        _allEpochSummaries  = await Api.GetAllEpochSummariesAsync();
        _allTimeStats = await Api.GetAllTimeStatsAsync();
        _miningPoolRanking = await Api.GetMiningPoolRankingAsync();

        // Running epoch not yet finalized → add its values on top of finalized totals
        var runningEpoch = _latestEpochSummary is { IsFinalized: false } ? _latestEpochSummary : null;
        var re = runningEpoch;
        var at = _allTimeStats;

        // Total = finalized sum + running epoch
        _totalPoolAccepted       = (at?.TotalPoolAccepted       ?? 0) + (re?.TotalPoolAccepted       ?? 0);
        _totalPoolRejected       = (at?.TotalPoolRejected       ?? 0) + (re?.TotalPoolRejected       ?? 0);
        _totalSolutionsAccepted  = (at?.TotalSolutionsAccepted  ?? 0) + (re?.TotalSolutionsAccepted  ?? 0);
        _totalSolutionsStale     = (at?.TotalSolutionsStale     ?? 0) + (re?.TotalSolutionsStale     ?? 0);
        _totalTasksDistributed        = (at?.TotalTasksDistributed ?? 0) + (re?.TotalTasksDistributed ?? 0);
        _currentEpochTasksDistributed = _latestEpochSummary?.TotalTasksDistributed ?? 0;
        var dogeBlocks = _recentBlocks.Where(b => b.Chain != "LTC").ToList();
        var ltcBlocks  = _recentBlocks.Where(b => b.Chain == "LTC").ToList();

        _totalBlocksFound     = dogeBlocks.Count;
        _totalBlocksConfirmed = dogeBlocks.Count(b => b.Confirmed);
        _totalLtcBlocksFound     = ltcBlocks.Count;
        _totalLtcBlocksConfirmed = ltcBlocks.Count(b => b.Confirmed);
        _totalSharesValid     = (at?.TotalSharesValid ?? 0) + (re?.SharesValid ?? 0);

        // Current epoch — direct count from pool_blocks
        var curEpoch = _latest?.QubicEpoch ?? 0;
        _currentEpochBlocksFound        = curEpoch > 0 ? dogeBlocks.Count(b => b.QubicEpoch == curEpoch) : 0;
        _currentEpochBlocksConfirmed    = curEpoch > 0 ? dogeBlocks.Count(b => b.QubicEpoch == curEpoch && b.Confirmed) : 0;
        _currentEpochLtcBlocksFound     = curEpoch > 0 ? ltcBlocks.Count(b => b.QubicEpoch == curEpoch) : 0;
        _currentEpochLtcBlocksConfirmed = curEpoch > 0 ? ltcBlocks.Count(b => b.QubicEpoch == curEpoch && b.Confirmed) : 0;

        // Best epoch — DOGE
        var epochGroups = dogeBlocks.Where(b => b.QubicEpoch > 0).GroupBy(b => b.QubicEpoch).ToList();
        if (epochGroups.Count > 0)
        {
            var bestFound     = epochGroups.MaxBy(g => g.Count())!;
            var bestConfirmed = epochGroups.MaxBy(g => g.Count(b => b.Confirmed))!;
            _peakBlocksFound          = bestFound.Count();
            _peakBlocksFoundEpoch     = bestFound.Key;
            _peakBlocksConfirmed      = bestConfirmed.Count(b => b.Confirmed);
            _peakBlocksConfirmedEpoch = bestConfirmed.Key;
        }

        // Best epoch — LTC
        var ltcEpochGroups = ltcBlocks.Where(b => b.QubicEpoch > 0).GroupBy(b => b.QubicEpoch).ToList();
        if (ltcEpochGroups.Count > 0)
        {
            var bestLtcFound     = ltcEpochGroups.MaxBy(g => g.Count())!;
            var bestLtcConfirmed = ltcEpochGroups.MaxBy(g => g.Count(b => b.Confirmed))!;
            _peakLtcBlocksFound          = bestLtcFound.Count();
            _peakLtcBlocksFoundEpoch     = bestLtcFound.Key;
            _peakLtcBlocksConfirmed      = bestLtcConfirmed.Count(b => b.Confirmed);
            _peakLtcBlocksConfirmedEpoch = bestLtcConfirmed.Key;
        }

        // Epoch peak = highest single-epoch value ever; running epoch competes with finalized peaks
        int reEp = re?.EpochNumber ?? 0;
        (_peakPoolAccepted,      _peakPoolAcceptedEpoch)      = Peak(at?.PeakPoolAccepted      ?? 0, at?.PeakPoolAcceptedEpoch      ?? 0, re?.TotalPoolAccepted,      reEp);
        (_peakPoolRejected,      _peakPoolRejectedEpoch)      = Peak(at?.PeakPoolRejected      ?? 0, at?.PeakPoolRejectedEpoch      ?? 0, re?.TotalPoolRejected,      reEp);
        (_peakSolutionsAccepted, _peakSolutionsAcceptedEpoch) = Peak(at?.PeakSolutionsAccepted ?? 0, at?.PeakSolutionsAcceptedEpoch ?? 0, re?.TotalSolutionsAccepted, reEp);
        (_peakSolutionsStale,    _peakSolutionsStaleEpoch)    = Peak(at?.PeakSolutionsStale    ?? 0, at?.PeakSolutionsStaleEpoch    ?? 0, re?.TotalSolutionsStale,    reEp);
        (_peakTasksDistributed,  _peakTasksDistributedEpoch)  = Peak(at?.PeakTasksDistributed  ?? 0, at?.PeakTasksDistributedEpoch  ?? 0, re?.TotalTasksDistributed,  reEp);
        (_peakSharesValid,       _peakSharesValidEpoch)       = Peak(at?.PeakSharesValid        ?? 0, at?.PeakSharesValidEpoch        ?? 0, re?.SharesValid,            reEp);

        await NotifyNewBlocksAsync();
        BuildPoolEpochChart();
        BuildEpochRevenueChart();
        // 10080 = 7 days × 24h × 60min at 60s poll interval (full epoch)
        _fullHistory = await Api.GetHistoryAsync(10080);
        _fullHistory = _fullHistory.OrderBy(x => x.Timestamp).ToList();
        _history = _fullHistory.TakeLast(60).ToList();
_lastRefresh = DateTimeOffset.UtcNow;
        BuildChartData();
        Build24hChartData();
        BuildEpochChartData();
        BuildEpochTimelineData();
        BuildTop10SnapshotsChart();
        BuildNetworkChartsData();
        if (_apex24hChart is not null)
            await _apex24hChart.UpdateSeriesAsync();
        if (_apex24hChartLite is not null)
            await _apex24hChartLite.UpdateSeriesAsync();
    }

    private async Task NotifyNewBlocksAsync()
    {
        if (!_blockTrackingReady)
        {
            // First load — read last known block height from localStorage
            var stored = await JS.InvokeAsync<string?>("localStorage.getItem", BlockLocalStorageKey);
            long lastSeenHeight = 0;
            if (!string.IsNullOrEmpty(stored))
                long.TryParse(stored, out lastSeenHeight);

            var sortedDesc = _recentBlocks.OrderByDescending(b => b.Height).ToList();
            var maxHeight = sortedDesc.FirstOrDefault()?.Height ?? 0;

            if (lastSeenHeight > 0)
            {
                var newBlocks = sortedDesc.Where(b => b.Height > lastSeenHeight).OrderBy(b => b.Height).ToList();
                if (newBlocks.Count > 5)
                {
                    Snackbar.Add(
                        $"🐕 {newBlocks.Count} new blocks found since your last visit!",
                        Severity.Info,
                        config =>
                        {
                            config.VisibleStateDuration = 90 * 60 * 1000;
                            config.ShowCloseIcon = true;
                        });
                }
                else
                {
                    foreach (var block in newBlocks)
                        ShowBlockSnackbar(block);
                }
            }
            // else: first ever visit — show nothing, just seed

            // Persist only the highest known block height
            if (maxHeight > 0)
                await JS.InvokeVoidAsync("localStorage.setItem", BlockLocalStorageKey, maxHeight.ToString());

            _knownBlockHashes = _recentBlocks.Select(b => b.Hash).ToHashSet();
            _blockTrackingReady = true;
            return;
        }

        // Subsequent timer refreshes: notify only genuinely new blocks
        var newDuringRefresh = _recentBlocks.Where(b => !_knownBlockHashes.Contains(b.Hash)).ToList();
        foreach (var block in newDuringRefresh)
        {
            _knownBlockHashes.Add(block.Hash);
            ShowBlockSnackbar(block);
        }

        if (newDuringRefresh.Count > 0)
        {
            var maxH = _recentBlocks.Max(b => b.Height);
            await JS.InvokeVoidAsync("localStorage.setItem", BlockLocalStorageKey, maxH.ToString());
        }
    }

    private void ShowBlockSnackbar(PoolBlock block)
    {
        var time = block.Time.ToLocalTime().ToString("HH:mm");
        Snackbar.Add(
            $"🐕 Block #{block.Height} found! — {time}",
