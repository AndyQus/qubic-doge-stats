        </MudPaper>
        <MudText Typo="Typo.caption" Class="dim-text mt-2 d-block">
            Profit = Revenue − (Power × 24h × $/kWh) · Network hashrate: @(_networkStats is not null ? $"{_networkStats.NetworkHashrate / 1_000_000_000_000.0:F2} TH/s" : "–")
        </MudText>
    </MudTabPanel>

</MudTabs>

@code {
    [CascadingParameter(Name = "IsDarkMode")] private bool IsDarkMode { get; set; } = true;

    private static readonly string[] _darkPalette = ["#7e6fff", "#4EE0FC", "#4caf50", "#ff9800", "#f44336"];
    private static readonly string[] _lightPalette = ["#3d1fcc", "#006f8a", "#1b5e20", "#bf3600", "#8b0000"];

    private System.Threading.Timer? _refreshTimer;

    private const decimal DogeBlockReward = 10_000m;

    private HashrateSnapshot? _latest;
    private PoolLiveStats? _poolStats;

    // Effective totals = finalized AllTimeStats + current running epoch (if not yet finalized)
    private int _totalPoolAccepted;
    private int _totalPoolRejected;
    private int _totalSolutionsAccepted;
    private int _totalSolutionsStale;
    private int _totalTasksDistributed;
    private int _totalBlocksFound;
    private int _totalBlocksConfirmed;
    private int _currentEpochBlocksFound;
    private int _currentEpochBlocksConfirmed;
    private int _totalSharesValid;

    // Epoch peak = highest single-epoch value ever recorded (with epoch number)
    private int _peakPoolAccepted,      _peakPoolAcceptedEpoch;
    private int _peakPoolRejected,      _peakPoolRejectedEpoch;
    private int _peakSolutionsAccepted, _peakSolutionsAcceptedEpoch;
    private int _peakSolutionsStale,    _peakSolutionsStaleEpoch;
    private int _peakTasksDistributed,  _peakTasksDistributedEpoch;
    private int _peakBlocksFound,       _peakBlocksFoundEpoch;
    private int _peakBlocksConfirmed,   _peakBlocksConfirmedEpoch;
    private int _peakSharesValid,       _peakSharesValidEpoch;

    private static (int Val, int Epoch) Peak(int atVal, int atEp, int? runVal, int runEp) =>
        (runVal ?? 0) > atVal ? (runVal!.Value, runEp) : (atVal, atEp);
    private DogeNetworkStats? _networkStats;
    private DogePriceStats? _dogePrice;
    private EpochSummary? _latestEpochSummary;
    private AllTimeStats? _allTimeStats;
    private MiningPoolRanking? _miningPoolRanking;
    private List<HashrateSnapshot> _history = [];
    private List<HashrateSnapshot> _fullHistory = [];
    private DateTimeOffset _lastRefresh = DateTimeOffset.UtcNow;

    // Block-found notification tracking
    private HashSet<string> _knownBlockHashes = [];
    private bool _blockTrackingReady = false;

    // Pool-specific fields
    private List<PoolBlock> _recentBlocks = [];
    private List<ChartSeries<double>> _epochBlockSeries = [];
    private string[] _poolEpochLabels = [];

    private BarChartOptions _poolChartOptions => new BarChartOptions
    {
        YAxisTicks = 5,
        YAxisFormat = "F0",
        ChartPalette = IsDarkMode ? new[] { "#7e6fff", "#4caf50", "#f44336", "#4EE0FC", "#FFD700" }
                                  : new[] { "#3d1fcc", "#1b5e20", "#8b0000", "#006f8a", "#bf3600" },
    };

    // Live 60-min chart
    private List<ChartSeries<double>> _chartSeries = [];
    private string[] _chartLabels = [];
    private LineChartOptions _chartOptions => new LineChartOptions
    {
        YAxisTicks = 1,
        MaxNumYAxisTicks = 10,
        YAxisFormat = "F2",
        LineStrokeWidth = 2,
        ChartPalette = IsDarkMode ? _darkPalette : _lightPalette,
    };

    // Today's hashrate by hour
    private List<ChartSeries<double>> _todaySeries = [];
    private string[] _todayLabels = [];
    private double _todayPeak = 0;

    // Epoch comparison charts (side by side)
    private List<ChartSeries<double>> _epochHashrateSeries = [];
    private List<ChartSeries<double>> _epochSolutionsDetailSeries = [];
    private List<ChartSeries<double>> _epochPoolSeries = [];
    private string[] _epochLabels = [];
    private BarChartOptions _epochHashrateChartOptions => new BarChartOptions
    {
        YAxisTicks = 1,
        MaxNumYAxisTicks = 10,
        YAxisFormat = "F2",
        ChartPalette = IsDarkMode ? _darkPalette : _lightPalette,
    };

    private BarChartOptions _epochCounterChartOptions => new BarChartOptions
    {
        YAxisTicks = 5,
        YAxisFormat = "F0",
        ChartPalette = IsDarkMode ? _darkPalette : _lightPalette,
    };

    // Current epoch timeline chart
    private List<ChartSeries<double>> _epochTimelineSeries = [];
    private string[] _epochTimelineLabels = [];

    protected override async Task OnInitializedAsync()
    {
        Snackbar.Configuration.PositionClass = Defaults.Classes.Position.TopRight;
        Snackbar.Configuration.PreventDuplicates = false;
        Snackbar.Configuration.MaxDisplayedSnackbars = 10;
        await RefreshDataAsync();
        _refreshTimer = new System.Threading.Timer(async _ =>
        {
            await RefreshDataAsync();
            await InvokeAsync(StateHasChanged);
        }, null, TimeSpan.FromSeconds(60), TimeSpan.FromSeconds(60));

    }

    private async Task RefreshDataAsync()
    {
        _latest = await Api.GetLatestSnapshotAsync();
        _poolStats = await Api.GetPoolStatsAsync();
        _networkStats = await Api.GetNetworkStatsAsync();
        _dogePrice = await Api.GetDogePriceAsync();
        _recentBlocks = await Api.GetPoolBlocksAsync();
        _latestEpochSummary = await Api.GetLatestEpochSummaryAsync();
        _allTimeStats = await Api.GetAllTimeStatsAsync();
        _miningPoolRanking = await Api.GetMiningPoolRankingAsync();

        // Running epoch not yet finalized → add its values on top of finalized totals
        var runningEpoch = _latestEpochSummary is { IsFinalized: false } ? _latestEpochSummary : null;
        var re = runningEpoch;
        var at = _allTimeStats;

        // Total = finalized sum + running epoch
        _totalPoolAccepted       = (at?.TotalPoolAccepted       ?? 0) + (re?.TotalPoolAccepted       ?? 0);
        _totalPoolRejected       = (at?.TotalPoolRejected       ?? 0) + (re?.TotalPoolRejected       ?? 0);
        _totalSolutionsAccepted  = (at?.TotalSolutionsAccepted  ?? 0) + (re?.TotalSolutionsAccepted  ?? 0);
        _totalSolutionsStale     = (at?.TotalSolutionsStale     ?? 0) + (re?.TotalSolutionsStale     ?? 0);
        _totalTasksDistributed   = (at?.TotalTasksDistributed   ?? 0) + (re?.TotalTasksDistributed   ?? 0);
        _totalBlocksFound     = _recentBlocks.Count;
        _totalBlocksConfirmed = _recentBlocks.Count(b => b.Confirmed);
        _totalSharesValid     = (at?.TotalSharesValid ?? 0) + (re?.SharesValid ?? 0);

        // Current epoch — direct count from pool_blocks
        var curEpoch = _latest?.QubicEpoch ?? 0;
        _currentEpochBlocksFound     = curEpoch > 0 ? _recentBlocks.Count(b => b.QubicEpoch == curEpoch) : 0;
        _currentEpochBlocksConfirmed = curEpoch > 0 ? _recentBlocks.Count(b => b.QubicEpoch == curEpoch && b.Confirmed) : 0;

        // Best epoch — group pool_blocks by epoch, find epoch with most blocks
        var epochGroups = _recentBlocks.Where(b => b.QubicEpoch > 0).GroupBy(b => b.QubicEpoch).ToList();
        if (epochGroups.Count > 0)
        {
            var bestFound     = epochGroups.MaxBy(g => g.Count())!;
            var bestConfirmed = epochGroups.MaxBy(g => g.Count(b => b.Confirmed))!;
            _peakBlocksFound          = bestFound.Count();
            _peakBlocksFoundEpoch     = bestFound.Key;
            _peakBlocksConfirmed      = bestConfirmed.Count(b => b.Confirmed);
            _peakBlocksConfirmedEpoch = bestConfirmed.Key;
        }

        // Epoch peak = highest single-epoch value ever; running epoch competes with finalized peaks
        int reEp = re?.EpochNumber ?? 0;
        (_peakPoolAccepted,      _peakPoolAcceptedEpoch)      = Peak(at?.PeakPoolAccepted      ?? 0, at?.PeakPoolAcceptedEpoch      ?? 0, re?.TotalPoolAccepted,      reEp);
        (_peakPoolRejected,      _peakPoolRejectedEpoch)      = Peak(at?.PeakPoolRejected      ?? 0, at?.PeakPoolRejectedEpoch      ?? 0, re?.TotalPoolRejected,      reEp);
        (_peakSolutionsAccepted, _peakSolutionsAcceptedEpoch) = Peak(at?.PeakSolutionsAccepted ?? 0, at?.PeakSolutionsAcceptedEpoch ?? 0, re?.TotalSolutionsAccepted, reEp);
        (_peakSolutionsStale,    _peakSolutionsStaleEpoch)    = Peak(at?.PeakSolutionsStale    ?? 0, at?.PeakSolutionsStaleEpoch    ?? 0, re?.TotalSolutionsStale,    reEp);
        (_peakTasksDistributed,  _peakTasksDistributedEpoch)  = Peak(at?.PeakTasksDistributed  ?? 0, at?.PeakTasksDistributedEpoch  ?? 0, re?.TotalTasksDistributed,  reEp);
        (_peakSharesValid,       _peakSharesValidEpoch)       = Peak(at?.PeakSharesValid        ?? 0, at?.PeakSharesValidEpoch        ?? 0, re?.SharesValid,            reEp);

        NotifyNewBlocks();
        BuildPoolEpochChart();
        // 10080 = 7 days × 24h × 60min at 60s poll interval (full epoch)
        _fullHistory = await Api.GetHistoryAsync(10080);
        _fullHistory = _fullHistory.OrderBy(x => x.Timestamp).ToList();
        _history = _fullHistory.TakeLast(60).ToList();
_lastRefresh = DateTimeOffset.UtcNow;
        BuildChartData();
        BuildEpochChartData();
        BuildEpochTimelineData();
    }

    private void NotifyNewBlocks()
    {
        if (!_blockTrackingReady)
        {
            // First load: seed known hashes, no notifications
            _knownBlockHashes = _recentBlocks.Select(b => b.Hash).ToHashSet();
            _blockTrackingReady = true;
            return;
        }

        foreach (var block in _recentBlocks.Where(b => !_knownBlockHashes.Contains(b.Hash)))
        {
            _knownBlockHashes.Add(block.Hash);
            var time = block.Time.ToLocalTime().ToString("HH:mm");
            Snackbar.Add(
                $"🐕 Block #{block.Height} gefunden! — {time} Uhr",
                Severity.Success,
                config =>
                {
                    config.VisibleStateDuration = 90 * 60 * 1000; // 90 Minuten
                    config.ShowCloseIcon = true;
                    config.DuplicatesBehavior = SnackbarDuplicatesBehavior.Allow;
                });
        }
    }

    private void BuildPoolEpochChart()
    {
        if (_recentBlocks.Count == 0) return;

        var byEpoch = _recentBlocks
            .Where(b => b.QubicEpoch > 0)
            .GroupBy(b => b.QubicEpoch)
            .OrderBy(g => g.Key)
            .ToList();

        if (byEpoch.Count == 0) return;

        _poolEpochLabels = byEpoch.Select(g => $"Ep {g.Key}").ToArray();
        _epochBlockSeries =
        [
            new ChartSeries<double>
            {
                Name = "Found",
                Data = byEpoch.Select(g => (double)g.Count()).ToArray()
            },
            new ChartSeries<double>
            {
                Name = "Confirmed",
                Data = byEpoch.Select(g => (double)g.Count(b => b.Confirmed)).ToArray()
            }
        ];
    }

    private void BuildChartData()
    {
        if (_history.Count == 0) return;

        // 60-min chart: actual time labels every 10 points to avoid overlap
        var values = _history.Select(h => ToTeraHashPerSecond(h.Hashrate)).ToArray();
        int total = values.Length;
        _chartLabels = _history.Select((h, i) =>
            (i % 10 == 0 && i < total - 5) || i == total - 1
                ? h.Timestamp.ToLocalTime().ToString("HH:mm")
                : ""
        ).ToArray();
        _chartSeries = [new ChartSeries<double> { Name = "TH/s", Data = values, TooltipYValueFormat = "F2" }];

        // Today chart: peak TH/s per hour bucket (00–23)
        var todayLocal = DateTimeOffset.UtcNow.ToLocalTime().Date;
        var byHour = _fullHistory
            .Where(h => h.Timestamp.ToLocalTime().Date == todayLocal)
            .GroupBy(h => h.Timestamp.ToLocalTime().Hour)
            .ToDictionary(g => g.Key, g => g.Max(x => ToTeraHashPerSecond(x.Hashrate)));

        int currentHour = DateTimeOffset.UtcNow.ToLocalTime().Hour;
        _todayLabels = Enumerable.Range(0, currentHour + 1).Select(h => $"{h:D2}").ToArray();
        _todaySeries =
        [
            new ChartSeries<double>
            {
                Name = "TH/s",
                Data = Enumerable.Range(0, currentHour + 1)
                    .Select(h => byHour.TryGetValue(h, out var v) ? v : 0.0)
                    .ToArray(),
                TooltipYValueFormat = "F2"
            }
        ];

        var todayAll = _fullHistory.Where(h => h.Timestamp.ToLocalTime().Date == todayLocal).ToList();
        _todayPeak = todayAll.Count > 0 ? todayAll.Max(h => ToTeraHashPerSecond(h.Hashrate)) : 0;
    }

    // ── Profitability tab ────────────────────────────────────────────────────

    private double _profPowerCost = 0.08;

    private record L7Spec(string Model, int HashrateGHs, int PowerWatts);

    private static readonly L7Spec[] _l7Specs =
    [
        new("Antminer L7 9500Mh",  9500, 3425),
        new("Antminer L7 9300Mh",  9300, 3425),
        new("Antminer L7 9160Mh",  9160, 3225),
        new("Antminer L7 9050Mh",  9050, 3260),
    ];

    private record L7Row(string Model, int HashrateGHs, int PowerWatts,
        double Revenue24hUsd, double Profit24hUsd, double BreakevenKwh);

    private List<L7Row> GetL7Profitability()
    {
        // DOGE: ~10,000 DOGE block reward, ~1 block/min = 1440 blocks/day network-wide
        // Miner share = minerHashrate / networkHashrate
        const double dogePerBlock = 10_000.0;
        const double blocksPerDay = 1440.0;
        double networkGHs = _networkStats?.NetworkHashrate / 1_000_000_000.0 ?? 0;
        double dogeUsd    = _dogePrice is not null ? (double)_dogePrice.UsdPrice : 0;

        return _l7Specs.Select(s =>
        {
            double minerGHs = s.HashrateGHs / 1000.0;  // MH/s → GH/s
            double revenue = networkGHs > 0 && dogeUsd > 0
                ? (minerGHs / networkGHs) * blocksPerDay * dogePerBlock * dogeUsd
                : 0;
            double powerCost = s.PowerWatts / 1000.0 * 24 * _profPowerCost;
            double profit    = revenue > 0 ? revenue - powerCost : 0;
            double breakeven = revenue > 0 ? revenue / (s.PowerWatts / 1000.0 * 24) : 0;
            return new L7Row(s.Model, s.HashrateGHs, s.PowerWatts, revenue, profit, breakeven);
        }).ToList();
    }

