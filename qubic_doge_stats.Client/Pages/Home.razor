                    </MudTd>
                    <MudTd Style="text-align:right; font-size:0.82rem; color:var(--mud-palette-text-secondary);">
                        @(context.Revenue24hUsd > 0 ? $"{context.BreakevenKwh:F3} $/kWh" : "–")
