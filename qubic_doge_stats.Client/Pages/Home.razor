    private static string GetCountryFlag(string countryCode)
    {
        if (string.IsNullOrEmpty(countryCode) || countryCode.Length != 2) return "";
        // Regional indicator symbols: 'A' = U+1F1E6, offset from 'A'
        int offset = 0x1F1E6 - 'A';
        return char.ConvertFromUtf32(countryCode[0] + offset) + char.ConvertFromUtf32(countryCode[1] + offset);
    }

