    private void BuildChartData()
    {
        if (_history.Count == 0) return;

        // 60-min chart: actual time labels every 10 points to avoid overlap
        var values = _history.Select(h => ToTeraHashPerSecond(h.Hashrate)).ToArray();
        int total = values.Length;
        _chartLabels = _history.Select((h, i) =>
            (i % 10 == 0 && i < total - 5) || i == total - 1
                ? h.Timestamp.ToLocalTime().ToString("HH:mm")
                : ""
        ).ToArray();
        _chartSeries = [new ChartSeries<double> { Name = "TH/s", Data = values, TooltipYValueFormat = "F2" }];

        // Today chart: peak TH/s per 5-min bucket
        var todayLocal = DateTimeOffset.UtcNow.ToLocalTime().Date;
        var nowLocal = DateTimeOffset.UtcNow.ToLocalTime();
        int currentSlot = (int)((nowLocal - nowLocal.Date).TotalMinutes / 5);

        var bySlot = _fullHistory
            .Where(h => h.Timestamp.ToLocalTime().Date == todayLocal)
            .GroupBy(h => (int)(h.Timestamp.ToLocalTime().TimeOfDay.TotalMinutes / 5))
            .ToDictionary(g => g.Key, g => g.Max(x => ToTeraHashPerSecond(x.Hashrate)));

        // Show hour label every 12 slots (= 60 min), suppress intermediate labels
        _todayLabels = Enumerable.Range(0, currentSlot + 1)
            .Select(s => s % 12 == 0 ? $"{s / 12:D2}" : "")
            .ToArray();
        _todaySeries =
        [
            new ChartSeries<double>
            {
                Name = "Peak TH/s",
                Data = Enumerable.Range(0, currentSlot + 1)
                    .Select(s => bySlot.TryGetValue(s, out var v) ? v : 0.0)
                    .ToArray(),
                TooltipYValueFormat = "F2"
            }
        ];

        var todayAll = _fullHistory.Where(h => h.Timestamp.ToLocalTime().Date == todayLocal).ToList();
        _todayPeak = todayAll.Count > 0 ? todayAll.Max(h => ToTeraHashPerSecond(h.Hashrate)) : 0;
    }

    private void Build24hChartData()
    {
        if (_fullHistory.Count == 0) return;

        // Use last 24h of data, but if less is available use whatever exists
        var cutoff = DateTimeOffset.UtcNow.AddHours(-24);
        var data24h = _fullHistory
            .Where(h => h.Timestamp >= cutoff)
            .OrderBy(h => h.Timestamp)
            .ToList();

        // Fall back to all available history if 24h window has fewer than 4 points
        if (data24h.Count < 4)
            data24h = _fullHistory.OrderBy(h => h.Timestamp).ToList();

        if (data24h.Count == 0) return;

        // 30-min buckets — only buckets with actual data are created (no empty leading zeros)
        var buckets = data24h
            .GroupBy(h => new DateTimeOffset(
                h.Timestamp.UtcDateTime.Year, h.Timestamp.UtcDateTime.Month, h.Timestamp.UtcDateTime.Day,
                h.Timestamp.UtcDateTime.Hour, (h.Timestamp.UtcDateTime.Minute / 30) * 30, 0,
                TimeSpan.Zero))
            .OrderBy(g => g.Key)
            .ToList();

        if (buckets.Count == 0) return;

        // Label only full hours; always show first and last bucket
        int total = buckets.Count;
        _24hLabels = buckets.Select((g, i) =>
        {
            if (i == 0 || i == total - 1 || g.Key.Minute == 0)
                return g.Key.ToLocalTime().ToString("HH:mm");
            return "";
        }).ToArray();

        var dataValues = buckets.Select(g => g.Average(h => ToTeraHashPerSecond(h.Hashrate))).ToArray();

        // Mini chart: empty strings (not null — null causes MudBlazor NaN rendering)
        _24hMiniLabels = Enumerable.Repeat("", dataValues.Length).ToArray();

        _24hSeries =
        [
            new ChartSeries<double>
            {
                Name = "TH/s",
                Data = dataValues,
                TooltipYValueFormat = "F2"
            }
        ];

        _24hPeak = dataValues.DefaultIfEmpty(0).Max();

        // ApexCharts data: mutate in place to avoid chart destroy/recreate on re-render
        _apex24hData.Clear();
        _apex24hData.AddRange(buckets.Zip(dataValues, (b, v) => new Apex24hPoint(b.Key.ToLocalTime(), v)));
    }

