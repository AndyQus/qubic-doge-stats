@page "/"
@inject ApiClient Api
@inject ISnackbar Snackbar
@inject IJSRuntime JS
@inject NavigationManager Nav
@implements IDisposable

<PageTitle>Qubic Doge Stats</PageTitle>

@* ===== LITE MODE ===== *@
<div style="@(IsLiteMode ? "" : "display:none")">
    @* ── Lite Panels ── *@
    @if (_latest is not null)
    {
        <MudGrid Class="mb-4 stats-grid" Spacing="3">
            @* Hashrate *@
            <MudItem xs="12" sm="6" md="3">
                <StatCard Icon="@Icons.Material.Filled.Speed"
                          Title="Hashrate"
                          Value="@FormatHashrateDisplay(_latest.Hashrate)"
                          SecondaryValue="@(_latestEpochSummary is not null ? $"{_latestEpochSummary.PeakHashrateDisplay}" : "–")"
                          SecondaryLabel="Epoch"
                          TertiaryValue="@(_allTimeStats is not null && _allTimeStats.PeakHashrate > 0 ? $"{_allTimeStats.PeakHashrateDisplay} · E{_allTimeStats.PeakHashrateEpoch}" : "–")"
                          TertiaryLabel="ATH"
                          Color="#7e6fff"
                          Tooltip="Current pool hashrate." />
            </MudItem>
            @* DOGE Blocks *@
            <MudItem xs="12" sm="6" md="3">
                <MudPaper Class="glass-card pa-3" Elevation="0" Style="height:100%;">
                    <div class="d-flex align-center gap-2 mb-2">
                        <MudIcon Icon="@Icons.Material.Filled.Stars" Style="color:#4caf50; font-size:1.4rem;" />
                        <MudText Class="stat-card-label" Style="font-size:0.75rem; font-weight:500; letter-spacing:0.5px;">DOGE BLOCKS</MudText>
                        <MudTooltip Text="Gold = Found, Green = Confirmed. Row 1: current epoch. Row 2 (Best): epoch with the most blocks ever. Row 3 (Total): all-time sum." Placement="Placement.Top" Arrow="true">
                            <MudIcon Icon="@Icons.Material.Outlined.Info" Class="stat-card-info-icon" Style="font-size:0.95rem; cursor:help; margin-left:auto;" />
                        </MudTooltip>
                    </div>
                    <div class="d-flex gap-2 align-baseline mb-1">
                        <MudText Typo="Typo.h5" Style="color:#4caf50; font-weight:700;">@(_currentEpochBlocksConfirmed > 0 ? _currentEpochBlocksConfirmed.ToString("N0") : "–")</MudText>
                        <MudText Typo="Typo.body2" Style="color:#FFD700; font-weight:600;">(@(_currentEpochBlocksFound > 0 ? _currentEpochBlocksFound.ToString("N0") : "–"))</MudText>
                    </div>
                    <div class="d-flex align-center gap-1 mt-1">
                        <MudText Typo="Typo.caption" Class="dim-text" Style="min-width:3rem;">Best</MudText>
                        <MudText Typo="Typo.body2" Style="color:#4caf50; opacity:0.8; font-weight:600;">@(_peakBlocksConfirmed > 0 ? _peakBlocksConfirmed.ToString("N0") : "–")</MudText>
                        <MudText Typo="Typo.body2" Style="color:#FFD700; opacity:0.8; font-weight:600;">(@(_peakBlocksFound > 0 ? _peakBlocksFound.ToString("N0") : "–"))</MudText>
                        <MudText Typo="Typo.caption" Class="dim-text mx-1">·</MudText>
                        <MudText Typo="Typo.caption" Style="color:#4caf50;">E@(_peakBlocksFoundEpoch)</MudText>
                    </div>
                    <div class="d-flex align-center gap-1 mt-1">
                        <MudText Typo="Typo.body1" Style="color:#FF8C00; font-weight:700; min-width:3rem;">Total</MudText>
                        <MudText Typo="Typo.body1" Style="color:#4caf50; opacity:0.8; font-weight:600;">@(_totalBlocksConfirmed > 0 ? _totalBlocksConfirmed.ToString("N0") : "–")</MudText>
                        <MudText Typo="Typo.body1" Style="color:#FFD700; opacity:0.8; font-weight:600;">(@(_totalBlocksFound > 0 ? _totalBlocksFound.ToString("N0") : "–"))</MudText>
                    </div>
                </MudPaper>
            </MudItem>
            @* LTC Blocks *@
            <MudItem xs="12" sm="6" md="3">
                <MudPaper Class="glass-card pa-3" Elevation="0" Style="height:100%;">
                    <div class="d-flex align-center gap-2 mb-2">
                        <MudIcon Icon="@Icons.Material.Filled.Stars" Style="color:#4caf50; font-size:1.4rem;" />
                        <MudText Class="stat-card-label" Style="font-size:0.75rem; font-weight:500; letter-spacing:0.5px;">LTC BLOCKS</MudText>
                        <MudTooltip Text="Blue = Found, Green = Confirmed. Row 1: current epoch. Row 2 (Best): epoch with the most LTC blocks ever. Row 3 (Total): all-time sum." Placement="Placement.Top" Arrow="true">
                            <MudIcon Icon="@Icons.Material.Outlined.Info" Class="stat-card-info-icon" Style="font-size:0.95rem; cursor:help; margin-left:auto;" />
                        </MudTooltip>
                    </div>
                    <div class="d-flex gap-2 align-baseline mb-1">
                        <MudText Typo="Typo.h5" Style="color:#4caf50; font-weight:700;">@(_currentEpochLtcBlocksConfirmed > 0 ? _currentEpochLtcBlocksConfirmed.ToString("N0") : "–")</MudText>
                        <MudText Typo="Typo.body2" Style="color:#345D9D; font-weight:600;">(@(_currentEpochLtcBlocksFound > 0 ? _currentEpochLtcBlocksFound.ToString("N0") : "–"))</MudText>
                    </div>
                    <div class="d-flex align-center gap-1 mt-1">
                        <MudText Typo="Typo.caption" Class="dim-text" Style="min-width:3rem;">Best</MudText>
                        <MudText Typo="Typo.body2" Style="color:#4caf50; opacity:0.8; font-weight:600;">@(_peakLtcBlocksConfirmed > 0 ? _peakLtcBlocksConfirmed.ToString("N0") : "–")</MudText>
                        <MudText Typo="Typo.body2" Style="color:#345D9D; opacity:0.8; font-weight:600;">(@(_peakLtcBlocksFound > 0 ? _peakLtcBlocksFound.ToString("N0") : "–"))</MudText>
                        <MudText Typo="Typo.caption" Class="dim-text mx-1">·</MudText>
                        <MudText Typo="Typo.caption" Style="color:#4caf50;">E@(_peakLtcBlocksFoundEpoch)</MudText>
                    </div>
                    <div class="d-flex align-center gap-1 mt-1">
                        <MudText Typo="Typo.body1" Style="color:#FF8C00; font-weight:700; min-width:3rem;">Total</MudText>
                        <MudText Typo="Typo.body1" Style="color:#4caf50; opacity:0.8; font-weight:600;">@(_totalLtcBlocksConfirmed > 0 ? _totalLtcBlocksConfirmed.ToString("N0") : "–")</MudText>
                        <MudText Typo="Typo.body1" Style="color:#345D9D; opacity:0.8; font-weight:600;">(@(_totalLtcBlocksFound > 0 ? _totalLtcBlocksFound.ToString("N0") : "–"))</MudText>
                    </div>
                </MudPaper>
            </MudItem>
            @* Block Revenue *@
            <MudItem xs="12" sm="6" md="3">
                <MudPaper Class="glass-card pa-3" Elevation="0" Style="height:100%;">
                    <div class="d-flex align-center gap-2 mb-2">
                        <MudIcon Icon="@Icons.Material.Filled.AttachMoney" Style="color:#4caf50; font-size:1.4rem;" />
                        <MudText Class="stat-card-label" Style="font-size:0.75rem; font-weight:500; letter-spacing:0.5px;">BLOCK REVENUE</MudText>
                        <MudTooltip Text="Combined DOGE + LTC block rewards in USD. Row 1: current epoch. Row 2 (Best): epoch with highest revenue. Row 3 (Total): all-time sum." Placement="Placement.Top" Arrow="true">
                            <MudIcon Icon="@Icons.Material.Outlined.Info" Class="stat-card-info-icon" Style="font-size:0.95rem; cursor:help; margin-left:auto;" />
                        </MudTooltip>
                    </div>
                    <div class="d-flex gap-2 align-baseline mb-1">
                        <MudText Typo="Typo.h5" Style="color:#4caf50; font-weight:700;">@(_currentEpochRevenueUsd > 0 ? $"${_currentEpochRevenueUsd:N0}" : "–")</MudText>
                    </div>
                    <div class="d-flex align-center gap-1 mt-1">
                        <MudText Typo="Typo.caption" Class="dim-text" Style="min-width:3rem;">Best</MudText>
                        <MudText Typo="Typo.body2" Style="color:#4caf50; opacity:0.8; font-weight:600;">@(_bestEpochRevenueUsd > 0 ? $"${_bestEpochRevenueUsd:N0}" : "–")</MudText>
                        @if (_bestEpochRevenueEpoch > 0)
                        {
                            <MudText Typo="Typo.caption" Class="dim-text mx-1">·</MudText>
                            <MudText Typo="Typo.caption" Style="color:#4caf50;">E@(_bestEpochRevenueEpoch)</MudText>
                        }
                    </div>
                    <div class="d-flex align-center gap-1 mt-1">
                        <MudText Typo="Typo.body1" Style="color:#FF8C00; font-weight:700; min-width:3rem;">Total</MudText>
                        <MudText Typo="Typo.body1" Style="color:#4caf50; opacity:0.8; font-weight:600;">@(_totalRevenueUsd > 0 ? $"${_totalRevenueUsd:N0}" : "–")</MudText>
                    </div>
                </MudPaper>
            </MudItem>
            @* Pool Rank (DOGE) *@
            <MudItem xs="12" sm="6" md="3">
                <StatCard Icon="@Icons.Material.Filled.EmojiEvents"
                          Title="Pool Rank (DOGE)"
                          Value="@(_miningPoolRanking is not null ? $"#{_miningPoolRanking.Qubic.Rank}" : "–")"
                          SecondaryValue="@(_latestEpochSummary is not null && _latestEpochSummary.BestRank > 0 ? $"#{_latestEpochSummary.BestRank}" : "–")"
                          SecondaryLabel="Epoch"
                          TertiaryValue="@(_allTimeStats is not null && _allTimeStats.BestRank > 0 ? $"#{_allTimeStats.BestRank} · E{_allTimeStats.BestRankEpoch}" : "–")"
                          TertiaryLabel="Best"
                          Color="#7e6fff"
                          Tooltip="@(_miningPoolRanking is not null ? $"Qubic's rank among all DOGE mining pools (of {_miningPoolRanking.TotalPools} pools)." : "Qubic's rank among all DOGE mining pools.")" />
            </MudItem>
        </MudGrid>
    }
    else
    {
        <MudPaper Class="glass-card pa-6 mb-4 d-flex justify-center align-center" Elevation="0">
            <MudProgressCircular Indeterminate="true" Color="Color.Primary" Size="Size.Large" />
            <MudText Class="ml-4 dim-text">Loading stats...</MudText>
        </MudPaper>
    }

    @* ── Lite Charts: alle 4 im 2-Spalten-Layout ── *@
    <MudGrid Class="mb-2">
        @* Chart 1: Live 24h Hashrate *@
        <MudItem xs="12" md="6">
            <MudPaper Class="glass-card pa-2" Elevation="0" Style="height:100%; overflow:visible;">
                <MudText Typo="Typo.h6" Class="mb-1" Style="color: #7e6fff;">Live 24h Hashrate (TH/s)</MudText>
                <div class="d-flex justify-space-between align-end mb-3 flex-wrap gap-1">
                    <MudText Typo="Typo.caption" Class="dim-text">Last 24h · by 30 min · auto 60 s · @_lastRefresh.ToLocalTime().ToString("HH:mm:ss")</MudText>
                    @if (_24hPeak > 0)
                    {
                        <MudText Typo="Typo.caption" Style="color: #4EE0FC;">Peak TH/s: @($"{_24hPeak:F2}")</MudText>
                    }
                </div>
                @if (_apex24hData.Count > 0)
                {
                    <div class="chart-apex-wrapper" style="padding: 0 8px;">
                        <ApexCharts.ApexChart TItem="Apex24hPoint"
                                   Options="@_apex24hOptions"
                                   @ref="_apex24hChartLite"
                                   Height="280">
                            <ApexCharts.ApexPointSeries TItem="Apex24hPoint"
                                             Items="@_apex24hData"
                                             SeriesType="ApexCharts.SeriesType.Line"
                                             Name="TH/s"
                                             XValue="@(p => p.Time.ToUnixTimeMilliseconds())"
                                             YValue="@(p => (decimal)p.Value)"
                                             OrderBy="p => p.X" />
                        </ApexCharts.ApexChart>
                    </div>
                }
                else
                {
                    <div class="d-flex justify-center align-center" style="height:280px;">
                        <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
                        <MudText Class="ml-3 dim-text">Collecting 24h data…</MudText>
                    </div>
                }
            </MudPaper>
        </MudItem>
        @* Chart 2: Top 10 Epochs by Peak Hashrate *@
        <MudItem xs="12" md="6">
            <MudPaper Class="glass-card pa-2" Elevation="0" Style="height:100%;">
                <MudText Typo="Typo.h6" Class="mb-1" Style="color: #7e6fff;">Top 10 Epochs by Peak Hashrate (TH/s)</MudText>
                <MudText Typo="Typo.caption" Class="mb-3 dim-text">Ranking of the 10 epochs with the highest peak hashrate ever recorded</MudText>
                @if (_top10EpochPeakSeries.Count > 0)
                {
                    <div class="chart-mobile-wrapper" style="@ChartWrapperStyle(_top10EpochPeakSeries, _top10EpochPeakLabels)">
                        <MudChart ChartType="ChartType.Bar"
                                  ChartSeries="@_top10EpochPeakSeries"
                                  ChartLabels="@_top10EpochPeakLabels"
                                  Width="100%" Height="280px"
                                  ChartOptions="@_top10PeakChartOptions" />
                    </div>
                }
                else
                {
                    <div class="d-flex justify-center align-center" style="height:280px;">
                        <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
                    </div>
                }
            </MudPaper>
        </MudItem>
        @* Chart 3: Blocks per Epoch *@
        <MudItem xs="12" md="6">
            <MudPaper Class="glass-card pa-2" Elevation="0" Style="height:100%;">
                <MudText Typo="Typo.h6" Class="mb-1" Style="color: #7e6fff;">Blocks per Epoch</MudText>
                <MudText Typo="Typo.caption" Class="mb-3 dim-text">Found and confirmed blocks per Qubic epoch</MudText>
                @if (_epochBlockSeries.Count > 0)
                {
                    <div class="chart-mobile-wrapper" style="@ChartWrapperStyle(_epochBlockSeries, _poolEpochLabels)">
                        <MudChart ChartType="ChartType.Bar"
                                  ChartSeries="@_epochBlockSeries"
                                  ChartLabels="@_poolEpochLabels"
                                  Width="100%" Height="280px"
                                  ChartOptions="@_poolChartOptions" />
                    </div>
                }
                else
                {
                    <div class="d-flex flex-column justify-center align-center gap-3" style="height:280px;">
                        <MudText Class="dim-text">No block data yet…</MudText>
                        <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
                    </div>
                }
            </MudPaper>
        </MudItem>
        @* Chart 4: Block Revenue per Epoch *@
        <MudItem xs="12" md="6">
            <MudPaper Class="glass-card pa-2" Elevation="0" Style="height:100%;">
                <MudText Typo="Typo.h6" Class="mb-1" Style="color: #7e6fff;">Block Revenue per Epoch (USDT)</MudText>
                <MudText Typo="Typo.caption" Class="mb-3 dim-text">DOGE + LTC block rewards in USD at price at time of find · per Qubic epoch</MudText>
                @if (_epochRevenueSeries.Count > 0)
                {
                    <div class="chart-mobile-wrapper" style="@ChartWrapperStyle(_epochRevenueSeries, _epochRevenueLabels)">
                        <MudChart ChartType="ChartType.Bar"
                                  ChartSeries="@_epochRevenueSeries"
                                  ChartLabels="@_epochRevenueLabels"
                                  Width="100%" Height="280px"
                                  ChartOptions="@_epochRevenueChartOptions" />
                    </div>
                }
                else
                {
                    <div class="d-flex flex-column justify-center align-center gap-3" style="height:280px;">
                        <MudText Class="dim-text">No block data yet…</MudText>
                        <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
                    </div>
                }
            </MudPaper>
        </MudItem>
    </MudGrid>

    @* All Blocks *@
    @if (_recentBlocks.Count > 0)
    {
        <MudPaper Class="glass-card pa-4 mb-4" Elevation="0">
            <div class="d-flex align-center justify-space-between mb-3">
                <MudText Typo="Typo.h6" Style="color: #7e6fff;">All Blocks (@_recentBlocks.Count total)</MudText>
                <MudTextField @bind-Value="_allBlocksSearch" Placeholder="Search height, hash, worker, epoch, coin…"
                              Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                              Immediate="true" Clearable="true" Variant="Variant.Outlined"
                              Margin="Margin.Dense" Style="max-width: 320px; margin-left: auto;" />
            </div>
            <MudTable Items="@_recentBlocks.OrderByDescending(b => b.Time)" Dense="true" Hover="true"
                      Style="background: transparent;" RowsPerPage="10"
                      GroupBy="@_blockGroupDef" Filter="@(b => AllBlocksFilter(b))"
                      Breakpoint="Breakpoint.Sm">
                <HeaderContent>
                    <MudTh Style="color: #7e6fff;">Coin</MudTh>
                    <MudTh Style="color: #7e6fff;">Height</MudTh>
                    <MudTh Style="color: #7e6fff;">Hash</MudTh>
                    <MudTh Style="color: #7e6fff;">Worker</MudTh>
                    <MudTh Style="color: #7e6fff;">Time</MudTh>
                    <MudTh Style="color: #7e6fff;">Reward (USD)</MudTh>
                    <MudTh Style="color: #7e6fff;">Confirmations</MudTh>
                    <MudTh Style="color: #7e6fff;">Verify</MudTh>
                </HeaderContent>
                <GroupHeaderTemplate>
                    <MudTh colspan="8" Style="background: rgba(78,224,252,0.10); padding: 4px 12px; border-left: 3px solid #4EE0FC;">
                        <MudText Typo="Typo.subtitle2" Style="color: #4EE0FC;">
                            @(context.Key is int k && k > 0 ? $"Epoch {k}" : "Epoch –")
                        </MudText>
                    </MudTh>
                </GroupHeaderTemplate>
                <RowTemplate>
                    <MudTd DataLabel="Coin">
                        @if (context.Chain == "LTC")
                        {
                            <MudChip T="string" Size="Size.Small" Style="background:#345D9D; color:#fff; font-weight:700; font-size:0.7rem; height:20px;">LTC</MudChip>
                        }
                        else
                        {
                            <MudChip T="string" Size="Size.Small" Style="background:#c8a400; color:#fff; font-weight:700; font-size:0.7rem; height:20px;">DOGE</MudChip>
                        }
                    </MudTd>
                    <MudTd DataLabel="Height">
                        <MudLink Href="@(context.Chain == "LTC" ? $"https://blockchair.com/litecoin/block/{context.Height}" : $"https://dogechain.info/block/{context.Height}")"
                                 Target="_blank" Style="color: #4EE0FC;">@context.Height</MudLink>
                    </MudTd>
                    <MudTd DataLabel="Hash">
                        <span style="font-family: monospace; font-size: 0.875rem; color: #4EE0FC;">
                            @(string.IsNullOrEmpty(context.Hash) ? "–" : context.Hash.Length > 16 ? context.Hash[..12] + "…" + context.Hash[^4..] : context.Hash)
                        </span>
                    </MudTd>
                    <MudTd DataLabel="Worker">
                        <MudLink Href="@(context.Chain == "LTC" ? $"https://blockchair.com/litecoin/address/{context.Worker}" : $"https://dogechain.info/address/{context.Worker}")"
                                 Target="_blank" Style="color: #7e6fff; font-family: monospace; font-size: 0.875rem;">
                            @(string.IsNullOrEmpty(context.Worker) ? "–" : context.Worker.Length > 16 ? context.Worker[..12] + "…" + context.Worker[^4..] : context.Worker)
                        </MudLink>
                    </MudTd>
                    <MudTd DataLabel="Time" Style="font-size: 0.875rem;">@context.Time.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</MudTd>
                    <MudTd DataLabel="Reward (USD)" Style="color: #4caf50; font-size: 0.875rem;">
                        @if (context.Chain == "LTC")
                        {
                            @(context.LtcPriceUsdAtFind > 0
                                ? $"${LtcBlockReward * context.LtcPriceUsdAtFind:F2}"
                                : _ltcPrice is not null ? $"${LtcBlockReward * _ltcPrice.UsdPrice:F2}" : "–")
                        }
                        else
                        {
                            @(context.DogePriceUsdAtFind > 0
                                ? $"${DogeBlockReward * context.DogePriceUsdAtFind:F2}"
                                : _dogePrice is not null ? $"${DogeBlockReward * _dogePrice.UsdPrice:F2}" : "–")
                        }
                    </MudTd>
                    <MudTd DataLabel="Confirmations">
                        @if (context.Chain == "LTC")
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Default">–</MudChip>
                        }
                        else
                        {
                            var confFull = _networkStats?.BestBlockHeight > 0 && context.Height > 0
                                ? _networkStats!.BestBlockHeight - context.Height + 1 : (long?)null;
                            if (confFull is null)
                            {
                                <MudChip T="string" Size="Size.Small" Color="Color.Warning">Pending</MudChip>
                            }
                            else if (confFull >= 100)
                            {
                                <MudChip T="string" Size="Size.Small" Color="Color.Success">@($"{confFull:N0}")</MudChip>
                            }
                            else
                            {
                                <MudChip T="string" Size="Size.Small" Color="Color.Warning">@($"{confFull:N0}")</MudChip>
                            }
                        }
                    </MudTd>
                    <MudTd DataLabel="Verify">
                        <MudLink Href="@(context.Chain == "LTC"
                                        ? $"https://blockchair.com/litecoin/block/{(string.IsNullOrEmpty(context.Hash) ? context.Height.ToString() : context.Hash)}"
                                        : $"https://blockchair.com/dogecoin/block/{(string.IsNullOrEmpty(context.Hash) ? context.Height.ToString() : context.Hash)}")"
                                 Target="_blank" Style="color: #7e6fff;">
                            <MudIcon Icon="@Icons.Material.Filled.OpenInNew" Style="font-size: 1.3rem;" />
                        </MudLink>
                    </MudTd>
                </RowTemplate>
                <PagerContent>
                    <MudTablePager PageSizeOptions="@_tablePagSizes" />
                </PagerContent>
            </MudTable>
        </MudPaper>
    }
</div>

<div style="@(IsLiteMode ? "display:none" : "")">

@* ===== MOBILE MINI CHART (only on xs, hidden on sm+) ===== *@
@if (_24hSeries.Count > 0 && _24hPeak > 0)
{
    <div class="d-sm-none mb-3" style="width:100%;">
        <MudPaper Class="glass-card pa-3" Elevation="0" Style="width:100%; overflow:visible;">
            <div class="d-flex align-center gap-2 mb-1">
                <MudIcon Icon="@Icons.Material.Filled.Speed" Style="color:#7e6fff; font-size:1.4rem;" />
                <MudText Class="stat-card-label" Style="font-size:0.75rem; font-weight:500; letter-spacing:0.5px;">LIVE 24H HASHRATE (TH/S)</MudText>
            </div>
            <div style="pointer-events:none; margin-left:-1rem; width:calc(100% + 1rem); overflow:visible;">
                <MudChart ChartType="ChartType.Line"
                          ChartSeries="@_24hSeries"
                          ChartLabels="@_24hMiniLabels"
                          Width="100%" Height="80px"
                          ChartOptions="@_miniChartOptions" />
            </div>
        </MudPaper>
    </div>
}

@* ===== STATS CARDS ===== *@
@if (_latest is not null)
{
    <MudGrid Class="mb-4 stats-grid" Spacing="3">

        @* ── Zeile 1: Mining-Leistung + DOGE Blöcke ── *@
        <MudItem xs="12" sm="6" md="3">
            <StatCard Icon="@Icons.Material.Filled.Speed"
                      Title="Hashrate"
                      Value="@FormatHashrateDisplay(_latest.Hashrate)"
                      SecondaryValue="@(_latestEpochSummary is not null ? $"{_latestEpochSummary.PeakHashrateDisplay}" : "–")"
                      SecondaryLabel="Epoch"
                      TertiaryValue="@(_allTimeStats is not null && _allTimeStats.PeakHashrate > 0 ? $"{_allTimeStats.PeakHashrateDisplay} · E{_allTimeStats.PeakHashrateEpoch}" : "–")"
                      TertiaryLabel="ATH"
                      Color="#7e6fff"
                      Tooltip="Current pool hashrate. Ep Avg: average over the last completed epoch. ATH: highest hashrate ever recorded." />
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <StatCard Icon="@Icons.Material.Filled.Language"
                      Title="Pool Share of Network"
                      Value="@(_networkStats is not null && _networkStats.NetworkHashrate > 0
                          ? $"{(_latest.Hashrate / (double)_networkStats.NetworkHashrate * 100):F3} %"
                          : "–")"
                      SecondaryValue="@(_latestEpochSummary is not null && _latestEpochSummary.PeakNetworkSharePct > 0 ? $"{_latestEpochSummary.PeakNetworkSharePct:F3} %" : "–")"
                      SecondaryLabel="Epoch"
                      TertiaryValue="@(_allTimeStats is not null && _allTimeStats.PeakNetworkSharePct > 0 ? $"{_allTimeStats.PeakNetworkSharePct:F3} % · E{_allTimeStats.PeakNetworkShareEpoch}" : "–")"
                      TertiaryLabel="ATH"
                      Color="#7e6fff"
                      Tooltip="Pool's share of the total Dogecoin network hashrate (24h avg). Ep Peak: highest in last completed epoch. ATH: highest ever recorded." />
        </MudItem>

          @* ── Pool Rank StatCard ── *@
        <MudItem xs="12" sm="6" md="3">
            <StatCard Icon="@Icons.Material.Filled.EmojiEvents"
                      Title="Pool Rank (DOGE)"
                      Value="@(_miningPoolRanking is not null ? $"#{_miningPoolRanking.Qubic.Rank}" : "–")"
                      SecondaryValue="@(_latestEpochSummary is not null && _latestEpochSummary.BestRank > 0 ? $"#{_latestEpochSummary.BestRank}" : "–")"
                      SecondaryLabel="Epoch"
                      TertiaryValue="@(_allTimeStats is not null && _allTimeStats.BestRank > 0 ? $"#{_allTimeStats.BestRank} · E{_allTimeStats.BestRankEpoch}" : "–")"
                      TertiaryLabel="Best"
                      Color="#7e6fff"
                      Tooltip="@(_miningPoolRanking is not null ? $"Qubic's rank among all DOGE mining pools by hashrate (of {_miningPoolRanking.TotalPools} pools · updated {_miningPoolRanking.FetchedAt.ToLocalTime():HH:mm}). Lower = better. Epoch: best rank this epoch. Best: all-time best rank." : "Qubic's rank among all DOGE mining pools by hashrate. Lower = better.")" />
        </MudItem>
        
        @* ── DOGE Blocks ── *@
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Class="glass-card pa-3" Elevation="0" Style="height:100%;">
                <div class="d-flex align-center gap-2 mb-2">
                    <MudIcon Icon="@Icons.Material.Filled.Stars" Style="color:#4caf50; font-size:1.4rem;" />
                    <MudText Class="stat-card-label" Style="font-size:0.75rem; font-weight:500; letter-spacing:0.5px;">DOGE BLOCKS</MudText>
                    <MudTooltip Text="Gold = Found, Green = Confirmed. Row 1: current epoch. Row 2 (Best): epoch with the most blocks ever. Row 3 (Total): all-time sum across all epochs." Placement="Placement.Top" Arrow="true">
                        <MudIcon Icon="@Icons.Material.Outlined.Info" Class="stat-card-info-icon" Style="font-size:0.95rem; cursor:help; margin-left:auto;" />
                    </MudTooltip>
                </div>
                <div class="d-flex gap-2 align-baseline mb-1">
                    <MudText Typo="Typo.h5" Style="color:#4caf50; font-weight:700;">@(_currentEpochBlocksConfirmed > 0 ? _currentEpochBlocksConfirmed.ToString("N0") : "–")</MudText>
                    <MudText Typo="Typo.body2" Style="color:#FFD700; font-weight:600;">(@(_currentEpochBlocksFound > 0 ? _currentEpochBlocksFound.ToString("N0") : "–"))</MudText>
                </div>
                <div class="d-flex align-center gap-1 mt-1">
                    <MudText Typo="Typo.caption" Class="dim-text" Style="min-width:3rem;">Best</MudText>
                    <MudText Typo="Typo.body2" Style="color:#4caf50; opacity:0.8; font-weight:600;">@(_peakBlocksConfirmed > 0 ? _peakBlocksConfirmed.ToString("N0") : "–")</MudText>
                    <MudText Typo="Typo.body2" Style="color:#FFD700; opacity:0.8; font-weight:600;">(@(_peakBlocksFound > 0 ? _peakBlocksFound.ToString("N0") : "–"))</MudText>
                    <MudText Typo="Typo.caption" Class="dim-text mx-1">·</MudText>
                    <MudText Typo="Typo.caption" Style="color:#4caf50;">E@(_peakBlocksFoundEpoch)</MudText>
                </div>
                <div class="d-flex align-center gap-1 mt-1">
                    <MudText Typo="Typo.body1" Style="color:#FF8C00; font-weight:700; min-width:3rem;">Total</MudText>
                    <MudText Typo="Typo.body1" Style="color:#4caf50; opacity:0.8; font-weight:600;">@(_totalBlocksConfirmed > 0 ? _totalBlocksConfirmed.ToString("N0") : "–")</MudText>
                    <MudText Typo="Typo.body1" Style="color:#FFD700; opacity:0.8; font-weight:600;">(@(_totalBlocksFound > 0 ? _totalBlocksFound.ToString("N0") : "–"))</MudText>
                </div>
            </MudPaper>
        </MudItem>

        @* ── LTC Blocks ── *@
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Class="glass-card pa-3" Elevation="0" Style="height:100%;">
                <div class="d-flex align-center gap-2 mb-2">
                    <MudIcon Icon="@Icons.Material.Filled.Stars" Style="color:#4caf50; font-size:1.4rem;" />
                    <MudText Class="stat-card-label" Style="font-size:0.75rem; font-weight:500; letter-spacing:0.5px;">LTC BLOCKS</MudText>
                    <MudTooltip Text="Blue = Found, Green = Confirmed. Row 1: current epoch. Row 2 (Best): epoch with the most LTC blocks ever. Row 3 (Total): all-time sum across all epochs." Placement="Placement.Top" Arrow="true">
                        <MudIcon Icon="@Icons.Material.Outlined.Info" Class="stat-card-info-icon" Style="font-size:0.95rem; cursor:help; margin-left:auto;" />
                    </MudTooltip>
                </div>
                <div class="d-flex gap-2 align-baseline mb-1">
                    <MudText Typo="Typo.h5" Style="color:#4caf50; font-weight:700;">@(_currentEpochLtcBlocksConfirmed > 0 ? _currentEpochLtcBlocksConfirmed.ToString("N0") : "–")</MudText>
                    <MudText Typo="Typo.body2" Style="color:#345D9D; font-weight:600;">(@(_currentEpochLtcBlocksFound > 0 ? _currentEpochLtcBlocksFound.ToString("N0") : "–"))</MudText>
                </div>
                <div class="d-flex align-center gap-1 mt-1">
                    <MudText Typo="Typo.caption" Class="dim-text" Style="min-width:3rem;">Best</MudText>
                    <MudText Typo="Typo.body2" Style="color:#4caf50; opacity:0.8; font-weight:600;">@(_peakLtcBlocksConfirmed > 0 ? _peakLtcBlocksConfirmed.ToString("N0") : "–")</MudText>
                    <MudText Typo="Typo.body2" Style="color:#345D9D; opacity:0.8; font-weight:600;">(@(_peakLtcBlocksFound > 0 ? _peakLtcBlocksFound.ToString("N0") : "–"))</MudText>
                    <MudText Typo="Typo.caption" Class="dim-text mx-1">·</MudText>
                    <MudText Typo="Typo.caption" Style="color:#4caf50;">E@(_peakLtcBlocksFoundEpoch)</MudText>
                </div>
                <div class="d-flex align-center gap-1 mt-1">
                    <MudText Typo="Typo.body1" Style="color:#FF8C00; font-weight:700; min-width:3rem;">Total</MudText>
                    <MudText Typo="Typo.body1" Style="color:#4caf50; opacity:0.8; font-weight:600;">@(_totalLtcBlocksConfirmed > 0 ? _totalLtcBlocksConfirmed.ToString("N0") : "–")</MudText>
                    <MudText Typo="Typo.body1" Style="color:#345D9D; opacity:0.8; font-weight:600;">(@(_totalLtcBlocksFound > 0 ? _totalLtcBlocksFound.ToString("N0") : "–"))</MudText>
                </div>
            </MudPaper>
        </MudItem>

        @* ── Mining Pool Ranking ── *@
        <MudItem xs="12" sm="6" md="3">
            @if (_miningPoolRanking is not null)
            {
                <MudPaper Class="glass-card pa-3" Elevation="0" Style="height:100%;">
                    <div style="display:flex; align-items:center; gap:6px; margin-bottom:8px;">
                        <MudIcon Icon="@Icons.Material.Filled.Leaderboard" Style="color:#7e6fff; font-size:1.1rem;" />
                        <span style="font-weight:600; letter-spacing:0.05em; text-transform:uppercase; font-size:0.75rem; color:var(--mud-palette-text-secondary);">Pool Ranking (DOGE)</span>
                        <MudLink Href="https://miningpoolstats.stream/dogecoin" Target="_blank" Underline="Underline.None" Style="display:flex; align-items:center; line-height:1;">
                            <MudIcon Icon="@Icons.Material.Filled.OpenInNew" Style="font-size:0.75rem; color:var(--mud-palette-text-secondary);" />
                        </MudLink>
                    </div>
                    <div style="display:flex; flex-direction:column; gap:4px;">
                        @if (_miningPoolRanking.Above is { } above)
                        {
                            <div style="display:flex; justify-content:space-between; align-items:center; padding:4px 8px; border-radius:6px; background:rgba(255,255,255,0.04);">
                                <div style="display:flex; align-items:center; gap:6px;">
                                    <span style="font-size:0.7rem; color:var(--mud-palette-text-secondary); min-width:22px;">#@above.Rank</span>
                                    <span style="font-size:0.82rem; color:var(--mud-palette-text-secondary);">@above.Name</span>
                                </div>
                                <span style="font-size:0.78rem; color:var(--mud-palette-text-secondary);">@FormatGHs(above.HashrateGHs)</span>
                            </div>
                        }
                        <div style="display:flex; justify-content:space-between; align-items:center; padding:5px 8px; border-radius:6px; background:rgba(126,111,255,0.18); border:1px solid rgba(126,111,255,0.35);">
                            <div style="display:flex; align-items:center; gap:6px;">
                                <span style="font-size:0.75rem; font-weight:700; color:#7e6fff; min-width:22px;">#@_miningPoolRanking.Qubic.Rank</span>
                                <span style="font-size:0.88rem; font-weight:600; color:#7e6fff;">@_miningPoolRanking.Qubic.Name</span>
                            </div>
                            <span style="font-size:0.82rem; font-weight:600; color:#7e6fff;">@FormatGHs(_miningPoolRanking.Qubic.HashrateGHs)</span>
                        </div>
                        @if (_miningPoolRanking.Below is { } below)
                        {
                            <div style="display:flex; justify-content:space-between; align-items:center; padding:4px 8px; border-radius:6px; background:rgba(255,255,255,0.04);">
                                <div style="display:flex; align-items:center; gap:6px;">
                                    <span style="font-size:0.7rem; color:var(--mud-palette-text-secondary); min-width:22px;">#@below.Rank</span>
                                    <span style="font-size:0.82rem; color:var(--mud-palette-text-secondary);">@below.Name</span>
                                </div>
                                <span style="font-size:0.78rem; color:var(--mud-palette-text-secondary);">@FormatGHs(below.HashrateGHs)</span>
                            </div>
                        }
                    </div>
                </MudPaper>
            }
            else
            {
                <MudPaper Class="glass-card pa-3" Elevation="0" Style="height:100%; display:flex; align-items:center; justify-content:center;">
                    <MudText Typo="Typo.caption" Class="dim-text">Ranking loading...</MudText>
                </MudPaper>
            }
        </MudItem>      


        @* ── Zeile 2: Systeminformationen ── *@
        <MudItem xs="12" sm="6" md="3">
            @{ var _lastFoundBlock = _recentBlocks.Count > 0 ? _recentBlocks.OrderByDescending(b => b.Time).First() : null; }
            <StatCard Icon="@Icons.Material.Filled.AvTimer"
                      Title="Avg Block Interval"
                      Value="@(_lastFoundBlock is not null ? FormatUptimeSpan(DateTimeOffset.UtcNow - _lastFoundBlock.Time) : "–")"
                      ValueLabel="since last"
                      SecondaryValue="@(_avgBlockIntervalEpoch.HasValue ? FormatUptimeSpan(_avgBlockIntervalEpoch.Value) : "–")"
                      SecondaryLabel="Epoch"
                      TertiaryValue="@(_avgBlockIntervalAll.HasValue ? FormatUptimeSpan(_avgBlockIntervalAll.Value) : "–")"
                      TertiaryLabel="All-time"
                      Color="#FFD700"
                      Tooltip="Time since the last block was found (live). Epoch: average interval between blocks in the current epoch. All-time: average over all blocks ever found." />
        </MudItem>
        @* ── Network Status: Epoch + Peers ── *@
        <MudItem xs="12" sm="6" md="6">
            <MudPaper Class="glass-card pa-3" Elevation="0" Style="height:100%;">
                <div class="d-flex align-center gap-2 mb-3">
                    <MudIcon Icon="@Icons.Material.Filled.Hub" Style="color:#4EE0FC; font-size:1.4rem;" />
                    <MudText Class="stat-card-label" Style="font-size:0.75rem; font-weight:500; letter-spacing:0.5px;">NETWORK STATUS</MudText>
                    <MudTooltip Text="Current Qubic epoch (increments weekly, Wed 12:00 UTC). Connected peers vs. total known peers in the Qubic network." Placement="Placement.Top" Arrow="true">
                        <MudIcon Icon="@Icons.Material.Outlined.Info" Class="stat-card-info-icon" Style="font-size:0.95rem; cursor:help; margin-left:auto;" />
                    </MudTooltip>
                </div>
                <div class="d-flex gap-6 align-end">
                    <div>
                        <MudText Typo="Typo.caption" Class="dim-text" Style="display:block; margin-bottom:2px;">Epoch</MudText>
                        <MudText Typo="Typo.h5" Style="color:#4EE0FC; font-weight:700;">@(_latest.QubicEpoch > 0 ? _latest.QubicEpoch.ToString() : "–")</MudText>
                    </div>
                    <div style="width:1px; background:rgba(255,255,255,0.08); align-self:stretch; margin:0 8px;"></div>
                    <div>
                        <MudText Typo="Typo.caption" Class="dim-text" Style="display:block; margin-bottom:2px;">Connected Peers</MudText>
                        <MudText Typo="Typo.h5" Style="color:#4EE0FC; font-weight:700;">@($"{_latest.ConnectedPeers} / {_latest.TotalPeers}")</MudText>
                    </div>
                </div>
            </MudPaper>
        </MudItem>

        @* ── Uptime: Dispatcher + Pool Session ── *@
        <MudItem xs="12" sm="6" md="6">
            <MudPaper Class="glass-card pa-3" Elevation="0" Style="height:100%;">
                <div class="d-flex align-center gap-2 mb-3">
                    <MudIcon Icon="@Icons.Material.Filled.Timer" Style="color:#4EE0FC; font-size:1.4rem;" />
                    <MudText Class="stat-card-label" Style="font-size:0.75rem; font-weight:500; letter-spacing:0.5px;">UPTIME</MudText>
                    <MudTooltip Text="Dispatcher: time since last dispatcher restart. Pool session: time since last pool server restart — shares and blocks are counted per session." Placement="Placement.Top" Arrow="true">
                        <MudIcon Icon="@Icons.Material.Outlined.Info" Class="stat-card-info-icon" Style="font-size:0.95rem; cursor:help; margin-left:auto;" />
                    </MudTooltip>
                </div>
                <div class="d-flex gap-3 align-end">
                    <div>
                        <MudText Typo="Typo.caption" Class="dim-text" Style="display:block; margin-bottom:2px;">Dispatcher</MudText>
                        <MudText Style="color:#4EE0FC; font-weight:700; font-size:1.2rem;">@FormatUptime(_latest.UptimeSeconds)</MudText>
                    </div>
                    <div style="width:1px; background:rgba(255,255,255,0.08); align-self:stretch; margin:0 8px;"></div>
                    <div>
                        <MudText Typo="Typo.caption" Class="dim-text" Style="display:block; margin-bottom:2px;">Pool Session</MudText>
                        <MudText Style="color:#4EE0FC; font-weight:700; font-size:1.2rem;">@(_poolStats is not null ? FormatUptimeSpan(DateTimeOffset.UtcNow - _poolStats.SessionStart) : "–")</MudText>
                    </div>
                </div>
            </MudPaper>
        </MudItem>

        @* ── Zeile 3: Arbeitsdaten (Qubic + Pool Shares) ── *@
        <MudItem xs="12" sm="6" md="2">
            <StatCard Icon="@Icons.Material.Filled.Assignment"
                      Title="Tasks Distributed"
                      Value="@(_currentEpochTasksDistributed > 0 ? _currentEpochTasksDistributed.ToString("N0") : "–")"
                      SecondaryValue="@(_peakTasksDistributed > 0 ? $"{_peakTasksDistributed:N0} · E{_peakTasksDistributedEpoch}" : "–")"
                      SecondaryLabel="Epoch"
                      TertiaryValue="@(_totalTasksDistributed > 0 ? _totalTasksDistributed.ToString("N0") : "–")"
                      TertiaryLabel="Total"
                      Color="#4EE0FC"
                      Tooltip="Compute tasks distributed to miners. Epoch: highest single-epoch value (with epoch number). Total: all-time sum." />
        </MudItem>
        <MudItem xs="12" sm="6" md="2">
            <StatCard Icon="@Icons.Material.Filled.TaskAlt"
                      Title="Solutions Accepted"
                      Value="@(_latestEpochSummary is not null && _latestEpochSummary.TotalSolutionsAccepted > 0 ? _latestEpochSummary.TotalSolutionsAccepted.ToString("N0") : "–")"
                      SecondaryValue="@(_peakSolutionsAccepted > 0 ? $"{_peakSolutionsAccepted:N0} · E{_peakSolutionsAcceptedEpoch}" : "–")"
                      SecondaryLabel="Epoch"
                      TertiaryValue="@(_totalSolutionsAccepted > 0 ? _totalSolutionsAccepted.ToString("N0") : "–")"
                      TertiaryLabel="Total"
                      Color="#4caf50"
                      Tooltip="Solutions accepted by the Qubic network. Epoch: highest single-epoch value (with epoch number). Total: all-time sum." />
        </MudItem>
        <MudItem xs="12" sm="6" md="2">
            <StatCard Icon="@Icons.Material.Filled.ContentPaste"
                      Title="Solutions Stale"
                      Value="@(_latestEpochSummary is not null && _latestEpochSummary.TotalSolutionsStale > 0 ? _latestEpochSummary.TotalSolutionsStale.ToString("N0") : "–")"
                      SecondaryValue="@(_peakSolutionsStale > 0 ? $"{_peakSolutionsStale:N0} · E{_peakSolutionsStaleEpoch}" : "–")"
                      SecondaryLabel="Epoch"
                      TertiaryValue="@(_totalSolutionsStale > 0 ? _totalSolutionsStale.ToString("N0") : "–")"
                      TertiaryLabel="Total"
                      Color="#ff9800"
                      Tooltip="Stale solutions — submitted after the tick expired. Epoch: highest single-epoch value (with epoch number). Total: all-time sum." />
        </MudItem>
        <MudItem xs="12" sm="6" md="2">
            <StatCard Icon="@Icons.Material.Filled.CheckCircle"
                      Title="Pool Accepted"
                      Value="@(_latestEpochSummary is not null && _latestEpochSummary.TotalPoolAccepted > 0 ? _latestEpochSummary.TotalPoolAccepted.ToString("N0") : "–")"
                      SecondaryValue="@(_peakPoolAccepted > 0 ? $"{_peakPoolAccepted:N0} · E{_peakPoolAcceptedEpoch}" : "–")"
                      SecondaryLabel="Epoch"
                      TertiaryValue="@(_totalPoolAccepted > 0 ? _totalPoolAccepted.ToString("N0") : "–")"
                      TertiaryLabel="Total"
                      Color="#4caf50"
                      Tooltip="Shares accepted by the pool. Epoch: highest single-epoch value (with epoch number). Total: all-time sum." />
        </MudItem>
        <MudItem xs="12" sm="6" md="2">
            <StatCard Icon="@Icons.Material.Filled.Error"
                      Title="Pool Rejected"
                      Value="@(_latestEpochSummary is not null && _latestEpochSummary.TotalPoolRejected > 0 ? _latestEpochSummary.TotalPoolRejected.ToString("N0") : "–")"
                      SecondaryValue="@(_peakPoolRejected > 0 ? $"{_peakPoolRejected:N0} · E{_peakPoolRejectedEpoch}" : "–")"
                      SecondaryLabel="Epoch"
                      TertiaryValue="@(_totalPoolRejected > 0 ? _totalPoolRejected.ToString("N0") : "–")"
                      TertiaryLabel="Total"
                      Color="#f44336"
                      Tooltip="Shares rejected by the pool. Epoch: highest single-epoch value (with epoch number). Total: all-time sum." />
        </MudItem>
        <MudItem xs="12" sm="6" md="2">
            <StatCard Icon="@Icons.Material.Filled.CheckCircle"
                      Title="Pool Shares Valid"
                      Value="@(_latestEpochSummary is not null && _latestEpochSummary.SharesValid > 0 ? _latestEpochSummary.SharesValid.ToString("N0") : "–")"
                      SecondaryValue="@(_peakSharesValid > 0 ? $"{_peakSharesValid:N0} · E{_peakSharesValidEpoch}" : "–")"
                      SecondaryLabel="Epoch"
                      TertiaryValue="@(_totalSharesValid > 0 ? _totalSharesValid.ToString("N0") : "–")"
                      TertiaryLabel="Total"
                      Color="#4caf50"
                      Tooltip="Valid shares. Session: current pool session. Epoch: highest single-epoch value (with epoch number). Total: all-time sum." />
        </MudItem>

        @* ── Zeile 4: Finanzen ── *@
        @{
            var totalBlocks    = _totalBlocksFound;
            var historicalUsd  = _recentBlocks.Where(b => b.Chain != "LTC" && b.DogePriceUsdAtFind > 0).Sum(b => b.DogePriceUsdAtFind * DogeBlockReward);
            var currentUsd     = _dogePrice is not null ? totalBlocks * DogeBlockReward * _dogePrice.UsdPrice : 0m;

            var totalLtcBlocks    = _totalLtcBlocksFound;
            var ltcHistoricalUsd  = _recentBlocks.Where(b => b.Chain == "LTC" && b.LtcPriceUsdAtFind > 0).Sum(b => b.LtcPriceUsdAtFind * LtcBlockReward);
            var ltcCurrentUsd     = _ltcPrice is not null ? totalLtcBlocks * LtcBlockReward * _ltcPrice.UsdPrice : 0m;
        }

        @* DOGE: Price · Per Block · Block Reward *@
        <MudItem xs="12" sm="6" md="4">
            <MudPaper Class="glass-card pa-3" Elevation="0" Style="height:100%;">
                <div class="d-flex align-center gap-2 mb-3">
                    <MudIcon Icon="@Icons.Material.Filled.MonetizationOn" Style="color:#FFD700; font-size:1.4rem;" />
                    <MudText Class="stat-card-label" Style="font-size:0.75rem; font-weight:500; letter-spacing:0.5px;">DOGE <span style="opacity:0.4; font-weight:400;">·</span> 10,000 DOGE block reward</MudText>
                    <MudTooltip Text="DOGE price updated hourly via CoinPaprika. Block reward is permanently fixed at 10,000 DOGE since 2015. Per Block = price × 10,000 DOGE." Placement="Placement.Top" Arrow="true">
                        <MudIcon Icon="@Icons.Material.Outlined.Info" Class="stat-card-info-icon" Style="font-size:0.95rem; cursor:help; margin-left:auto;" />
                    </MudTooltip>
                </div>
                <div class="d-flex align-center gap-3 flex-wrap">
                    <div>
                        <MudText Typo="Typo.caption" Class="dim-text" Style="display:block; margin-bottom:1px;">Price</MudText>
                        <MudText Typo="Typo.h5" Style="color:#FFD700; font-weight:700; white-space:nowrap;">
                            @(_dogePrice is not null ? $"${_dogePrice.UsdPrice:F4}" : "–")
                        </MudText>
                    </div>
                    <div style="width:1px; background:rgba(255,255,255,0.08); align-self:stretch; margin:0 8px;"></div>
                    <div>
                        <MudText Typo="Typo.caption" Class="dim-text" Style="display:block; margin-bottom:1px;">Per Block</MudText>
                        <MudText Typo="Typo.h5" Style="color:#FFD700; font-weight:700; white-space:nowrap;">
                            @(_dogePrice is not null ? $"${DogeBlockReward * _dogePrice.UsdPrice:F2}" : "–")
                        </MudText>
                    </div>
                </div>
            </MudPaper>
        </MudItem>

        @* DOGE Total Block Reward *@
        <MudItem xs="12" sm="6" md="8">
            <StatCard Icon="@Icons.Material.Filled.Savings"
                      Title="Total Block Reward"
                      Value="@($"{totalBlocks * DogeBlockReward:N0} DOGE")"
                      SecondaryValue="@(historicalUsd > 0 ? $"${historicalUsd:N2}" : "–")"
                      SecondaryLabel="Hist. USD"
                      TertiaryValue="@(_dogePrice is not null ? $"${currentUsd:N2}" : "–")"
                      TertiaryLabel="Now USD"
                      Color="#4caf50"
                      Tooltip="Total DOGE from all blocks (blocks × 10,000). Hist. USD: sum of USD value at the moment each block was found. Now USD: same DOGE at current price." />
        </MudItem>

        @* LTC: Price · Per Block · Block Reward *@
        <MudItem xs="12" sm="6" md="4">
            <MudPaper Class="glass-card pa-3" Elevation="0" Style="height:100%;">
                <div class="d-flex align-center gap-2 mb-3">
                    <MudIcon Icon="@Icons.Material.Filled.MonetizationOn" Style="color:#345D9D; font-size:1.4rem;" />
                    <MudText Class="stat-card-label" Style="font-size:0.75rem; font-weight:500; letter-spacing:0.5px;">LTC <span style="opacity:0.4; font-weight:400;">·</span> 6.25 LTC block reward</MudText>
                    <MudTooltip Text="LTC price updated hourly via CoinPaprika. Block reward is currently 6.25 LTC (next halving ~August 2027). Per Block = price × 6.25 LTC." Placement="Placement.Top" Arrow="true">
                        <MudIcon Icon="@Icons.Material.Outlined.Info" Class="stat-card-info-icon" Style="font-size:0.95rem; cursor:help; margin-left:auto;" />
                    </MudTooltip>
                </div>
                <div class="d-flex align-center gap-3 flex-wrap">
                    <div>
                        <MudText Typo="Typo.caption" Class="dim-text" Style="display:block; margin-bottom:1px;">Price</MudText>
                        <MudText Typo="Typo.h5" Style="color:#345D9D; font-weight:700; white-space:nowrap;">
                            @(_ltcPrice is not null ? $"${_ltcPrice.UsdPrice:F2}" : "–")
                        </MudText>
                    </div>
                    <div style="width:1px; background:rgba(255,255,255,0.08); align-self:stretch; margin:0 8px;"></div>
                    <div>
                        <MudText Typo="Typo.caption" Class="dim-text" Style="display:block; margin-bottom:1px;">Per Block</MudText>
                        <MudText Typo="Typo.h5" Style="color:#345D9D; font-weight:700; white-space:nowrap;">
                            @(_ltcPrice is not null ? $"${LtcBlockReward * _ltcPrice.UsdPrice:F2}" : "–")
                        </MudText>
                    </div>
                </div>
            </MudPaper>
        </MudItem>

        @* LTC Total Block Reward *@
        <MudItem xs="12" sm="6" md="8">
            <StatCard Icon="@Icons.Material.Filled.Savings"
                      Title="Total Block Reward"
                      Value="@($"{totalLtcBlocks * LtcBlockReward:N2} LTC")"
                      SecondaryValue="@(ltcHistoricalUsd > 0 ? $"${ltcHistoricalUsd:N2}" : "–")"
                      SecondaryLabel="Hist. USD"
                      TertiaryValue="@(_ltcPrice is not null && totalLtcBlocks > 0 ? $"${ltcCurrentUsd:N2}" : "–")"
                      TertiaryLabel="Now USD"
                      Color="#4caf50"
                      Tooltip="Total LTC from all blocks (blocks × 6.25). Hist. USD: sum of USD value at the moment each block was found. Now USD: same LTC at current price." /></MudItem>

        @* ── Block Revenue ── *@
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Class="glass-card pa-3" Elevation="0" Style="height:100%;">
                <div class="d-flex align-center gap-2 mb-2">
                    <MudIcon Icon="@Icons.Material.Filled.AttachMoney" Style="color:#4caf50; font-size:1.4rem;" />
                    <MudText Class="stat-card-label" Style="font-size:0.75rem; font-weight:500; letter-spacing:0.5px;">BLOCK REVENUE</MudText>
                    <MudTooltip Text="Combined DOGE + LTC block rewards in USD. Row 1: current epoch at price at time of find. Row 2 (Best): epoch with highest total revenue. Row 3 (Total): all-time sum." Placement="Placement.Top" Arrow="true">
                        <MudIcon Icon="@Icons.Material.Outlined.Info" Class="stat-card-info-icon" Style="font-size:0.95rem; cursor:help; margin-left:auto;" />
                    </MudTooltip>
                </div>
                <div class="d-flex gap-2 align-baseline mb-1">
                    <MudText Typo="Typo.h5" Style="color:#4caf50; font-weight:700;">@(_currentEpochRevenueUsd > 0 ? $"${_currentEpochRevenueUsd:N0}" : "–")</MudText>
                </div>
                <div class="d-flex align-center gap-1 mt-1">
                    <MudText Typo="Typo.caption" Class="dim-text" Style="min-width:3rem;">Best</MudText>
                    <MudText Typo="Typo.body2" Style="color:#4caf50; opacity:0.8; font-weight:600;">@(_bestEpochRevenueUsd > 0 ? $"${_bestEpochRevenueUsd:N0}" : "–")</MudText>
                    @if (_bestEpochRevenueEpoch > 0)
                    {
                        <MudText Typo="Typo.caption" Class="dim-text mx-1">·</MudText>
                        <MudText Typo="Typo.caption" Style="color:#4caf50;">E@(_bestEpochRevenueEpoch)</MudText>
                    }
                </div>
                <div class="d-flex align-center gap-1 mt-1">
                    <MudText Typo="Typo.body1" Style="color:#FF8C00; font-weight:700; min-width:3rem;">Total</MudText>
                    <MudText Typo="Typo.body1" Style="color:#4caf50; opacity:0.8; font-weight:600;">@(_totalRevenueUsd > 0 ? $"${_totalRevenueUsd:N0}" : "–")</MudText>
                </div>
            </MudPaper>
        </MudItem>

        @* ── Pool Difficulty (live) — auskommentiert, ggf. später wieder aktivieren ──
        <MudItem xs="12" sm="6" md="3">
            <StatCard Icon="@Icons.Material.Filled.TrendingUp"
                      Title="Pool Difficulty (live)"
                      Value="@(_latest is not null && _latest.PoolDifficulty > 0 ? $"{_latest.PoolDifficulty / 1_000_000.0:F1} M" : "–")"
                      Color="#7e6fff"
                      Tooltip="Current pool difficulty in millions. Adjusted automatically by the pool based on miner hashrate." />
        </MudItem>
        ── *@

        @* ── Farblegende (auskommentiert) ──
        <MudItem xs="12">
            <MudPaper Class="glass-card pa-3" Elevation="0">
                <MudText Typo="Typo.caption" Class="mb-2 dim-text" Style="font-weight:600; letter-spacing:0.05em; text-transform:uppercase;">Panel Color Legend</MudText>
                <div style="display:flex; flex-wrap:wrap; gap:12px 24px; align-items:center;">
                    <div style="display:flex; align-items:center; gap:6px;">
                        <div style="width:12px; height:12px; border-radius:50%; background:#7e6fff; flex-shrink:0;"></div>
                        <MudText Typo="Typo.caption"><b style="color:#7e6fff;">Purple</b> — Mining performance (Hashrate, Pool Share)</MudText>
                    </div>
                    <div style="display:flex; align-items:center; gap:6px;">
                        <div style="width:12px; height:12px; border-radius:50%; background:#4EE0FC; flex-shrink:0;"></div>
                        <MudText Typo="Typo.caption"><b style="color:#4EE0FC;">Cyan</b> — System status &amp; neutral metrics (Epoch, Uptime, Peers, Tasks)</MudText>
                    </div>
                    <div style="display:flex; align-items:center; gap:6px;">
                        <div style="width:12px; height:12px; border-radius:50%; background:#FFD700; flex-shrink:0;"></div>
                        <MudText Typo="Typo.caption"><b style="color:#FFD700;">Gold</b> — DOGE &amp; financial values (Blocks Found, Price, Reward)</MudText>
                    </div>
                    <div style="display:flex; align-items:center; gap:6px;">
                        <div style="width:12px; height:12px; border-radius:50%; background:#4caf50; flex-shrink:0;"></div>
                        <MudText Typo="Typo.caption"><b style="color:#4caf50;">Green</b> — Positive &amp; confirmed (Blocks Confirmed, Accepted, Valid, Total Reward)</MudText>
                    </div>
                    <div style="display:flex; align-items:center; gap:6px;">
                        <div style="width:12px; height:12px; border-radius:50%; background:#f44336; flex-shrink:0;"></div>
                        <MudText Typo="Typo.caption"><b style="color:#f44336;">Red</b> — Rejected / negative (Pool Rejected)</MudText>
                    </div>
                    <div style="display:flex; align-items:center; gap:6px;">
                        <div style="width:12px; height:12px; border-radius:50%; background:#ff9800; flex-shrink:0;"></div>
                        <MudText Typo="Typo.caption"><b style="color:#ff9800;">Orange</b> — Warning / stale (Solutions Stale)</MudText>
                    </div>
                </div>
            </MudPaper>
        </MudItem>
        *@

    </MudGrid>
}
else
{
    <MudPaper Class="glass-card pa-6 mb-4 d-flex justify-center align-center" Elevation="0">
        <MudProgressCircular Indeterminate="true" Color="Color.Primary" Size="Size.Large" />
        <MudText Class="ml-4 dim-text">Loading stats...</MudText>
    </MudPaper>
}

@* ===== TABS ===== *@
<MudTabs Elevation="0" TabHeaderClass="mb-4">
    <MudTabPanel Text="Hashrate" Icon="@Icons.Material.Filled.Speed">

        <div class="d-flex align-center justify-space-between flex-wrap gap-2 mb-3">
            <MudText Typo="Typo.caption" Class="dim-text">Last updated: @_lastRefresh.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")</MudText>
            <div class="d-flex gap-2 flex-wrap">
                @foreach (var cat in new[] { "All", "Live", "Epoch History", "Rankings", "Solutions & Shares" })
                {
                    var active = _hashrateFilter.Contains(cat);
                    <MudChip T="string"
                             Size="Size.Small"
                             OnClick="@(() => ToggleHashrateFilter(cat))"
                             Style="@(active
                                 ? "background:rgba(126,111,255,0.25); color:#7e6fff; border:1px solid rgba(126,111,255,0.5); cursor:pointer;"
                                 : "background:rgba(255,255,255,0.05); color:var(--mud-palette-text-secondary); border:1px solid rgba(255,255,255,0.1); cursor:pointer;")">
                        @cat
                    </MudChip>
                }
            </div>
        </div>

        @* ===== 24h HASHRATE CHART (full width) ===== *@
        @if (ShowHashrateCategory("Live"))
        {
        <MudGrid Class="mb-2">
            <MudItem xs="12">
                <MudPaper Class="glass-card pa-2" Elevation="0" Style="overflow:visible;">
                    <div class="d-flex justify-space-between align-end mb-3 flex-wrap gap-1">
                        <MudText Typo="Typo.h6" Style="color: #7e6fff;">Live 24h Hashrate (TH/s)</MudText>
                        <div class="d-flex flex-column align-end">
                            <MudText Typo="Typo.caption" Class="dim-text">Last 24 hours · by 30 min · auto 60 s · last update: @_lastRefresh.ToLocalTime().ToString("HH:mm:ss")</MudText>
                            @if (_24hPeak > 0)
                            {
                                <MudText Typo="Typo.caption" Style="color: #4EE0FC;">Peak: @($"{_24hPeak:F2} TH/s")</MudText>
                            }
                        </div>
                    </div>
                    @if (_apex24hData.Count > 0)
                    {
                        <div class="chart-apex-wrapper">
                            <ApexCharts.ApexChart TItem="Apex24hPoint"
                                       Options="@_apex24hOptions"
                                       @ref="_apex24hChart"
                                       Height="300">
                                <ApexCharts.ApexPointSeries TItem="Apex24hPoint"
                                                 Items="@_apex24hData"
                                                 SeriesType="ApexCharts.SeriesType.Line"
                                                 Name="TH/s"
                                                 XValue="@(p => p.Time.ToUnixTimeMilliseconds())"
                                                 YValue="@(p => (decimal)p.Value)"
                                                 OrderBy="p => p.X" />
                            </ApexCharts.ApexChart>
                        </div>
                    }
                    else
                    {
                        <div class="d-flex justify-center align-center" style="height:300px;">
                            <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
                            <MudText Class="ml-3 dim-text">Collecting 24h data…</MudText>
                        </div>
                    }
                </MudPaper>
            </MudItem>
        </MudGrid>
        }

        @* ===== LIVE HASHRATE CHARTS (side by side) ===== *@
        @if (ShowHashrateCategory("Live"))
        {
        <MudGrid Class="mb-2">
            <MudItem xs="12" md="6">
                <MudPaper Class="glass-card pa-2" Elevation="0" Style="height:100%;">
                    <div class="d-flex justify-space-between align-end mb-3 flex-wrap gap-1">
                        <MudText Typo="Typo.h6" Style="color: #7e6fff;">Live Hashrate (TH/s)</MudText>
                        <MudText Typo="Typo.caption" Class="dim-text">
                            Last update: @_lastRefresh.ToLocalTime().ToString("HH:mm:ss") · auto 60 s
                        </MudText>
                    </div>
                    @if (_history.Count > 1)
                    {
                        <div class="chart-mobile-wrapper" style="@ChartWrapperStyle(_chartSeries, _chartLabels)">
                            <MudChart ChartType="ChartType.Line"
                                      ChartSeries="@_chartSeries"
                                      ChartLabels="@_chartLabels"
                                      Width="100%" Height="280px"
                                      ChartOptions="@_chartOptions" />
                        </div>
                    }
                    else
                    {
                        <div class="d-flex justify-center align-center" style="height:280px;">
                            <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
                            <MudText Class="ml-3 dim-text">Waiting for data…</MudText>
                        </div>
                    }
                </MudPaper>
            </MudItem>
            <MudItem xs="12" md="6">
                <MudPaper Class="glass-card pa-2" Elevation="0" Style="height:100%;">
                    <div class="d-flex justify-space-between align-end mb-3 flex-wrap gap-1">
                        <MudText Typo="Typo.h6" Style="color: #7e6fff;">Today's Peak Hashrate (TH/s)</MudText>
                        <div class="d-flex flex-column align-end">
                            <MudText Typo="Typo.caption" Class="dim-text">
                                @DateTimeOffset.UtcNow.ToLocalTime().ToString("yyyy-MM-dd") · by 5 min
                            </MudText>
                            @if (_todayPeak > 0)
                            {
                                <MudText Typo="Typo.caption" Style="color: #FFD700;">
                                    Peak: @($"{_todayPeak:F2} TH/s")
                                </MudText>
                            }
                        </div>
                    </div>
                    @if (_todaySeries.Count > 0)
                    {
                        <div class="chart-mobile-wrapper" style="@ChartWrapperStyle(_todaySeries, _todayLabels)">
                            <MudChart ChartType="ChartType.Line"
                                      ChartSeries="@_todaySeries"
                                      ChartLabels="@_todayLabels"
                                      Width="100%" Height="320px"
                                      ChartOptions="@_peakLineChartOptions" />
                        </div>
                    }
                    else
                    {
                        <div class="d-flex justify-center align-center" style="height:280px;">
                            <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
                            <MudText Class="ml-3 dim-text">Collecting today's data…</MudText>
                        </div>
                    }
                </MudPaper>
            </MudItem>
        </MudGrid>
        }

        @* ===== CURRENT EPOCH TIMELINE + AVG HASHRATE PER EPOCH (side by side) ===== *@
        @if (ShowHashrateCategory("Epoch History"))
        {
        <MudGrid Class="mb-2">
            <MudItem xs="12" md="6">
                <MudPaper Class="glass-card pa-2" Elevation="0" Style="height:100%;">
                    <MudText Typo="Typo.h6" Class="mb-1" Style="color: #7e6fff;">
                        Current Epoch @(_latest?.QubicEpoch > 0 ? $"· Epoch {_latest.QubicEpoch}" : "") · Avg Hashrate (TH/s)
                    </MudText>
                    <MudText Typo="Typo.caption" Class="mb-3 dim-text">
                        Wed 12:00 UTC → next Wed 12:00 UTC
                    </MudText>
                    @if (_epochTimelineSeries.Count > 0)
                    {
                        <div class="chart-mobile-wrapper" style="@ChartWrapperStyle(_epochTimelineSeries, _epochTimelineLabels)">
                            <MudChart ChartType="ChartType.Line"
                                      ChartSeries="@_epochTimelineSeries"
                                      ChartLabels="@_epochTimelineLabels"
                                      Width="100%" Height="260px"
                                      ChartOptions="@_chartOptions" />
                        </div>
                    }
                    else
                    {
                        <div class="d-flex justify-center align-center" style="height:260px;">
                            <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
                            <MudText Class="ml-3 dim-text">Collecting current epoch data…</MudText>
                        </div>
                    }
                </MudPaper>
            </MudItem>
            <MudItem xs="12" md="6">
                <MudPaper Class="glass-card pa-2" Elevation="0" Style="height:100%;">
                    <MudText Typo="Typo.h6" Class="mb-1" Style="color: #7e6fff;">Avg Hashrate per Epoch (TH/s)</MudText>
                    <MudText Typo="Typo.caption" Class="mb-3 dim-text">Mean TH/s over all recorded snapshots per epoch</MudText>
                    @if (_epochHashrateSeries.Count > 0)
                    {
                        <div class="chart-mobile-wrapper" style="@ChartWrapperStyle(_epochHashrateSeries, _epochLabels)">
                            <MudChart ChartType="ChartType.Bar"
                                      ChartSeries="@_epochHashrateSeries"
                                      ChartLabels="@_epochLabels"
                                      Width="100%" Height="260px"
                                      ChartOptions="@_epochHashrateChartOptions" />
                        </div>
                    }
                    else
                    {
                        <div class="d-flex justify-center align-center" style="height:260px;">
                            <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
                        </div>
                    }
                </MudPaper>
            </MudItem>
        </MudGrid>
        }

 @* ===== TOP 10 EPOCHS BY PEAK + TOP 10 SNAPSHOTS ===== *@
        @if (ShowHashrateCategory("Rankings"))
        {
        <MudGrid Class="mb-2">
            <MudItem xs="12" md="6">
                <MudPaper Class="glass-card pa-2" Elevation="0" Style="height:100%;">
                    <MudText Typo="Typo.h6" Class="mb-1" Style="color: #7e6fff;">Top 10 Epochs by Peak Hashrate (TH/s)</MudText>
                    <MudText Typo="Typo.caption" Class="mb-3 dim-text">Ranking of the 10 epochs with the highest peak hashrate ever recorded</MudText>
                    @if (_top10EpochPeakSeries.Count > 0)
                    {
                        <div class="chart-mobile-wrapper" style="@ChartWrapperStyle(_top10EpochPeakSeries, _top10EpochPeakLabels)">
                            <MudChart ChartType="ChartType.Bar"
                                      ChartSeries="@_top10EpochPeakSeries"
                                      ChartLabels="@_top10EpochPeakLabels"
                                      Width="100%" Height="280px"
                                      ChartOptions="@_top10PeakChartOptions" />
                        </div>
                    }
                    else
                    {
                        <div class="d-flex justify-center align-center" style="height:280px;">
                            <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
                        </div>
                    }
                </MudPaper>
            </MudItem>
            <MudItem xs="12" md="6">
                <MudPaper Class="glass-card pa-2" Elevation="0" Style="height:100%;">
                    <MudText Typo="Typo.h6" Class="mb-1" Style="color: #7e6fff;">Top 10 Days by Peak Hashrate (TH/s)</MudText>
                    <MudText Typo="Typo.caption" Class="mb-3 dim-text">The 10 days with the highest peak hashrate ever recorded</MudText>
                    @if (_top10SnapshotSeries.Count > 0)
                    {
                        <div class="chart-mobile-wrapper" style="@ChartWrapperStyle(_top10SnapshotSeries, _top10SnapshotLabels)">
                            <MudChart ChartType="ChartType.Bar"
                                      ChartSeries="@_top10SnapshotSeries"
                                      ChartLabels="@_top10SnapshotLabels"
                                      Width="100%" Height="280px"
                                      ChartOptions="@_singlePeakChartOptions" />
                        </div>
                    }
                    else
                    {
                        <div class="d-flex justify-center align-center" style="height:280px;">
                            <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
                        </div>
                    }
                </MudPaper>
            </MudItem>
        </MudGrid>
        }
        
        @* ===== AVG + PEAK GROUPED BAR + NETWORK SHARE ===== *@
        @if (ShowHashrateCategory("Epoch History"))
        {
        <MudGrid Class="mb-2">
            <MudItem xs="12" md="6">
                <MudPaper Class="glass-card pa-2" Elevation="0" Style="height:100%;">
                    <MudText Typo="Typo.h6" Class="mb-1" Style="color: #7e6fff;">Avg &amp; Peak Hashrate per Epoch (TH/s)</MudText>
                    <MudText Typo="Typo.caption" Class="mb-3 dim-text">Average vs. peak hashrate per epoch — shows how far peak exceeds the average</MudText>
                    @if (_epochAvgPeakSeries.Count > 0)
                    {
                        <div class="chart-mobile-wrapper" style="@ChartWrapperStyle(_epochAvgPeakSeries, _epochLabels)">
                            <MudChart ChartType="ChartType.Bar"
                                      ChartSeries="@_epochAvgPeakSeries"
                                      ChartLabels="@_epochLabels"
                                      Width="100%" Height="280px"
                                      ChartOptions="@_epochHashrateChartOptions" />
                        </div>
                    }
                    else
                    {
                        <div class="d-flex justify-center align-center" style="height:280px;">
                            <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
                        </div>
                    }
                </MudPaper>
            </MudItem>
            <MudItem xs="12" md="6">
                <MudPaper Class="glass-card pa-2" Elevation="0" Style="height:100%;">
                    <MudText Typo="Typo.h6" Class="mb-1" Style="color: #7e6fff;">Pool Network Share per Epoch (%)</MudText>
                    <MudText Typo="Typo.caption" Class="mb-3 dim-text">Peak share of total DOGE network hashrate per epoch</MudText>
                    @if (_epochNetworkShareSeries.Count > 0)
                    {
                        <div class="chart-mobile-wrapper" style="@ChartWrapperStyle(_epochNetworkShareSeries, _epochLabels)">
                            <MudChart ChartType="ChartType.Bar"
                                      ChartSeries="@_epochNetworkShareSeries"
                                      ChartLabels="@_epochLabels"
                                      Width="100%" Height="280px"
                                      ChartOptions="@_networkShareChartOptions" />
                        </div>
                    }
                    else
                    {
                        <div class="d-flex justify-center align-center" style="height:280px;">
                            <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
                        </div>
                    }
                </MudPaper>
            </MudItem>
        </MudGrid>
        }

        @* ===== SOLUTIONS + POOL SHARES PER EPOCH ===== *@
        @if (ShowHashrateCategory("Solutions & Shares"))
        {
        <MudGrid Class="mb-2">
            <MudItem xs="12" md="6">
                <MudPaper Class="glass-card pa-2" Elevation="0" Style="height:100%;">
                    <MudText Typo="Typo.h6" Class="mb-1" Style="color: #7e6fff;">Solutions per Epoch</MudText>
                    <MudText Typo="Typo.caption" Class="mb-3 dim-text">Accepted, rejected and stale solutions per epoch</MudText>
                    @if (_epochSolutionsDetailSeries.Count > 0)
                    {
                        <div class="chart-mobile-wrapper" style="@ChartWrapperStyle(_epochSolutionsDetailSeries, _epochLabels)">
                            <MudChart ChartType="ChartType.Bar"
                                      ChartSeries="@_epochSolutionsDetailSeries"
                                      ChartLabels="@_epochLabels"
                                      Width="100%" Height="260px"
                                      ChartOptions="@_epochCounterChartOptions" />
                        </div>
                    }
                    else
                    {
                        <div class="d-flex justify-center align-center" style="height:260px;">
                            <MudProgressCircular Indeterminate="true" Color="Color.Secondary" />
                        </div>
                    }
                </MudPaper>
            </MudItem>
            <MudItem xs="12" md="6">
                <MudPaper Class="glass-card pa-2" Elevation="0" Style="height:100%;">
                    <MudText Typo="Typo.h6" Class="mb-1" Style="color: #7e6fff;">Pool Shares per Epoch</MudText>
                    <MudText Typo="Typo.caption" Class="mb-3 dim-text">Accepted vs. rejected pool shares per epoch</MudText>
                    @if (_epochPoolSeries.Count > 0)
                    {
                        <div class="chart-mobile-wrapper" style="@ChartWrapperStyle(_epochPoolSeries, _epochLabels)">
                            <MudChart ChartType="ChartType.Bar"
                                      ChartSeries="@_epochPoolSeries"
                                      ChartLabels="@_epochLabels"
                                      Width="100%" Height="260px"
                                      ChartOptions="@_epochCounterChartOptions" />
                        </div>
                    }
                    else
                    {
                        <div class="d-flex justify-center align-center" style="height:260px;">
                            <MudProgressCircular Indeterminate="true" Color="Color.Secondary" />
                        </div>
                    }
                </MudPaper>
            </MudItem>
            @if (ShowHashrateCategory("Live"))
            {
            <MudItem xs="12" md="6">
                <MudPaper Class="glass-card pa-2" Elevation="0" Style="height:100%;">
                    <div class="d-flex justify-space-between align-end mb-3 flex-wrap gap-1">
                        <MudText Typo="Typo.h6" Style="color: #7e6fff;">DOGE Network Hashrate (TH/s)</MudText>
                        <MudText Typo="Typo.caption" Class="dim-text">Last 60 min · auto 60 s</MudText>
                    </div>
                    @if (_networkHashrateSeries.Count > 0)
                    {
                        <div class="chart-mobile-wrapper" style="@ChartWrapperStyle(_networkHashrateSeries, _networkHashrateLabels)">
                            <MudChart ChartType="ChartType.Line"
                                      ChartSeries="@_networkHashrateSeries"
                                      ChartLabels="@_networkHashrateLabels"
                                      Width="100%" Height="260px"
                                      ChartOptions="@_chartOptions" />
                        </div>
                    }
                    else
                    {
                        <div class="d-flex justify-center align-center" style="height:260px;">
                            <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
                        </div>
                    }
                </MudPaper>
            </MudItem>
            }
        </MudGrid>
        }

    </MudTabPanel>
    <MudTabPanel Text="Blocks" Icon="@Icons.Material.Filled.ViewList">

        @* Row 1: Blocks per Epoch + Revenue per Epoch *@
        <MudGrid Class="mb-2">
            <MudItem xs="12" md="6">
                <MudPaper Class="glass-card pa-2" Elevation="0" Style="height:100%;">
                    <MudText Typo="Typo.h6" Class="mb-1" Style="color: #7e6fff;">Blocks per Epoch</MudText>
                    <MudText Typo="Typo.caption" Class="mb-3 dim-text">Found and confirmed blocks per Qubic epoch</MudText>
                    @if (_epochBlockSeries.Count > 0)
                    {
                        <div class="chart-mobile-wrapper" style="@ChartWrapperStyle(_epochBlockSeries, _poolEpochLabels)">
                            <MudChart ChartType="ChartType.Bar"
                                      ChartSeries="@_epochBlockSeries"
                                      ChartLabels="@_poolEpochLabels"
                                      Width="100%" Height="260px"
                                      ChartOptions="@_poolChartOptions" />
                        </div>
                    }
                    else
                    {
                        <div class="d-flex flex-column justify-center align-center gap-3" style="height:260px;">
                            <MudText Class="dim-text">No block data yet…</MudText>
                            <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
                        </div>
                    }
                </MudPaper>
            </MudItem>
            <MudItem xs="12" md="6">
                <MudPaper Class="glass-card pa-2" Elevation="0" Style="height:100%;">
                    <MudText Typo="Typo.h6" Class="mb-1" Style="color: #7e6fff;">Block Revenue per Epoch (USDT)</MudText>
                    <MudText Typo="Typo.caption" Class="mb-3 dim-text">DOGE + LTC block rewards in USD at price at time of find · per Qubic epoch</MudText>
                    @if (_epochRevenueSeries.Count > 0)
                    {
                        <div class="chart-mobile-wrapper" style="@ChartWrapperStyle(_epochRevenueSeries, _epochRevenueLabels)">
                            <MudChart ChartType="ChartType.Bar"
                                      ChartSeries="@_epochRevenueSeries"
                                      ChartLabels="@_epochRevenueLabels"
                                      Width="100%" Height="260px"
                                      ChartOptions="@_epochRevenueChartOptions" />
                        </div>
                    }
                    else
                    {
                        <div class="d-flex flex-column justify-center align-center gap-3" style="height:260px;">
                            <MudText Class="dim-text">No block data yet…</MudText>
                            <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
                        </div>
                    }
                </MudPaper>
            </MudItem>
        </MudGrid>

        @* Row 2: Recent Blocks — auskommentiert, ggf. später wieder aktivieren
        <MudGrid Class="mb-2">
            <MudItem xs="12">
                <MudPaper Class="glass-card pa-2" Elevation="0" Style="height:100%;">
                    <MudText Typo="Typo.h6" Class="mb-3" Style="color: #7e6fff;">Recent Blocks (Latest 5)</MudText>
                    @if (_recentBlocks.Count > 0)
                    {
                        <MudTable Items="@_recentBlocks.OrderByDescending(b => b.Time).Take(5)" Dense="true" Hover="true"
                                  Style="background: transparent;" Class="pool-blocks-table"
                                  GroupBy="@_blockGroupDef" Breakpoint="Breakpoint.Sm">
                            <HeaderContent>
                                <MudTh Style="color: #7e6fff;">Coin</MudTh>
                                <MudTh Style="color: #7e6fff;">Height</MudTh>
                                <MudTh Style="color: #7e6fff;">Hash</MudTh>
                                <MudTh Style="color: #7e6fff;">Time</MudTh>
                                <MudTh Style="color: #7e6fff;">Reward (USD)</MudTh>
                                <MudTh Style="color: #7e6fff;">Verify</MudTh>
                            </HeaderContent>
                            <GroupHeaderTemplate>
                                <MudTh colspan="6" Style="background: rgba(78,224,252,0.10); padding: 4px 12px; border-left: 3px solid #4EE0FC;">
                                    <MudText Typo="Typo.subtitle2" Style="color: #4EE0FC;">Epoch @context.Key</MudText>
                                </MudTh>
                            </GroupHeaderTemplate>
                            <RowTemplate>
                                <MudTd DataLabel="Coin">
                                    @if (context.Chain == "LTC")
                                    {
                                        <MudChip T="string" Size="Size.Small" Style="background:#345D9D; color:#fff; font-weight:700; font-size:0.7rem; height:20px;">LTC</MudChip>
                                    }
                                    else
                                    {
                                        <MudChip T="string" Size="Size.Small" Style="background:#c8a400; color:#fff; font-weight:700; font-size:0.7rem; height:20px;">DOGE</MudChip>
                                    }
                                </MudTd>
                                <MudTd DataLabel="Height">
                                    <MudLink Href="@(context.Chain == "LTC" ? $"https://blockchair.com/litecoin/block/{context.Height}" : $"https://dogechain.info/block/{context.Height}")"
                                             Target="_blank" Style="color: #4EE0FC;">@context.Height</MudLink>
                                </MudTd>
                                <MudTd DataLabel="Hash">
                                    <span style="font-family: monospace; font-size: 0.875rem; color: #4EE0FC;">
                                        @(string.IsNullOrEmpty(context.Hash) ? "–" : context.Hash.Length > 12 ? context.Hash[..8] + "…" + context.Hash[^4..] : context.Hash)
                                    </span>
                                </MudTd>
                                <MudTd DataLabel="Time" Style="font-size: 0.875rem;">@context.Time.ToLocalTime().ToString("MM-dd HH:mm")</MudTd>
                                <MudTd DataLabel="Reward (USD)" Style="color: #4caf50; font-size: 0.875rem;">
                                    @if (context.Chain == "LTC")
                                    {
                                        @(context.LtcPriceUsdAtFind > 0
                                            ? $"${LtcBlockReward * context.LtcPriceUsdAtFind:F2}"
                                            : _ltcPrice is not null ? $"${LtcBlockReward * _ltcPrice.UsdPrice:F2}" : "–")
                                    }
                                    else
                                    {
                                        @(context.DogePriceUsdAtFind > 0
                                            ? $"${DogeBlockReward * context.DogePriceUsdAtFind:F2}"
                                            : _dogePrice is not null ? $"${DogeBlockReward * _dogePrice.UsdPrice:F2}" : "–")
                                    }
                                </MudTd>
                                <MudTd DataLabel="Verify">
                                    <MudLink Href="@(context.Chain == "LTC"
                                                    ? $"https://blockchair.com/litecoin/block/{(string.IsNullOrEmpty(context.Hash) ? context.Height.ToString() : context.Hash)}"
                                                    : $"https://blockchair.com/dogecoin/block/{(string.IsNullOrEmpty(context.Hash) ? context.Height.ToString() : context.Hash)}")"
                                             Target="_blank" Style="color: #7e6fff;">
                                        <MudIcon Icon="@Icons.Material.Filled.OpenInNew" Style="font-size: 1.3rem;" />
                                    </MudLink>
                                </MudTd>
                            </RowTemplate>
                        </MudTable>
                    }
                    else
                    {
                        <div class="d-flex justify-center align-center" style="height:200px;">
                            <MudText Class="dim-text">No blocks found yet.</MudText>
                        </div>
                    }
                </MudPaper>
            </MudItem>
        </MudGrid>
        *@

        @* Per-Worker Block Stats *@
        @if (_workerBlockStats.Count > 0)
        {
            <MudPaper Class="glass-card pa-3 mb-3" Elevation="0">
                <div class="d-flex align-center gap-2 mb-2">
                    <MudIcon Icon="@Icons.Material.Filled.Person" Style="color:#7e6fff; font-size:1.2rem;" />
                    <MudText Style="font-weight:600; letter-spacing:0.05em; text-transform:uppercase; font-size:0.75rem; color:var(--mud-palette-text-secondary);">Per Miner / Worker</MudText>
                    <MudTooltip Text="Avg interval between consecutive blocks per worker address. Workers with only 1 block have no interval to calculate." Placement="Placement.Top" Arrow="true">
                        <MudIcon Icon="@Icons.Material.Outlined.Info" Class="stat-card-info-icon" Style="font-size:0.95rem; cursor:help;" />
                    </MudTooltip>
                </div>
                <MudTable Items="@_workerBlockStats.OrderByDescending(w => w.BlockCount)" Dense="true" Hover="true"
                          Style="background: transparent;" Breakpoint="Breakpoint.Sm">
                    <HeaderContent>
                        <MudTh Style="color: #7e6fff;">Worker</MudTh>
                        <MudTh Style="color: #7e6fff;">Blocks</MudTh>
                        <MudTh Style="color: #7e6fff;">Ø Interval</MudTh>
                        <MudTh Style="color: #7e6fff;">Last Block</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Worker">
                            <MudLink Href="@($"https://dogechain.info/address/{context.Worker}")" Target="_blank"
                                     Style="color: #7e6fff; font-family: monospace; font-size: 0.75rem;">
                                @(string.IsNullOrEmpty(context.Worker) ? "–" : context.Worker.Length > 16 ? context.Worker[..12] + "…" + context.Worker[^4..] : context.Worker)
                            </MudLink>
                        </MudTd>
                        <MudTd DataLabel="Blocks">
                            <MudText Style="color:#FFD700; font-weight:600;">@context.BlockCount</MudText>
                        </MudTd>
                        <MudTd DataLabel="Ø Interval">
                            @if (context.AvgInterval.HasValue)
                            {
                                <MudText Style="color:#4caf50; font-weight:600;">@FormatUptimeSpan(context.AvgInterval.Value)</MudText>
                            }
                            else
                            {
                                <MudText Class="dim-text">–</MudText>
                            }
                        </MudTd>
                        <MudTd DataLabel="Last Block" Style="font-size: 0.8rem;">@context.LastBlockTime.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</MudTd>
                    </RowTemplate>
                </MudTable>
            </MudPaper>
        }

        @* Full Block History Table *@
        @if (_recentBlocks.Count > 0)
        {
            <MudPaper Class="glass-card pa-4 mb-4" Elevation="0">
                <div class="d-flex align-center justify-space-between mb-3">
                    <MudText Typo="Typo.h6" Style="color: #7e6fff;">All Blocks (@_recentBlocks.Count total)</MudText>
                    <MudTextField @bind-Value="_allBlocksSearch" Placeholder="Search height, hash, worker, epoch, coin…"
                                  Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                                  Immediate="true" Clearable="true" Variant="Variant.Outlined"
                                  Margin="Margin.Dense" Style="max-width: 320px; margin-left: auto;" />
                </div>
                <MudTable Items="@_recentBlocks.OrderByDescending(b => b.Time)" Dense="true" Hover="true"
                          Style="background: transparent;" @bind-RowsPerPage="_allBlocksPageSize"
                          GroupBy="@_blockGroupDef" Filter="@(b => AllBlocksFilter(b))"
                          Breakpoint="Breakpoint.Sm">
                    <HeaderContent>
                        <MudTh Style="color: #7e6fff;">Coin</MudTh>
                        <MudTh Style="color: #7e6fff;">Height</MudTh>
                        <MudTh Style="color: #7e6fff;">Hash</MudTh>
                        <MudTh Style="color: #7e6fff;">Worker</MudTh>
                        <MudTh Style="color: #7e6fff;">Time</MudTh>
                        <MudTh Style="color: #7e6fff;">Reward (USD)</MudTh>
                        <MudTh Style="color: #7e6fff;">Confirmations</MudTh>
                        <MudTh Style="color: #7e6fff;">Verify</MudTh>
                    </HeaderContent>
                    <GroupHeaderTemplate>
                        <MudTh colspan="8" Style="background: rgba(78,224,252,0.10); padding: 4px 12px; border-left: 3px solid #4EE0FC;">
                            <MudText Typo="Typo.subtitle2" Style="color: #4EE0FC;">
                                @(context.Key is int k && k > 0 ? $"Epoch {k}" : "Epoch –")
                            </MudText>
                        </MudTh>
                    </GroupHeaderTemplate>
                    <RowTemplate>
                        <MudTd DataLabel="Coin">
                            @if (context.Chain == "LTC")
                            {
                                <MudChip T="string" Size="Size.Small" Style="background:#345D9D; color:#fff; font-weight:700; font-size:0.7rem; height:20px;">LTC</MudChip>
                            }
                            else
                            {
                                <MudChip T="string" Size="Size.Small" Style="background:#c8a400; color:#fff; font-weight:700; font-size:0.7rem; height:20px;">DOGE</MudChip>
                            }
                        </MudTd>
                        <MudTd DataLabel="Height">
                            <MudLink Href="@(context.Chain == "LTC" ? $"https://blockchair.com/litecoin/block/{context.Height}" : $"https://dogechain.info/block/{context.Height}")"
                                     Target="_blank" Style="color: #4EE0FC;">@context.Height</MudLink>
                        </MudTd>
                        <MudTd DataLabel="Hash">
                            <span style="font-family: monospace; font-size: 0.875rem; color: #4EE0FC;">
                                @(string.IsNullOrEmpty(context.Hash) ? "–" : context.Hash.Length > 16 ? context.Hash[..12] + "…" + context.Hash[^4..] : context.Hash)
                            </span>
                        </MudTd>
                        <MudTd DataLabel="Worker">
                            <MudLink Href="@(context.Chain == "LTC" ? $"https://blockchair.com/litecoin/address/{context.Worker}" : $"https://dogechain.info/address/{context.Worker}")"
                                     Target="_blank" Style="color: #7e6fff; font-family: monospace; font-size: 0.875rem;">
                                @(string.IsNullOrEmpty(context.Worker) ? "–" : context.Worker.Length > 16 ? context.Worker[..12] + "…" + context.Worker[^4..] : context.Worker)
                            </MudLink>
                        </MudTd>
                        <MudTd DataLabel="Time" Style="font-size: 0.875rem;">@context.Time.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</MudTd>
                        <MudTd DataLabel="Reward (USD)" Style="color: #4caf50; font-size: 0.875rem;">
                            @if (context.Chain == "LTC")
                            {
                                @(context.LtcPriceUsdAtFind > 0
                                    ? $"${LtcBlockReward * context.LtcPriceUsdAtFind:F2}"
                                    : _ltcPrice is not null ? $"${LtcBlockReward * _ltcPrice.UsdPrice:F2}" : "–")
                            }
                            else
                            {
                                @(context.DogePriceUsdAtFind > 0
                                    ? $"${DogeBlockReward * context.DogePriceUsdAtFind:F2}"
                                    : _dogePrice is not null ? $"${DogeBlockReward * _dogePrice.UsdPrice:F2}" : "–")
                            }
                        </MudTd>
                        <MudTd DataLabel="Confirmations">
                            @if (context.Chain == "LTC")
                            {
                                <MudChip T="string" Size="Size.Small" Color="Color.Default">–</MudChip>
                            }
                            else
                            {
                                var confFull = _networkStats?.BestBlockHeight > 0 && context.Height > 0
                                    ? _networkStats!.BestBlockHeight - context.Height + 1 : (long?)null;
                                if (confFull is null)
                                {
                                    <MudChip T="string" Size="Size.Small" Color="Color.Warning">Pending</MudChip>
                                }
                                else if (confFull >= 100)
                                {
                                    <MudChip T="string" Size="Size.Small" Color="Color.Success">@($"{confFull:N0}")</MudChip>
                                }
                                else
                                {
                                    <MudChip T="string" Size="Size.Small" Color="Color.Warning">@($"{confFull:N0}")</MudChip>
                                }
                            }
                        </MudTd>
                        <MudTd DataLabel="Verify">
                            <MudLink Href="@(context.Chain == "LTC"
                                            ? $"https://blockchair.com/litecoin/block/{(string.IsNullOrEmpty(context.Hash) ? context.Height.ToString() : context.Hash)}"
                                            : $"https://blockchair.com/dogecoin/block/{(string.IsNullOrEmpty(context.Hash) ? context.Height.ToString() : context.Hash)}")"
                                     Target="_blank" Style="color: #7e6fff;">
                                <MudIcon Icon="@Icons.Material.Filled.OpenInNew" Style="font-size: 1.3rem;" />
                            </MudLink>
                        </MudTd>
                    </RowTemplate>
                    <PagerContent>
                        <MudTablePager PageSizeOptions="@_tablePagSizes" />
                    </PagerContent>
                </MudTable>
            </MudPaper>
        }

    </MudTabPanel>

    @* ── Profitability Tab ── *@
    <MudTabPanel Text="Profitability" Icon="@Icons.Material.Filled.TrendingUp">

        @* ── Qubic vs. Direct DOGE Comparison ── *@
        @{
            double netHashGHs    = (_networkStats?.NetworkHashrate ?? 0) / 1_000_000_000.0;
            double dogePrice     = (double)(_dogePrice?.UsdPrice ?? 0);
            double quPriceUsd    = _quPriceManual > 0 ? _quPriceManual : (double)(_quPrice?.UsdPrice ?? 0);
            double blocksPerDay  = 1440.0; // DOGE ~60s block time
            double dogePerGHDay  = netHashGHs > 0 ? blocksPerDay * 10_000 / netHashGHs : 0;
            double directUsdGH   = dogePerGHDay * dogePrice;
            double viaQubicUsdGH = directUsdGH * (1 + _quBonusPct / 100.0);
            double quPerGHDay    = quPriceUsd > 0 ? viaQubicUsdGH / quPriceUsd : 0;
            double diffPct       = directUsdGH > 0 ? (_quBonusPct) : 0;
        }

        <MudText Typo="Typo.h6" Class="mb-1" Style="color:#7e6fff;">Direct DOGE Mining vs. Via Qubic</MudText>
        <MudText Typo="Typo.caption" Class="dim-text mb-4 d-block">
            Comparison per 1 GH/s · Mining DOGE via Qubic pays out in QU tokens from partner pools
        </MudText>

        @* Bonus input + QU price *@
        <MudGrid Spacing="3" Class="mb-2">
            <MudItem xs="12" sm="6" md="4" Style="display:flex;">
                <MudPaper Class="glass-card pa-3" Elevation="0" Style="width:100%;">
                    <MudNumericField T="double"
                                     Label="Qubic Bonus %"
                                     @bind-Value="_quBonusPct"
                                     Min="0" Max="500" Step="0.5"
                                     Format="F1"
                                     Variant="Variant.Outlined"
                                     Margin="Margin.Dense"
                                     Adornment="Adornment.End"
                                     AdornmentText="%" />
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="6" md="4" Style="display:flex;">
                <MudPaper Class="glass-card pa-3" Elevation="0" Style="width:100%;">
                    <MudNumericField T="double"
                                     Label="QU Price (USD)"
                                     @bind-Value="_quPriceManual"
                                     Min="0" Max="1" Step="0.000000001"
                                     Format="F9"
                                     Variant="Variant.Outlined"
                                     Margin="Margin.Dense"
                                     Adornment="Adornment.Start"
                                     AdornmentText="$" />
                </MudPaper>
            </MudItem>
        </MudGrid>
        <MudPaper Class="glass-card pa-3 mb-4" Elevation="0">
            <MudText Typo="Typo.caption" Class="dim-text">
                <b style="color:#FFD700;">Phase 1 (Apr 2026, pool reserves):</b> Community data (Eko):
                DG1+ 13 GH/s → $8.78/day via Qubic vs. $5.75/day direct
                (<b style="color:#4caf50;">+53 %</b>).
                <b>Phase 2 target: ~+10 %</b> via buyback mechanism —
                <a href="https://qubic.org/blog-detail/qubic-doge-mining-pool-setup-dashboard-guide"
                   target="_blank" rel="noopener"
                   style="color:#FFD700; text-decoration:underline;">
                    qubic.org guide (Apr 10, 2026)
                </a>
            </MudText>
        </MudPaper>

        @* Comparison table *@
        <MudPaper Class="glass-card pa-4 mb-4" Elevation="0">
            <MudGrid Spacing="4">
                @* Direct DOGE *@
                <MudItem xs="12" sm="6">
                    <div style="border-left: 3px solid #7e6fff; padding-left: 12px;">
                        <MudText Typo="Typo.caption" Class="dim-text mb-1 d-block" Style="text-transform:uppercase; letter-spacing:0.5px;">Direct DOGE Mining</MudText>
                        <MudText Typo="Typo.h4" Style="color:#7e6fff; font-weight:700;">
                            @(directUsdGH > 0 ? $"${directUsdGH:F4}" : "–")
                            <span style="font-size:0.9rem; font-weight:400; color:var(--mud-palette-text-secondary);">/GH/day</span>
                        </MudText>
                        <div class="d-flex gap-4 mt-2 flex-wrap">
                            <div>
                                <MudText Typo="Typo.caption" Class="dim-text">DOGE/GH/day</MudText>
                                <MudText Typo="Typo.body2" Style="color:#7e6fff; font-weight:600;">@(dogePerGHDay > 0 ? $"{dogePerGHDay:F4}" : "–")</MudText>
                            </div>
                            <div>
                                <MudText Typo="Typo.caption" Class="dim-text">DOGE/TH/day</MudText>
                                <MudText Typo="Typo.body2" Style="color:#7e6fff; font-weight:600;">@(dogePerGHDay > 0 ? $"{dogePerGHDay * 1000:F2}" : "–")</MudText>
                            </div>
                            <div>
                                <MudText Typo="Typo.caption" Class="dim-text">USD/TH/day</MudText>
                                <MudText Typo="Typo.body2" Style="color:#7e6fff; font-weight:600;">@(directUsdGH > 0 ? $"${directUsdGH * 1000:F2}" : "–")</MudText>
                            </div>
                        </div>
                    </div>
                </MudItem>

                @* Via Qubic *@
                <MudItem xs="12" sm="6">
                    <div style="border-left: 3px solid #FFD700; padding-left: 12px;">
                        <MudText Typo="Typo.caption" Class="dim-text mb-1 d-block" Style="text-transform:uppercase; letter-spacing:0.5px;">Via Qubic (paid in QU)</MudText>
                        <MudText Typo="Typo.h4" Style="color:#FFD700; font-weight:700;">
                            @(viaQubicUsdGH > 0 ? $"${viaQubicUsdGH:F4}" : "–")
                            <span style="font-size:0.9rem; font-weight:400; color:var(--mud-palette-text-secondary);">/GH/day</span>
                        </MudText>
                        <div class="d-flex gap-4 mt-2 flex-wrap">
                            <div>
                                <MudText Typo="Typo.caption" Class="dim-text">QU/GH/day</MudText>
                                <MudText Typo="Typo.body2" Style="color:#FFD700; font-weight:600;">@(quPerGHDay > 0 ? $"{quPerGHDay:F0}" : "–")</MudText>
                            </div>
                            <div>
                                <MudText Typo="Typo.caption" Class="dim-text">QU/TH/day</MudText>
                                <MudText Typo="Typo.body2" Style="color:#FFD700; font-weight:600;">@(quPerGHDay > 0 ? $"{quPerGHDay * 1000:N0}" : "–")</MudText>
                            </div>
                            <div>
                                <MudText Typo="Typo.caption" Class="dim-text">USD/TH/day</MudText>
                                <MudText Typo="Typo.body2" Style="color:#FFD700; font-weight:600;">@(viaQubicUsdGH > 0 ? $"${viaQubicUsdGH * 1000:F2}" : "–")</MudText>
                            </div>
                        </div>
                    </div>
                </MudItem>
            </MudGrid>

            @* Difference banner *@
            @if (directUsdGH > 0 && _quBonusPct > 0)
            {
                <div style="margin-top:16px; padding:10px 14px; border-radius:8px; background:rgba(76,175,80,0.1); border:1px solid rgba(76,175,80,0.25); display:flex; align-items:center; gap:10px; flex-wrap:wrap;">
                    <MudIcon Icon="@Icons.Material.Filled.TrendingUp" Style="color:#4caf50;" />
                    <MudText Typo="Typo.body2" Style="color:#4caf50; font-weight:700;">
                        +@(_quBonusPct.ToString("F1")) % more yield via Qubic
                    </MudText>
                    <MudText Typo="Typo.caption" Class="dim-text">
                        = $@((viaQubicUsdGH - directUsdGH).ToString("F4")) extra per GH/day · $@(((viaQubicUsdGH - directUsdGH) * 1000).ToString("F2")) per TH/day
                    </MudText>
                </div>
            }
        </MudPaper>

        @* Partner pools *@
        <div class="d-flex align-center gap-3 mb-2 flex-wrap">
            <MudText Typo="Typo.subtitle2" Style="color:var(--mud-palette-text-secondary); text-transform:uppercase; letter-spacing:0.5px; font-size:0.75rem;">Qubic DOGE Mining Partner Pools</MudText>
            <MudChip T="string" Size="Size.Small" Style="background:rgba(76,175,80,0.15); color:#4caf50; font-weight:700; font-size:0.7rem;">0 % Fee · Launch Phase</MudChip>
        </div>
        <MudGrid Spacing="3" Class="mb-2">
            @foreach (var pool in _partnerPools)
            {
                <MudItem xs="12" sm="6" md="3" Style="display:flex;">
