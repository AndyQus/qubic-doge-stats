            <MudChip T="string" Color="@(_visitorPeriod == "months" ? Color.Primary : Color.Default)" Variant="Variant.Filled" Size="Size.Small" OnClick="@(() => _visitorPeriod = "months")">By Month</MudChip>
            <MudChip T="string" Color="@(_visitorPeriod == "years"  ? Color.Primary : Color.Default)" Variant="Variant.Filled" Size="Size.Small" OnClick="@(() => _visitorPeriod = "years")" >By Year</MudChip>
        </div>

        @* Page Views chart *@
        <MudGrid Class="mb-4" Spacing="3">
            <MudItem xs="12">
                <MudPaper Class="glass-card pa-2" Elevation="0" Style="overflow:visible;">
                    <div class="d-flex justify-space-between align-end mb-3 flex-wrap gap-1">
                        <MudText Typo="Typo.h6" Style="color:#7e6fff;">
                            Page Views @(_visitorPeriod == "days" ? "(Last 30 Days)" : _visitorPeriod == "months" ? "(By Month)" : "(By Year)")
                        </MudText>
                        <MudText Typo="Typo.caption" Class="dim-text">auto 30 s · last update: @_visitorLastRefresh.ToLocalTime().ToString("HH:mm:ss")</MudText>
                    </div>
                    @if (_visitorPeriod == "days" && _visitorStats?.Last30Days.Count > 0)
                    {
                        <ApexCharts.ApexChart TItem="DailyVisitorCount" Options="@_apexVisitorOptions" @ref="_apexVisitorChart" Height="280">
                            <ApexCharts.ApexPointSeries TItem="DailyVisitorCount"
                                Items="@_visitorStats.Last30Days" SeriesType="ApexCharts.SeriesType.Area" Name="Page Views"
                                XValue="@(p => DateTime.Parse(p.Date, System.Globalization.CultureInfo.InvariantCulture).ToLocalTime())"
                                YValue="@(p => (decimal)p.PageViews)" OrderBy="p => p.X" />
                        </ApexCharts.ApexChart>
                    }
                    else if (_visitorPeriod == "months" && _visitorStats?.Last24Months.Count > 0)
                    {
                        <ApexCharts.ApexChart TItem="MonthlyVisitorCount" Options="@_apexVisitorMonthOptions" Height="280">
                            <ApexCharts.ApexPointSeries TItem="MonthlyVisitorCount"
                                Items="@_visitorStats.Last24Months" SeriesType="ApexCharts.SeriesType.Bar" Name="Page Views"
                                XValue="@(p => p.Month)"
                                YValue="@(p => (decimal)p.PageViews)" OrderBy="p => p.X" />
                        </ApexCharts.ApexChart>
                    }
                    else if (_visitorPeriod == "years" && _visitorStats?.AllYears.Count > 0)
                    {
                        <ApexCharts.ApexChart TItem="YearlyVisitorCount" Options="@_apexVisitorYearOptions" Height="280">
                            <ApexCharts.ApexPointSeries TItem="YearlyVisitorCount"
                                Items="@_visitorStats.AllYears" SeriesType="ApexCharts.SeriesType.Bar" Name="Page Views"
                                XValue="@(p => p.Year.ToString())"
                                YValue="@(p => (decimal)p.PageViews)" OrderBy="p => p.X" />
                        </ApexCharts.ApexChart>
                    }
                    else
                    {
                        <div class="d-flex justify-center align-center" style="height:280px;">
                            <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
                            <MudText Class="ml-3 dim-text">Collecting visitor data…</MudText>
                        </div>
                    }
                </MudPaper>
            </MudItem>
        </MudGrid>

        @* Second row: Unique Visitors chart + Top Countries *@
        <MudGrid Class="mb-4" Spacing="3">
            <MudItem xs="12" md="6">
                <MudPaper Class="glass-card pa-2" Elevation="0" Style="height:100%;">
                    <MudText Typo="Typo.h6" Class="mb-3" Style="color:#7e6fff;">
                        Unique Visitors @(_visitorPeriod == "days" ? "(Last 30 Days)" : _visitorPeriod == "months" ? "(By Month)" : "(By Year)")
                    </MudText>
                    @if (_visitorPeriod == "days" && _visitorStats?.Last30Days.Count > 0)
                    {
                        <ApexCharts.ApexChart TItem="DailyVisitorCount" Options="@_apexUniqueVisitorOptions" Height="260">
                            <ApexCharts.ApexPointSeries TItem="DailyVisitorCount"
                                Items="@_visitorStats.Last30Days" SeriesType="ApexCharts.SeriesType.Line" Name="Unique Visitors"
                                XValue="@(p => DateTime.Parse(p.Date, System.Globalization.CultureInfo.InvariantCulture).ToLocalTime())"
                                YValue="@(p => (decimal)p.UniqueVisitors)" OrderBy="p => p.X" />
                        </ApexCharts.ApexChart>
                    }
                    else if (_visitorPeriod == "months" && _visitorStats?.Last24Months.Count > 0)
                    {
                        <ApexCharts.ApexChart TItem="MonthlyVisitorCount" Options="@_apexUniqueVisitorMonthOptions" Height="260">
                            <ApexCharts.ApexPointSeries TItem="MonthlyVisitorCount"
                                Items="@_visitorStats.Last24Months" SeriesType="ApexCharts.SeriesType.Bar" Name="Unique Visitors"
                                XValue="@(p => p.Month)"
                                YValue="@(p => (decimal)p.UniqueVisitors)" OrderBy="p => p.X" />
                        </ApexCharts.ApexChart>
                    }
                    else if (_visitorPeriod == "years" && _visitorStats?.AllYears.Count > 0)
                    {
                        <ApexCharts.ApexChart TItem="YearlyVisitorCount" Options="@_apexUniqueVisitorYearOptions" Height="260">
                            <ApexCharts.ApexPointSeries TItem="YearlyVisitorCount"
                                Items="@_visitorStats.AllYears" SeriesType="ApexCharts.SeriesType.Bar" Name="Unique Visitors"
                                XValue="@(p => p.Year.ToString())"
                                YValue="@(p => (decimal)p.UniqueVisitors)" OrderBy="p => p.X" />
                        </ApexCharts.ApexChart>
                    }
                    else
                    {
                        <div class="d-flex justify-center align-center" style="height:260px;">
                            <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
                        </div>
                    }
                </MudPaper>
            </MudItem>
            <MudItem xs="12" md="6">
                <MudPaper Class="glass-card pa-3" Elevation="0" Style="height:100%;">
                    <MudText Typo="Typo.h6" Class="mb-3" Style="color:#7e6fff;">
                        Top Countries @(_visitorPeriod == "days" ? "(Last 30 Days)" : "(All Time)")
                    </MudText>
                    @{
                        var countryList = _visitorPeriod == "days"
                            ? _visitorStats?.TopCountries30Days
                            : _visitorStats?.TopCountriesAllTime;
                    }
                    @if (countryList?.Count > 0)
                    {
                        <MudSimpleTable Dense="true" Hover="true" Style="background:transparent;">
                            <thead>
                                <tr>
                                    <th style="color:#7e6fff;">#</th>
                                    <th style="color:#7e6fff;">Country</th>
                                    <th style="color:#7e6fff; text-align:right;">Views</th>
                                </tr>
                            </thead>
                            <tbody>
                                @{ int rank = 1; }
                                @foreach (var country in countryList)
                                {
                                    <tr>
                                        <td style="color:var(--mud-palette-text-secondary); font-size:0.8rem;">@rank</td>
                                        <td>
                                            <span style="font-size:1.1rem; margin-right:6px;">@GetCountryFlag(country.CountryCode)</span>
                                            <span style="font-size:0.85rem;">@country.CountryName</span>
                                        </td>
                                        <td style="text-align:right; color:#4EE0FC; font-weight:600; font-size:0.85rem;">@country.Count.ToString("N0")</td>
                                    </tr>
                                    rank++;
                                }
                            </tbody>
                        </MudSimpleTable>
                    }
                    else
                    {
                        <div class="d-flex justify-center align-center" style="height:260px;">
                            <MudText Class="dim-text">No geo data yet.</MudText>
                        </div>
                    }
                </MudPaper>
            </MudItem>
        </MudGrid>

    </MudTabPanel>
    } @* end @if (_showVisitorTab) *@

</MudTabs>

</div> @* end extended view *@

@code {
