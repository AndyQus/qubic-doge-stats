                </RowTemplate>
            </MudTable>
        </MudPaper>
        <MudText Typo="Typo.caption" Class="dim-text mt-2 d-block">
            Profit = (DOGE + LTC Revenue) − (Power × 24h × $/kWh) · Network hashrate: @(_networkStats is not null ? $"{_networkStats.NetworkHashrate / 1_000_000_000_000.0:F2} TH/s" : "–")
        </MudText>


    </MudTabPanel>

    @* ── Visitors Tab — only visible with ?admin=true ── *@
    @if (_showVisitorTab)
    {
    <MudTabPanel Text="Visitors" Icon="@Icons.Material.Filled.People">

        <MudAlert Severity="Severity.Info" Variant="Variant.Text" Class="mb-4" Icon="@Icons.Material.Filled.Shield">
            <strong>Privacy-first analytics:</strong> No cookies, no third-party trackers, no personal data stored.
            IP addresses are irreversibly hashed (SHA-256) before storage and cannot be traced back to individuals.
            Geo-location is resolved to country level only. All data is self-hosted.
        </MudAlert>

        @* Top row: 4 stat cards *@
        <MudGrid Class="mb-4" Spacing="3">
            <MudItem xs="12" sm="6" md="3">
                <StatCard Icon="@Icons.Material.Filled.PersonPin"
