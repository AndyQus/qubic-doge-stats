    private double _profPowerCost = 0.08;

    private record L7Spec(string Model, int HashrateGHs, int PowerWatts);

    private static readonly L7Spec[] _l7Specs =
    [
        new("Antminer L7 9500Mh",  9500, 3425),
        new("Antminer L7 9300Mh",  9300, 3425),
        new("Antminer L7 9160Mh",  9160, 3225),
        new("Antminer L7 9050Mh",  9050, 3260),
    ];

    private record L7Row(string Model, int HashrateGHs, int PowerWatts,
        double DogeRevenue24hUsd, double LtcRevenue24hUsd,
        double Profit24hUsd, double BreakevenKwh)
    {
        public double TotalRevenue24hUsd => DogeRevenue24hUsd + LtcRevenue24hUsd;
    }

    private List<L7Row> GetL7Profitability()
    {
        // DOGE: ~10,000 DOGE block reward, ~1 block/min = 1440 blocks/day network-wide
        const double dogePerBlock    = 10_000.0;
        const double dogeBlocksPerDay = 1440.0;
        // LTC: 6.25 LTC block reward, ~2.5 min block time = 576 blocks/day network-wide
        const double ltcPerBlock     = 6.25;
        const double ltcBlocksPerDay = 576.0;

        double dogeNetworkGHs = _networkStats?.NetworkHashrate / 1_000_000_000.0 ?? 0;
        double dogeUsd = _dogePrice is not null ? (double)_dogePrice.UsdPrice : 0;
        double ltcUsd  = _ltcPrice  is not null ? (double)_ltcPrice.UsdPrice  : 0;

        return _l7Specs.Select(s =>
        {
            double minerGHs = s.HashrateGHs / 1000.0;  // MH/s → GH/s

            // DOGE revenue uses network hashrate from blockchair
            double dogeRevenue = dogeNetworkGHs > 0 && dogeUsd > 0
                ? (minerGHs / dogeNetworkGHs) * dogeBlocksPerDay * dogePerBlock * dogeUsd
                : 0;

            // LTC uses same hashrate (merged mining) but LTC network hashrate
            // Approximate LTC network as same order of magnitude as DOGE (both Scrypt)
            // Use dogeNetworkGHs as proxy since merged mining shares the same hashrate
            double ltcRevenue = dogeNetworkGHs > 0 && ltcUsd > 0
                ? (minerGHs / dogeNetworkGHs) * ltcBlocksPerDay * ltcPerBlock * ltcUsd
                : 0;

            double totalRevenue = dogeRevenue + ltcRevenue;
            double powerCost = s.PowerWatts / 1000.0 * 24 * _profPowerCost;
            double profit    = totalRevenue > 0 ? totalRevenue - powerCost : 0;
            double breakeven = totalRevenue > 0 ? totalRevenue / (s.PowerWatts / 1000.0 * 24) : 0;
            return new L7Row(s.Model, s.HashrateGHs, s.PowerWatts, dogeRevenue, ltcRevenue, profit, breakeven);
        }).ToList();
    }

