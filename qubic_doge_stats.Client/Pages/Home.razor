    private void BuildEpochRevenueChart()
    {
        if (_recentBlocks.Count == 0) return;

        const decimal dogePerBlock = 10_000m;
        const decimal ltcPerBlock  = 6.25m;

        // Group blocks by epoch, calculate USD value at time of find
        var epochRevenue = _recentBlocks
            .Where(b => b.QubicEpoch > 0)
            .GroupBy(b => b.QubicEpoch)
            .OrderBy(g => g.Key)
            .Select(g =>
            {
                var dogeBlocks = g.Where(b => b.Chain != "LTC").ToList();
                var ltcBlocks  = g.Where(b => b.Chain == "LTC").ToList();

                double dogeUsd = dogeBlocks.Sum(b =>
                    b.DogePriceUsdAtFind > 0 ? (double)(dogePerBlock * b.DogePriceUsdAtFind)
                    : _dogePrice is not null   ? (double)(dogePerBlock * _dogePrice.UsdPrice) : 0);

                double ltcUsd = ltcBlocks.Sum(b =>
                    b.LtcPriceUsdAtFind > 0 ? (double)(ltcPerBlock * b.LtcPriceUsdAtFind)
                    : _ltcPrice is not null   ? (double)(ltcPerBlock * _ltcPrice.UsdPrice) : 0);

                return (Epoch: g.Key, DogeUsd: dogeUsd, LtcUsd: ltcUsd, TotalUsd: dogeUsd + ltcUsd);
            })
            .ToList();

        if (epochRevenue.Count == 0) return;

        _epochRevenueLabels = epochRevenue.Select(x => $"Ep {x.Epoch}").ToArray();
        _epochRevenueSeries =
        [
            new ChartSeries<double>
            {
                Name = "DOGE (USD)",
                Data = epochRevenue.Select(x => x.DogeUsd).ToArray(),
                TooltipYValueFormat = "F0"
            },
            new ChartSeries<double>
            {
                Name = "LTC (USD)",
                Data = epochRevenue.Select(x => x.LtcUsd).ToArray(),
                TooltipYValueFormat = "F0"
            }
        ];

        var curEpoch = _latest?.QubicEpoch ?? 0;
        _currentEpochRevenueUsd = curEpoch > 0
            ? epochRevenue.FirstOrDefault(x => x.Epoch == curEpoch).TotalUsd : 0;

        var best = epochRevenue.MaxBy(x => x.TotalUsd);
        _bestEpochRevenueUsd   = best.TotalUsd;
        _bestEpochRevenueEpoch = best.Epoch;

        _totalRevenueUsd = epochRevenue.Sum(x => x.TotalUsd);
    }

    private void BuildEpochTimelineData()
    {
        _epochTimelineSeries = [];
        _epochTimelineLabels = [];

        var currentEpoch = _latest?.QubicEpoch ?? 0;
        if (currentEpoch == 0 || _fullHistory.Count == 0) return;

        // Filter by epoch tag — includes early-reporting snapshots before 12:00 UTC
        var epochData = _fullHistory
            .Where(h => h.QubicEpoch == currentEpoch)
            .OrderBy(h => h.Timestamp)
            .ToList();

        if (epochData.Count == 0) return;

        // Use Wed 12:00 UTC boundary of this epoch as reference start;
        // clamp backwards if RPC reported the epoch a few minutes early.
        var epochStart = GetEpochStart(epochData.Last().Timestamp.UtcDateTime);
        var actualStart = epochData[0].Timestamp.UtcDateTime < epochStart
            ? epochData[0].Timestamp.UtcDateTime
            : epochStart;

        string[] allDays = ["Sun", "Mon", "Tue", "Wed", "Thu", "Fri", "Sat"];

        var byDay = epochData
            .GroupBy(h => (int)((h.Timestamp.UtcDateTime - actualStart).TotalHours / 24))
            .Where(g => g.Key >= 0 && g.Key < 7)
            .OrderBy(g => g.Key)
            .ToList();

        if (byDay.Count == 0) return;

        var timelineData = byDay.Select(g => g.Average(h => ToTeraHashPerSecond(h.Hashrate))).ToArray();
        _epochTimelineSeries =
        [
            new ChartSeries<double>
            {
                Name = "Avg TH/s",
                Data = timelineData,
                TooltipYValueFormat = "F2"
            }
        ];

        int startDow = (int)actualStart.DayOfWeek;
        _epochTimelineLabels = byDay.Select(g => allDays[(startDow + g.Key) % 7]).ToArray();
    }

