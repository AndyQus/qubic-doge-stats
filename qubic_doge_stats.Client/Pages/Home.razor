    private bool AllBlocksFilter(PoolBlock b)
    {
        if (string.IsNullOrWhiteSpace(_allBlocksSearch)) return true;
        var s = _allBlocksSearch.Trim();
        return b.Height.ToString().Contains(s, StringComparison.OrdinalIgnoreCase)
            || (!string.IsNullOrEmpty(b.Hash) && b.Hash.Contains(s, StringComparison.OrdinalIgnoreCase))
            || (!string.IsNullOrEmpty(b.Worker) && b.Worker.Contains(s, StringComparison.OrdinalIgnoreCase))
            || b.QubicEpoch.ToString().Contains(s, StringComparison.OrdinalIgnoreCase)
            || (!string.IsNullOrEmpty(b.Chain) && b.Chain.Contains(s, StringComparison.OrdinalIgnoreCase));
    }
