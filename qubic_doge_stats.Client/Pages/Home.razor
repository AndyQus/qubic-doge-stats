        @* Table *@
        <MudPaper Class="glass-card" Elevation="0">
            <MudTable Items="@GetL7Profitability()" Dense="true" Hover="true"
                      Breakpoint="Breakpoint.Sm" Style="background:transparent;">
                <HeaderContent>
                    <MudTh Style="color:var(--mud-palette-text-secondary); font-size:0.75rem;">Model</MudTh>
                    <MudTh Style="color:var(--mud-palette-text-secondary); font-size:0.75rem; text-align:right;">Hashrate</MudTh>
                    <MudTh Style="color:var(--mud-palette-text-secondary); font-size:0.75rem; text-align:right;">Power</MudTh>
                    <MudTh Style="color:var(--mud-palette-text-secondary); font-size:0.75rem; text-align:right;">Revenue 24h</MudTh>
                    <MudTh Style="color:var(--mud-palette-text-secondary); font-size:0.75rem; text-align:right;">Profit 24h</MudTh>
                    <MudTh Style="color:var(--mud-palette-text-secondary); font-size:0.75rem; text-align:right;">Break-even</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd Style="font-size:0.85rem; font-weight:600;">@context.Model</MudTd>
                    <MudTd Style="text-align:right; font-size:0.85rem;">@($"{context.HashrateGHs / 1000.0:F2} GH/s")</MudTd>
                    <MudTd Style="text-align:right; font-size:0.85rem; color:var(--mud-palette-text-secondary);">@context.PowerWatts W</MudTd>
