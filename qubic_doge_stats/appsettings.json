{
  "DogeStats": {
    "ApiUrl": "https://doge-stats.qubic.org/dispatcher.json",
    "PollIntervalSeconds": 60
  },
  "QubicRpc": {
    "BaseUrl": "https://rpc.qubic.org/"
  },
  "LiteDb": {
    "Filename": "Data/doge_stats.db"
  },
  "PoolStats": {
    "ApiUrl": "https://doge-stats.qubic.org/pool.json"
  },
  "DataBackfill": {
    "Enabled": false
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
